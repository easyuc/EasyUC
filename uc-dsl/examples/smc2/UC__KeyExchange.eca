(* UC__KeyExchange.eca *)

(* The user's part of the KeyExchange security proof. *)

(*! Bound_RFIP_IF(PathPfx, Env, Adv, func, in_guard)
`|Pr[<<PathPfx>>DDH1(DDH_Adv(<<Env>>, <<Adv>>)).main(<<func>>, <<in_guard>>) @ &m : res] -
  Pr[<<PathPfx>>DDH2(DDH_Adv(<<Env>>, <<Adv>>)).main(<<func>>, <<in_guard>>) @ &m : res]|
*)

require import UCCore FMap.

require UC___KeyExchange.
clone include UC___KeyExchange.

(* real functionality has no parameters, so real functionality with
   ideal parameters is the same as real functionality with real
   parameters *)

module RFIP = RFRP.

require DDH.

clone export DDH as DDH' with
  type input <- (addr * int fset),
  type key   <- key,
  type exp   <- exp,
  op ( * )   <- ( * ),
  op dexp    <- dexp,
  op g       <- g,
  op (^)     <- (^)
proof *.
realize dexp_ll. apply dexp_ll. qed.
realize dexp_uni. apply dexp_uni. qed.
realize dexp_fu. apply dexp_fu. qed.
 
(* we make a DDH oracle adversary out of an environment and
   adversary *)

type ddh_func_state = [
  | DDHFuncStateWaitReq1
  | DDHFuncStateWaitAdv1 of port & port
  | DDHFuncStateWaitReq2 of port & port
  | DDHFuncStateWaitAdv2 of port
  | DDHFuncStateFinal
].

module (DDHOrAdv (Env : ENV, Adv : ADV) : DDH_OR_ADV) (Or : DDH_OR) = {
  module DDHFunc : FUNC = {
    var self : addr
    var st : ddh_func_state

    proc init(self_ : addr) : unit = {
      self <- self_;
      st <- DDHFuncStateWaitReq1;
    }

    proc state_DDHFuncStateWaitReq1(pt1 : port, pt2 : port) : msg option = {
      var _r : msg option <- None;
      var _pt1 : port <- _intport_Pt1 self;
      var _pt2 : port <- _intport_Pt2 self;
      var k1 : key; var u : univ;
      if (envport self pt2) {
        k1 <@ Or.get(One);
        u <- KeyExp'.epdp_port_port_key_univ.`enc (pt1, pt2, k1);
        _r <-
          Some
          (Forwarding1.UC_FwAdv.epdp__fw_obs.`enc
           {|Forwarding1.UC_FwAdv.fw_obs___func = _addr_Fw1 self;
             Forwarding1.UC_FwAdv.fw_obs___adv  = adv;
             Forwarding1.UC_FwAdv.fw_obs__pt1   = _pt1;
             Forwarding1.UC_FwAdv.fw_obs__pt2   = _pt2;
             Forwarding1.UC_FwAdv.fw_obs__u     = u|});
        st <- DDHFuncStateWaitAdv1 pt1 pt2;
      }
      else { _r <- None; }
      return _r;
    }

    proc state_DDHFuncStateWaitAdv1(pt1 : port, pt2 : port)
           : msg option = {
      var k3 : key; var _r : msg option <- None;
      Or.get(Two); k3 <@ Or.get(Three);
      _r <-
        Some
        (UC_KEDir.Pt2.epdp__ke_rsp1.`enc
         {|UC_KEDir.Pt2.ke_rsp1___func = self;
           UC_KEDir.Pt2.ke_rsp1__pt2   = pt2;
           UC_KEDir.Pt2.ke_rsp1__pt1   = pt1;
           UC_KEDir.Pt2.ke_rsp1__k     = k3|});
      st <- DDHFuncStateWaitReq2 pt1 pt2;
      return _r;
    }

    proc state_DDHFuncStateWaitReq2(pt1 : port, pt2 : port, pt2' : port)
           : msg option = {
      var u : univ; var k2 : key;
      var _pt1 : port <- _intport_Pt2 self;
      var _pt2 : port <- _intport_Pt1 self;
      var _r : msg option <- None;
      k2 <@ Or.get(Two);
      if (pt2' = pt2) {
        u <- KeyExp'.epdp_key_univ.`enc k2;
        _r <- Some
          (Forwarding2.UC_FwAdv.epdp__fw_obs.`enc
           {|Forwarding2.UC_FwAdv.fw_obs___func = _addr_Fw2 self;
             Forwarding2.UC_FwAdv.fw_obs___adv  = adv;
             Forwarding2.UC_FwAdv.fw_obs__pt1   = _pt1;
             Forwarding2.UC_FwAdv.fw_obs__pt2   = _pt2;
             Forwarding2.UC_FwAdv.fw_obs__u     = u|});
        st <- DDHFuncStateWaitAdv2 pt1;
      }
      return _r;
    }

    proc state_DDHFuncStateWaitAdv2(pt1 : port) : msg option = {
      var _r : msg option <- None;
      var k3 : key;
      k3 <@ Or.get(Three);
      _r <-
        Some
        (UC_KEDir.Pt1.epdp__ke_rsp2.`enc
         {|UC_KEDir.Pt1.ke_rsp2___func = self;
           UC_KEDir.Pt1.ke_rsp2__pt1   = pt1;
           UC_KEDir.Pt1.ke_rsp2__k     = k3|});
      st <- DDHFuncStateFinal;
      return _r;
    }
  
    proc invoke(m : msg) : msg option = {
      var r : msg option <- None;
      match st with
      | DDHFuncStateWaitReq1         => {
        if (m.`1 = Dir /\  m.`2 = _extport_dir_Pt1 self /\
            envport self m.`3) {
          match UC_KEDir.Pt1.epdp__ke_req1.`dec m with
          | Some x => {
              r <@ state_DDHFuncStateWaitReq1
                   (x.`UC_KEDir.Pt1.ke_req1__pt1,
                    x.`UC_KEDir.Pt1.ke_req1__pt2);
            }
          | None   => {}
          end;
        }
      }
      | DDHFuncStateWaitAdv1 pt1 pt2 => {
        if (m.`1 = Adv /\ m.`2.`1 = _addr_Fw1 self /\ m.`3.`1 = adv) { 
          match Forwarding1.UC_FwAdv.epdp__fw_ok.`dec m with
          | Some _ => {
              r <@ state_DDHFuncStateWaitAdv1(pt1, pt2);
            }
          | None   => {}
          end;
        }
      }
      | DDHFuncStateWaitReq2 pt1 pt2 => {
        if (m.`1 = Dir /\ m.`2 = _extport_dir_Pt2 self /\
            envport self m.`3) {
          match UC_KEDir.Pt2.epdp__ke_req2.`dec m with
          | Some x => {
              r <@ state_DDHFuncStateWaitReq2
                   (pt1, pt2, x.`UC_KEDir.Pt2.ke_req2__pt2);
            }
          | None   => {}
          end;
        }
      }
      | DDHFuncStateWaitAdv2 pt1 => {
        if (m.`1 = Adv /\ _addr_Fw2 self = m.`2.`1 /\
            m.`3.`1 = adv) {
          match Forwarding2.UC_FwAdv.epdp__fw_ok.`dec m with
          | Some _ => {
              r <@ state_DDHFuncStateWaitAdv2(pt1);
            }
          | None   => {}
          end;
        }
      }
      | DDHFuncStateFinal            => {}
      end;
      return r;
    }
  }

  proc main(func : addr, in_guard : int fset) : bool = {
    var b : bool;
    DDHFunc.init(func);
    b <@ Exper(MI(DDHFunc, Adv), Env).main(func, in_guard);
    return b;
  }
}.

module DDH_Adv (Env : ENV, Adv : ADV) : DDH_ADV =
  DDH_Adv_Conv(DDHOrAdv(Env, Adv)).

module AllCGs  = {
  module UC__AllCGs_ = AllCGs_
  proc foo() = {
    var x1  <- MSCore.CombEnvAdv.func;
    var x2  <- MSCore.CombEnvAdv.in_guard;
    var x3  <- DDHOrAdv.DDHFunc.self;
    var x4  <- DDHOrAdv.DDHFunc.st;
    var x5  <- DDH1_Or.x_opt;
    var x6  <- DDH1_Or.y_opt;
    var x7  <- DDH2_Or.x_opt;
    var x8  <- DDH2_Or.y_opt;
    var x9  <- DDH2_Or.z_opt;
    var x10 <- DDH_Adv_Conv.Or.k1;
    var x11 <- DDH_Adv_Conv.Or.k2;
    var x12 <- DDH_Adv_Conv.Or.k3;
    var x13 <- DDH_Adv_Conv.Or.one;
    var x14 <- DDH_Adv_Conv.Or.two;
  }
}.

section.

declare module Adv <: ADV{-MI, -RFIP, -IF, -SIM, -AllCGs}.
declare module Env <: ENV{-Adv, -MI, -RFIP, -IF, -SIM, -AllCGs}.

(* we first move from RFIP to RealSimp, which has a single state
   machine *)

type real_simp_state = [
  | RealSimpStateWaitReq1
  | RealSimpStateWaitAdv1 of port & port & exp
  | RealSimpStateWaitReq2 of port & port & exp & exp
  | RealSimpStateWaitAdv2 of port & exp & exp
  | RealSimpStateFinal
].

local module RealSimp : FUNC = {
  var self : addr
  var st : real_simp_state

  proc init(self_ : addr) : unit = {
    self <- self_;
    st <- RealSimpStateWaitReq1;
  }

  proc state_RealSimpStateWaitReq1(pt1 : port, pt2 : port) : msg option = {
    var q1 : exp; var _r : msg option <- None;
    var _pt1 : port <- _intport_Pt1 self;
    var _pt2 : port <- _intport_Pt2 self;
    var u : univ;
    if (envport self pt2) {
      q1 <$ dexp;
      u <- KeyExp'.epdp_port_port_key_univ.`enc (pt1, pt2, g ^ q1);
      _r <-
        Some
        (Forwarding1.UC_FwAdv.epdp__fw_obs.`enc
         {|Forwarding1.UC_FwAdv.fw_obs___func = _addr_Fw1 self;
           Forwarding1.UC_FwAdv.fw_obs___adv  = adv;
           Forwarding1.UC_FwAdv.fw_obs__pt1   = _pt1;
           Forwarding1.UC_FwAdv.fw_obs__pt2   = _pt2;
           Forwarding1.UC_FwAdv.fw_obs__u     = u|});
      st <- RealSimpStateWaitAdv1 pt1 pt2 q1;
    }
    else { _r <- None; }
    return _r;
  }

  proc state_RealSimpStateWaitAdv1(pt1 : port, pt2 : port, q1 : exp)
         : msg option = {
    var q2 : exp; var _r : msg option <- None;
    q2 <$ dexp;
    _r <-
      Some
      (UC_KEDir.Pt2.epdp__ke_rsp1.`enc
       {|UC_KEDir.Pt2.ke_rsp1___func = self;
         UC_KEDir.Pt2.ke_rsp1__pt2   = pt2;
         UC_KEDir.Pt2.ke_rsp1__pt1   = pt1;
         UC_KEDir.Pt2.ke_rsp1__k     = g ^ q1 ^ q2|});
    st <- RealSimpStateWaitReq2 pt1 pt2 q1 q2;
    return _r;
  }

  proc state_RealSimpStateWaitReq2
       (pt1 : port, pt2 : port, q1 : exp, q2 : exp, pt2' : port)
         : msg option = {
    var u : univ;
    var _pt1 : port <- _intport_Pt2 self;
    var _pt2 : port <- _intport_Pt1 self;
    var _r : msg option <- None;
    if (pt2' = pt2) {
      u <- KeyExp'.epdp_key_univ.`enc (g ^ q2);
      _r <- Some
        (Forwarding2.UC_FwAdv.epdp__fw_obs.`enc
         {|Forwarding2.UC_FwAdv.fw_obs___func = _addr_Fw2 self;
           Forwarding2.UC_FwAdv.fw_obs___adv  = adv;
           Forwarding2.UC_FwAdv.fw_obs__pt1   = _pt1;
           Forwarding2.UC_FwAdv.fw_obs__pt2   = _pt2;
           Forwarding2.UC_FwAdv.fw_obs__u     = u|});
      st <- RealSimpStateWaitAdv2 pt1 q1 q2;   
    }
    return _r;
  }

  proc state_RealSimpStateWaitAdv2
       (pt1 : port, q1 : exp, q2 : exp) : msg option = {
    var _r : msg option <- None;
    _r <-
      Some
      (UC_KEDir.Pt1.epdp__ke_rsp2.`enc
       {|UC_KEDir.Pt1.ke_rsp2___func = self;
         UC_KEDir.Pt1.ke_rsp2__pt1   = pt1;
         UC_KEDir.Pt1.ke_rsp2__k     = g ^ q2 ^ q1|});
    st <- RealSimpStateFinal;
    return _r;
  }
  
  proc invoke(m : msg) : msg option = {
    var r : msg option <- None;
    match st with
    | RealSimpStateWaitReq1               => {
      if (m.`1 = Dir /\  m.`2 = _extport_dir_Pt1 self /\ envport self m.`3) {
        match UC_KEDir.Pt1.epdp__ke_req1.`dec m with
        | Some x => {
            r <@ state_RealSimpStateWaitReq1
                 (x.`UC_KEDir.Pt1.ke_req1__pt1, x.`UC_KEDir.Pt1.ke_req1__pt2);
          }
        | None   => {}
        end;
      }
    }
    | RealSimpStateWaitAdv1 pt1 pt2 q1    => {
      if (m.`1 = Adv /\ m.`2.`1 = _addr_Fw1 self /\ m.`3.`1 = adv) { 
        match Forwarding1.UC_FwAdv.epdp__fw_ok.`dec m with
        | Some _ => {
            r <@ state_RealSimpStateWaitAdv1(pt1, pt2, q1);
          }
        | None   => {}
        end;
      }
    }
    | RealSimpStateWaitReq2 pt1 pt2 q1 q2 => {
      if (m.`1 = Dir /\ m.`2 = _extport_dir_Pt2 self /\ envport self m.`3) {
        match UC_KEDir.Pt2.epdp__ke_req2.`dec m with
        | Some x => {
            r <@ state_RealSimpStateWaitReq2
                 (pt1, pt2, q1, q2, x.`UC_KEDir.Pt2.ke_req2__pt2);
          }
        | None   => {}
        end;
      }
    }
    | RealSimpStateWaitAdv2 pt1 q1 q2 => {
      if (m.`1 = Adv /\ _addr_Fw2 self = m.`2.`1 /\ m.`3.`1 = adv) {
        match Forwarding2.UC_FwAdv.epdp__fw_ok.`dec m with
        | Some _ => {
            r <@ state_RealSimpStateWaitAdv2(pt1, q1, q2);
          }
        | None   => {}
        end;
      }
    }
    | RealSimpStateFinal                  => {}
    end;
    return r;
  }
}.

(* relational invariant for connecting RFIP and RealSimp *)

op glob_RFIP_to_self        (g : glob RFIP) : addr                  = g.`1.
op glob_RFIP_to_st_Pt1      (g : glob RFIP) : _state_Pt1            = g.`2.
op glob_RFIP_to_st_Pt2      (g : glob RFIP) : _state_Pt2            = g.`3.
op glob_RFIP_to_self_Fw1    (g : glob RFIP) : addr                  = g.`4.
op glob_RFIP_to_st_Fw1      (g : glob RFIP) : Forwarding1._state_IF = g.`5.
op glob_RFIP_to_self_Fw2    (g : glob RFIP) : addr                  = g.`6.
op glob_RFIP_to_st_Fw2      (g : glob RFIP) : Forwarding2._state_IF = g.`7.
op glob_RFIP_to_self_MakeRF (g : glob RFIP) : addr                  = g.`8.

op glob_RealSimp_to_self (g : glob RealSimp) : addr            = g.`1.
op glob_RealSimp_to_st   (g : glob RealSimp) : real_simp_state = g.`2.

op real_simp_invar_static
   (func : addr, grfip : glob RFIP, grs : glob RealSimp) : bool =
  glob_RFIP_to_self grfip        = func /\
  glob_RFIP_to_self_Fw1 grfip    = _addr_Fw1 func /\
  glob_RFIP_to_self_Fw2 grfip    = _addr_Fw2 func /\
  glob_RFIP_to_self_MakeRF grfip = func /\
  glob_RealSimp_to_self grs      = func.

op real_simp_invar_static_ports
   (func : addr, grfip : glob RFIP, grs : glob RealSimp,
    pt1 pt2 : port) : bool =
  glob_RFIP_to_self grfip        = func /\
  glob_RFIP_to_self_Fw1 grfip    = _addr_Fw1 func /\
  glob_RFIP_to_self_Fw2 grfip    = _addr_Fw2 func /\
  glob_RFIP_to_self_MakeRF grfip = func /\
  glob_RealSimp_to_self grs      = func /\
  envport func pt1 /\ envport func pt2.

op real_simp_invar0 (func : addr, grfip : glob RFIP,
                     grs : glob RealSimp) : bool =
  real_simp_invar_static func grfip grs /\
  (* -- *)
  glob_RFIP_to_st_Pt1 grfip = _State_Pt1_WaitReq1 /\
  glob_RFIP_to_st_Pt2 grfip = _State_Pt2_WaitFwd1 /\
  glob_RFIP_to_st_Fw1 grfip = Forwarding1._State_IF_Init /\
  glob_RFIP_to_st_Fw2 grfip = Forwarding2._State_IF_Init /\
  (* -- *)
  glob_RealSimp_to_st grs   = RealSimpStateWaitReq1.

op real_simp_invar1 (func : addr, grfip : glob RFIP, grs : glob RealSimp,
                     pt1 pt2 : port, q1 : exp) : bool =
  real_simp_invar_static_ports func grfip grs pt1 pt2 /\
  (* -- *)
  glob_RFIP_to_st_Pt1 grfip = _State_Pt1_WaitFwd2 pt1 q1 /\
  glob_RFIP_to_st_Pt2 grfip = _State_Pt2_WaitFwd1 /\
  glob_RFIP_to_st_Fw1 grfip =
    Forwarding1._State_IF_Wait (_intport_Pt1 func) (_intport_Pt2 func)
    (KeyExp'.epdp_port_port_key_univ.`enc (pt1, pt2, g ^ q1)) /\
  glob_RFIP_to_st_Fw2 grfip = Forwarding2._State_IF_Init /\
  (* -- *)
  glob_RealSimp_to_st grs   = RealSimpStateWaitAdv1 pt1 pt2 q1.

op real_simp_invar2 (func : addr, grfip : glob RFIP, grs : glob RealSimp,
                     pt1 pt2 : port, q1 q2 : exp) : bool =
  real_simp_invar_static_ports func grfip grs pt1 pt2 /\
  (* -- *)
  glob_RFIP_to_st_Pt1 grfip = _State_Pt1_WaitFwd2 pt1 q1 /\
  glob_RFIP_to_st_Pt2 grfip = _State_Pt2_WaitReq2 pt2 q2 /\
  glob_RFIP_to_st_Fw1 grfip = Forwarding1._State_IF_Final /\
  glob_RFIP_to_st_Fw2 grfip = Forwarding2._State_IF_Init /\
  (* -- *)
  glob_RealSimp_to_st grs   = RealSimpStateWaitReq2 pt1 pt2 q1 q2.

op real_simp_invar3 (func : addr, grfip : glob RFIP, grs : glob RealSimp,
                     pt1 pt2 : port, q1 q2 : exp) : bool =
  real_simp_invar_static_ports func grfip grs pt1 pt2 /\
  (* -- *)
  glob_RFIP_to_st_Pt1 grfip = _State_Pt1_WaitFwd2 pt1 q1 /\
  glob_RFIP_to_st_Pt2 grfip = _State_Pt2_Final /\
  glob_RFIP_to_st_Fw1 grfip = Forwarding1._State_IF_Final /\
  glob_RFIP_to_st_Fw2 grfip =
    Forwarding2._State_IF_Wait (_intport_Pt2 func) (_intport_Pt1 func)
    (KeyExp'.epdp_key_univ.`enc (g ^ q2)) /\
  glob_RFIP_to_self_MakeRF grfip = func /\
  (* -- *)
  glob_RealSimp_to_st grs   = RealSimpStateWaitAdv2 pt1 q1 q2.

op real_simp_invar4 (func : addr, grfip : glob RFIP,
                     grs : glob RealSimp) : bool =
  real_simp_invar_static func grfip grs /\
  (* -- *)
  glob_RFIP_to_st_Pt1 grfip = _State_Pt1_Final /\
  glob_RFIP_to_st_Pt2 grfip = _State_Pt2_Final /\
  glob_RFIP_to_st_Fw1 grfip = Forwarding1._State_IF_Final /\
  glob_RFIP_to_st_Fw2 grfip = Forwarding2._State_IF_Final /\
  (* -- *)
  glob_RealSimp_to_st grs   = RealSimpStateFinal.

inductive real_simp_invar (func : addr, grfip : glob RFIP,
                           grs : glob RealSimp) =
  | RealSimpInvar0 of
      (real_simp_invar0 func grfip grs)
  | RealSimpInvar1 (pt1 pt2 : port, q1 : exp) of
      (real_simp_invar1 func grfip grs pt1 pt2 q1)
  | RealSimpInvar2 (pt1 pt2 : port, q1 q2 : exp) of
      (real_simp_invar2 func grfip grs pt1 pt2 q1 q2)
  | RealSimpInvar3 (pt1 pt2 : port, q1 q2 : exp) of
      (real_simp_invar3 func grfip grs pt1 pt2 q1 q2)
  | RealSimpInvar4 of
      (real_simp_invar4 func grfip grs).

local lemma RFIP_RealSimp_init (func' : addr) :
  exper_pre func' =>
  equiv
  [RFIP.init ~ RealSimp.init :
   _self{1} = self_{2} /\ _self{1} = func' ==>
   real_simp_invar func' (glob RFIP){1} (glob RealSimp){2}].
proof.
move => ep_func'.
proc; inline; auto; smt(RealSimpInvar0).
qed.

local lemma RFIP_RealSimp_invoke (func' : addr) :
  exper_pre func' =>
  equiv
  [RFIP.invoke ~ RealSimp.invoke :
   ={m} /\
   (m{1}.`1 = Dir /\ func' = m{1}.`2.`1 /\ envport func' m{1}.`3 \/
    m{1}.`1 = Adv /\ func' <= m{1}.`2.`1 /\
    m{1}.`3.`1 = adv /\ 0 < m{1}.`3.`2) /\
   real_simp_invar func' (glob RFIP){1} (glob RealSimp){2} ==>
   ={res} /\
   real_simp_invar func' (glob RFIP){1} (glob RealSimp){2}].
proof.
move => ep_func'.
proc.
exlim (glob RFIP){1}, (glob RealSimp){2} => grfip grs.
(* the "!!" is a hack to make the ambient case be a boolean one *)
case @[ambient] (!! real_simp_invar func' grfip grs) =>
  [/= [] | ?]; last exfalso; smt().
(* real_simp_invar0 *)
move => real_simp_invar0_ass.
sp 1 1.
match RealSimpStateWaitReq1 {2} 1; first auto; smt().
if{2}.
rcondt{1} 1; first auto; smt().
inline{1} 1; sp 3 0.
rcondt{1} 1; first auto.
inline{1} 1; sp 2 0.
rcondf{1} 1; first auto; smt(@UCListPO).
rcondf{1} 1; first auto; smt(@UCListPO).
rcondt{1} 1; first auto; smt().
inline{1} 1; sp 2 0.
match _State_Pt1_WaitReq1 {1} 1; first auto; smt().
match => //.
seq 3 0 : 
  (grfip = (glob RFIP){1} /\ grs = (glob RealSimp){2} /\
   r0{1} = None /\ ! not_done{1} /\ r{2} = None).
call{1} (RFCore.MakeRF_after_core_error UC_KEReal); first auto.
rcondf{1} 1; first auto.
auto; smt(RealSimpInvar0).
move => x1 x2; inline{1} 1; inline{2} 1; sp 3 5.
if; first smt().
seq 1 1 : (#pre /\ ={q1}); first auto.
seq 5 4 :
  (={pt1, pt2, q1} /\
   m0{1}.`1 = Dir /\
   m0{1}.`2 = _extport_dir_Pt1 RealSimp.self{2} /\
   envport RealSimp.self{2} m0{1}.`3 /\
   real_simp_invar_static_ports func' (glob RFIP){1}
   (glob RealSimp){2} pt1{1} pt2{1} /\
   glob_RFIP_to_st_Pt1 (glob RFIP){1} = _State_Pt1_WaitFwd2 pt1{1} q1{1} /\
   glob_RFIP_to_st_Pt2 (glob RFIP){1} = _State_Pt2_WaitFwd1 /\
   glob_RFIP_to_st_Fw1 (glob RFIP){1} = Forwarding1._State_IF_Init /\
   glob_RFIP_to_st_Fw2 (glob RFIP){1} = Forwarding2._State_IF_Init /\
   RealSimp.st{2} = RealSimpStateWaitAdv1 pt1{2} pt2{2} q1{2} /\
   r0{1} = 
   Some
   (Forwarding1.UC_FwDir.D.epdp__fw_req.`enc
