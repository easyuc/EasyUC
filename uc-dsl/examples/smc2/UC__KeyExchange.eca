local lemma Exper_RFIP_RealSimp (func' : addr) (in_guard' : int fset) &m :
  exper_pre func' =>
  Pr[Exper(MI(RFIP, Adv), Env).main(func', in_guard') @ &m : res] =
  Pr[Exper(MI(RealSimp, Adv), Env).main(func', in_guard') @ &m : res].
proof.
move => ep_func.
apply
  (MakeInt.func_equiv_implies_exper_equal_prob
   RFIP RealSimp Adv Env func' in_guard' (real_simp_invar func') &m) => //.
by apply RFIP_RealSimp_init.
by conseq (RFIP_RealSimp_invoke func' _).
qed.

(* next we have the real/ideal hybrid functionality, which does the
   work of the ideal functionality and simulator in a single state
   machine *)

type hybrid_state = [
  | HybridStateWaitReq1
  | HybridStateWaitAdv1 of port & port & exp
  | HybridStateWaitReq2 of port & port & exp & exp
  | HybridStateWaitAdv2 of port & exp
  | HybridStateFinal
].

local module Hybrid : FUNC = {
  var self : addr
  var st : hybrid_state

  proc init(self_ : addr) : unit = {
    self <- self_;
    st <- HybridStateWaitReq1;
  }

  proc state_HybridStateWaitReq1(pt1 : port, pt2 : port) : msg option = {
    var q1 : exp; var _r : msg option <- None;
    var _pt1 : port <- _intport_Pt1 self;
    var _pt2 : port <- _intport_Pt2 self;
    var u : univ;
    if (envport self pt2) {
      q1 <$ dexp;
      u <- KeyExp'.epdp_port_port_key_univ.`enc (pt1, pt2, g ^ q1);
      _r <-
        Some
        (Forwarding1.UC_FwAdv.epdp__fw_obs.`enc
         {|Forwarding1.UC_FwAdv.fw_obs___func = _addr_Fw1 self;
           Forwarding1.UC_FwAdv.fw_obs___adv  = adv;
           Forwarding1.UC_FwAdv.fw_obs__pt1   = _pt1;
           Forwarding1.UC_FwAdv.fw_obs__pt2   = _pt2;
           Forwarding1.UC_FwAdv.fw_obs__u     = u|});
      st <- HybridStateWaitAdv1 pt1 pt2 q1;
    }
    else { _r <- None; }
    return _r;
  }

  proc state_HybridStateWaitAdv1(pt1 : port, pt2 : port, q1 : exp)
         : msg option = {
    var q2, q3 : exp; var _r : msg option <- None;
    q2 <$ dexp; q3 <$ dexp;
    _r <-
      Some
      (UC_KEDir.Pt2.epdp__ke_rsp1.`enc
       {|UC_KEDir.Pt2.ke_rsp1___func = self;
         UC_KEDir.Pt2.ke_rsp1__pt2   = pt2;
         UC_KEDir.Pt2.ke_rsp1__pt1   = pt1;
         UC_KEDir.Pt2.ke_rsp1__k     = g ^ q3|});
    st <- HybridStateWaitReq2 pt1 pt2 q2 q3;
    return _r;
  }

  proc state_HybridStateWaitReq2
       (pt1 : port, pt2 : port, q2 : exp, q3 : exp, pt2' : port)
         : msg option = {
    var u : univ;
    var _pt1 : port <- _intport_Pt2 self;
    var _pt2 : port <- _intport_Pt1 self;
    var _r : msg option <- None;
    if (pt2' = pt2) {
      u <- KeyExp'.epdp_key_univ.`enc (g ^ q2);
      _r <- Some
        (Forwarding2.UC_FwAdv.epdp__fw_obs.`enc
         {|Forwarding2.UC_FwAdv.fw_obs___func = _addr_Fw2 self;
           Forwarding2.UC_FwAdv.fw_obs___adv  = adv;
           Forwarding2.UC_FwAdv.fw_obs__pt1   = _pt1;
           Forwarding2.UC_FwAdv.fw_obs__pt2   = _pt2;
           Forwarding2.UC_FwAdv.fw_obs__u     = u|});
      st <- HybridStateWaitAdv2 pt1 q3;
    }
    return _r;
  }

  proc state_HybridStateWaitAdv2(pt1 : port, q3 : exp) : msg option = {
    var _r : msg option <- None;
    _r <-
      Some
      (UC_KEDir.Pt1.epdp__ke_rsp2.`enc
       {|UC_KEDir.Pt1.ke_rsp2___func = self;
         UC_KEDir.Pt1.ke_rsp2__pt1   = pt1;
         UC_KEDir.Pt1.ke_rsp2__k     = g ^ q3|});
    st <- HybridStateFinal;
    return _r;
  }

  proc invoke(m : msg) : msg option = {
    var r : msg option <- None;
    match st with
    | HybridStateWaitReq1               => {
      if (m.`1 = Dir /\  m.`2 = _extport_dir_Pt1 self /\ envport self m.`3) {
        match UC_KEDir.Pt1.epdp__ke_req1.`dec m with
        | Some x => {
            r <@ state_HybridStateWaitReq1
                 (x.`UC_KEDir.Pt1.ke_req1__pt1, x.`UC_KEDir.Pt1.ke_req1__pt2);
          }
        | None   => {}
        end;
      }
    }
    | HybridStateWaitAdv1 pt1 pt2 q1    => {
      if (m.`1 = Adv /\ m.`2.`1 = _addr_Fw1 self /\ m.`3.`1 = adv) {
        match Forwarding1.UC_FwAdv.epdp__fw_ok.`dec m with
        | Some _ => {
            r <@ state_HybridStateWaitAdv1(pt1, pt2, q1);
          }
        | None   => {}
        end;
      }
    }
    | HybridStateWaitReq2 pt1 pt2 q2 q3 => {
      if (m.`1 = Dir /\ m.`2 = _extport_dir_Pt2 self /\ envport self m.`3) {
        match UC_KEDir.Pt2.epdp__ke_req2.`dec m with
        | Some x => {
            r <@ state_HybridStateWaitReq2
                 (pt1, pt2, q2, q3, x.`UC_KEDir.Pt2.ke_req2__pt2);
          }
        | None   => {}
        end;
      }
    }
    | HybridStateWaitAdv2 pt1 q3    => {
      if (m.`1 = Adv /\ _addr_Fw2 self = m.`2.`1 /\ m.`3.`1 = adv) {
        match Forwarding2.UC_FwAdv.epdp__fw_ok.`dec m with
        | Some _ => {
            r <@ state_HybridStateWaitAdv2(pt1, q3);
          }
        | None   => {}
        end;
      }
    }
    | HybridStateFinal                  => {}
    end;
    return r;
  }
}.

op glob_Hybrid_to_self (g : glob Hybrid) : addr         = g.`1.
op glob_Hybrid_to_st   (g : glob Hybrid) : hybrid_state = g.`2.

(* we'll need a termination metric for Hybrid *)

op invar_Hybrid (_ : glob Hybrid) : bool = true.

op metric_Hybrid (g : glob Hybrid) : int =
  match glob_Hybrid_to_st g with
  | HybridStateWaitReq1         => 4
  | HybridStateWaitAdv1 _ _ _   => 3
  | HybridStateWaitReq2 _ _ _ _ => 2
  | HybridStateWaitAdv2 _ _     => 1
  | HybridStateFinal            => 0
  end.

lemma metric_Hybrid_good (g : glob Hybrid) :
  invar_Hybrid g => 0 <= metric_Hybrid g.
proof. smt(). qed.

local lemma metric_Hybrid_init :
  hoare [Hybrid.init : true ==> invar_Hybrid (glob Hybrid)].
proof. rewrite /invar_Hybrid; auto. qed.

local lemma metric_Hybrid_invoke (n : int) :
  hoare
  [Hybrid.invoke :
   invar_Hybrid (glob Hybrid) /\ metric_Hybrid (glob Hybrid) = n ==>
   invar_Hybrid (glob Hybrid) /\
   (res <> None => metric_Hybrid (glob Hybrid) < n)].
proof.
rewrite /_metric_KEHybrid /=; proc; inline; sp 1.
match.
if.
match; first auto.
sp 5.
if; auto.
auto.
if; [match; auto | auto].
auto; smt().
auto; smt().
auto.
qed.

(* to connect RealSimp and Hybrid, we use a reduction to the
   Decisional Diffie-Hellman assumption, via DDHOrAdv *)

op glob_DDHOrAdv_to_func_self (g : glob DDHOrAdv) : addr           = g.`1.
op glob_DDHOrAdv_to_func_st   (g : glob DDHOrAdv) : ddh_func_state = g.`2.
op glob_DDHOrAdv_to_mi_func   (g : glob DDHOrAdv) : addr           = g.`3.
op glob_DDHOrAdv_to_mi_guard  (g : glob DDHOrAdv) : int fset       = g.`4.

op glob_DDH1_Or_to_x_opt (g : glob DDH1_Or) : exp option = g.`1.
op glob_DDH1_Or_to_y_opt (g : glob DDH1_Or) : exp option = g.`2.

op real_simp_ddh1_invar_static
   (func : addr, guard : int fset,
    grs : glob RealSimp, gadv : glob DDHOrAdv, gor : glob DDH1_Or) : bool =
  glob_RealSimp_to_self grs       = func /\
  glob_DDHOrAdv_to_func_self gadv = func /\
  glob_DDHOrAdv_to_mi_func gadv   = func /\
  glob_DDHOrAdv_to_mi_guard gadv  = guard.

op real_simp_ddh1_invar0
   (func : addr, guard : int fset, grs : glob RealSimp,
    gadv : glob DDHOrAdv, gor : glob DDH1_Or) : bool =
  real_simp_ddh1_invar_static func guard grs gadv gor /\
  glob_RealSimp_to_st grs       = RealSimpStateWaitReq1 /\
  glob_DDHOrAdv_to_func_st gadv = DDHFuncStateWaitReq1 /\
  glob_DDH1_Or_to_x_opt gor     = None /\
  glob_DDH1_Or_to_y_opt gor     = None.

op real_simp_ddh1_invar1
   (func : addr, guard : int fset, grs : glob RealSimp,
    gadv : glob DDHOrAdv, gor : glob DDH1_Or,
    pt1 pt2 : port, q1 : exp) : bool =
  real_simp_ddh1_invar_static func guard grs gadv gor /\
  glob_RealSimp_to_st grs       = RealSimpStateWaitAdv1 pt1 pt2 q1 /\
  glob_DDHOrAdv_to_func_st gadv = DDHFuncStateWaitAdv1 pt1 pt2 /\
  glob_DDH1_Or_to_x_opt gor     = Some q1 /\
  glob_DDH1_Or_to_y_opt gor     = None.

op real_simp_ddh1_invar2
   (func : addr, guard : int fset, grs : glob RealSimp,
    gadv : glob DDHOrAdv, gor : glob DDH1_Or,
    pt1 pt2 : port, q1 q2 : exp) : bool =
  real_simp_ddh1_invar_static func guard grs gadv gor /\
  glob_RealSimp_to_st grs       = RealSimpStateWaitReq2 pt1 pt2 q1 q2 /\
  glob_DDHOrAdv_to_func_st gadv = DDHFuncStateWaitReq2 pt1 pt2 /\
  glob_DDH1_Or_to_x_opt gor     = Some q1 /\
  glob_DDH1_Or_to_y_opt gor     = Some q2.

op real_simp_ddh1_invar3
   (func : addr, guard : int fset, grs : glob RealSimp,
    gadv : glob DDHOrAdv, gor : glob DDH1_Or,
    pt1 pt2 : port, q1 q2 : exp) : bool =
  real_simp_ddh1_invar_static func guard grs gadv gor /\
  glob_RealSimp_to_st grs       = RealSimpStateWaitAdv2 pt1 q1 q2 /\
  glob_DDHOrAdv_to_func_st gadv = DDHFuncStateWaitAdv2 pt1 /\
  glob_DDH1_Or_to_x_opt gor     = Some q1 /\
  glob_DDH1_Or_to_y_opt gor     = Some q2.

op real_simp_ddh1_invar4
   (func : addr, guard : int fset, grs : glob RealSimp,
    gadv : glob DDHOrAdv, gor : glob DDH1_Or) : bool =
  real_simp_ddh1_invar_static func guard grs gadv gor /\
  glob_RealSimp_to_st grs       = RealSimpStateFinal /\
  glob_DDHOrAdv_to_func_st gadv = DDHFuncStateFinal.

inductive real_simp_ddh1_invar
          (func : addr, guard : int fset, grs : glob RealSimp,
           gadv : glob DDHOrAdv, gor : glob DDH1_Or) =
  | RealSimpDDH1Invar0 of
      (real_simp_ddh1_invar0 func guard grs gadv gor)
  | RealSimpDDH1Invar1 (pt1 pt2 : port, q1 : exp) of
      (real_simp_ddh1_invar1 func guard grs gadv gor pt1 pt2 q1)
  | RealSimpDDH1Invar2 (pt1 pt2 : port, q1 q2 : exp) of
      (real_simp_ddh1_invar2 func guard grs gadv gor pt1 pt2 q1 q2)
  | RealSimpDDH1Invar3 (pt1 pt2 : port, q1 q2 : exp) of
      (real_simp_ddh1_invar3 func guard grs gadv gor pt1 pt2 q1 q2)
  | RealSimpDDH1Invar4 of
      (real_simp_ddh1_invar4 func guard grs gadv gor).

module DDH1Func = DDHOrAdv(Env, Adv, DDH1_Or).DDHFunc.

local lemma Exper_RealSimp_DDH1 (func' : addr) (in_guard' : int fset) &m :
  exper_pre func' =>
  Pr[Exper(MI(RealSimp, Adv), Env).main(func', in_guard') @ &m : res] =
  Pr[DDH_Or_Game(DDH1_Or, DDHOrAdv(Env, Adv))
       .main(func', in_guard') @ &m : res].
proof.
move => ep_func'; byequiv => //; proc.
inline*; sp; wp.
seq 1 1 :
  (={glob Env, glob Adv, glob MakeInt.MI} /\
   func{1} = func' /\ func0{2} = func' /\
   in_guard{1} = in_guard' /\ in_guard0{2} = in_guard' /\
   MakeInt.MI.func{1} = func' /\
   MakeInt.MI.in_guard{1} = in_guard' /\
   RealSimp.self{1} = func' /\
   RealSimp.st{1} = RealSimpStateWaitReq1 /\
   DDHOrAdv.DDHFunc.self{2} = func' /\
   DDHOrAdv.DDHFunc.st{2} = DDHFuncStateWaitReq1 /\
   DDH1_Or.x_opt{2} = None /\ DDH1_Or.y_opt{2} = None).
call (_ : true); first auto.
call
  (_ :
   ={glob Adv, glob MakeInt.MI} /\
   real_simp_ddh1_invar func' in_guard'
   (glob RealSimp){1} (glob DDHOrAdv){2} (glob DDH1_Or){2}).
proc.
if => //.
inline{1} 1; inline{2} 1; sp 3 3; wp.
while
  (={glob Adv, glob MakeInt.MI, not_done, m0, r0} /\
   real_simp_ddh1_invar func' in_guard'
   (glob RealSimp){1} (glob DDHOrAdv){2} (glob DDH1_Or){2}).
if => //.
seq 1 1 :
  (={glob Adv, glob MakeInt.MI, r0} /\
   real_simp_ddh1_invar func' in_guard'
   (glob RealSimp){1} (glob DDHOrAdv){2} (glob DDH1_Or){2}).
call
  (_ :
   ={glob Adv, glob MakeInt.MI} /\
   real_simp_ddh1_invar func' in_guard'
   (glob RealSimp){1} (glob DDHOrAdv){2} (glob DDH1_Or){2}).
exlim (glob RealSimp){1}, (glob DDHOrAdv){2}, (glob DDH1_Or){2}
  => grs gadv gor.
(* the "!!" is a hack to make the ambient case be a boolean one *)
case @[ambient] (!! real_simp_ddh1_invar func' in_guard' grs gadv gor) =>
  [/= [] | ?]; last exfalso; smt().
(* real_simp_ddh1_invar0 *)
move => real_simp_ddh1_invar0_ass.
sp 1 1.
match RealSimpStateWaitReq1 {1} 1; first auto; smt().
match DDHFuncStateWaitReq1 {2} 1; first auto; smt().
if; first smt().
match => // x1 x2.
inline{1} 1; inline{2} 1; sp 5 5.
if; first smt().
inline{2} 1; sp 0 1.
match One {2} 1; first auto.
rcondt{2} 1; first auto; smt().
seq 1 1 : (#pre /\ q1{1} = x{2}); first auto.
auto => /> &1 &2 dec_to_x1 dec_to_x2.
have eq_x1_x2 : x1 = x2.
  apply someI; by rewrite -dec_to_x1 -dec_to_x2.
progress; first smt().
rewrite
  (RealSimpDDH1Invar1 _ _ _ _ _
   (UC_KEDir.Pt1.ke_req1__pt1 x1) (UC_KEDir.Pt1.ke_req1__pt2 x1)
   x{2}) /#.
auto.
auto.
(* real_simp_ddh1_invar1 *)
move => pt1' pt2' q1' real_simp_ddh1_invar1_ass.
sp 1 1.
match RealSimpStateWaitAdv1 {1} 1; first auto; smt().
match DDHFuncStateWaitAdv1 {2} 1; first auto; smt().
if; first smt().
match => // x1 x2.
inline{1} 1; inline{2} 1; inline{2} 4.
match Two {2} 5; first auto.
rcondt{2} 5; first auto; smt().
inline{2} 8.
match Three {2} 9; first auto.
swap{1} 5 -4; swap{2} 5 -4.
rcondt{2} 9; first auto; smt().
seq 1 1 : (#pre /\ q2{1} = y{2}); first auto.
auto => /> &1 &2 dec_to_x1 dec_to_x2.
have eq_x1_x2 : x1 = x2.
  apply someI; by rewrite -dec_to_x1 -dec_to_x2.
progress; first smt(KeyExp'.double_exp KeyExp'.mulC).
rewrite (RealSimpDDH1Invar2 _ _ _ _ _ pt1{1} pt2{1} q1{1} y{2}) /#.
auto.
(* real_simp_ddh1_invar2 *)
move => pt1' pt2'' q1' q2' real_simp_ddh1_invar2_ass.
sp 1 1.
match RealSimpStateWaitReq2 {1} 1; first auto; smt().
match DDHFuncStateWaitReq2 {2} 1; first auto; smt().
if; first smt().
match => // x1 x2.
inline{1} 1; inline{2} 1; inline{2} 7.
match Two {2} 8; first auto.
rcondf{2} 8; first auto; smt().
sp 8 9.
if; first smt().
auto; progress; first smt().
rewrite (RealSimpDDH1Invar3 _ _ _ _ _ pt1{2} pt2{2} q1{1} q2{1}) /#.
auto.
auto.
(* real_simp_ddh1_invar3 *)
move => pt1' pt2' q1' q2' real_simp_ddh1_invar3_ass.
sp 1 1.
match RealSimpStateWaitAdv2 {1} 1; first auto; smt().
match DDHFuncStateWaitAdv2 {2} 1; first auto; smt().
if; first smt().
match => // x1 x2.
inline{1} 1; inline{2} 1; inline{2} 3.
match Three {2} 4; first auto.
rcondt{2} 4; first auto; smt().
auto; progress; first smt(KeyExp'.double_exp KeyExp'.mulC).
smt(RealSimpDDH1Invar4).
auto.
(* real_simp_ddh1_invar4 *)
move => real_simp_ddh1_invar4_ass.
sp 1 1.
match RealSimpStateFinal {1} 1; first auto; smt().
match DDHFuncStateFinal {2} 1; first auto; smt().
auto.
auto.
conseq (_ : ={r0, MI.func} ==> ={r0, m0, not_done}) => //.
call (MakeInt.MI_after_func_equiv RealSimp DDH1Func Adv); first auto.
seq 1 1 :
  (={glob Adv, glob MakeInt.MI, r0} /\
   real_simp_ddh1_invar func' in_guard'
   (glob RealSimp){1} (glob DDHOrAdv){2} (glob DDH1_Or){2}).
call (_ : true); first auto.
conseq (_ : ={r0, MI.func} ==> ={r0, m0, not_done}) => //.
call (MakeInt.MI_after_adv_equiv RealSimp DDH1Func Adv); first auto.
auto.
auto.
auto; smt(RealSimpDDH1Invar0).
qed.

op glob_DDH2_Or_to_x_opt (g : glob DDH2_Or) : exp option = g.`1.
op glob_DDH2_Or_to_y_opt (g : glob DDH2_Or) : exp option = g.`2.
op glob_DDH2_Or_to_z_opt (g : glob DDH2_Or) : exp option = g.`3.

op hybrid_ddh2_invar_static
   (func : addr, guard : int fset,
    ghy : glob Hybrid, gadv : glob DDHOrAdv, gor : glob DDH2_Or) : bool =
  glob_Hybrid_to_self ghy         = func /\
  glob_DDHOrAdv_to_func_self gadv = func /\
  glob_DDHOrAdv_to_mi_func gadv   = func /\
  glob_DDHOrAdv_to_mi_guard gadv  = guard.

op hybrid_ddh2_invar0
   (func : addr, guard : int fset, ghy : glob Hybrid,
    gadv : glob DDHOrAdv, gor : glob DDH2_Or) : bool =
  hybrid_ddh2_invar_static func guard ghy gadv gor /\
  glob_Hybrid_to_st ghy         = HybridStateWaitReq1 /\
  glob_DDHOrAdv_to_func_st gadv = DDHFuncStateWaitReq1 /\
  glob_DDH2_Or_to_x_opt gor     = None /\
  glob_DDH2_Or_to_y_opt gor     = None /\
  glob_DDH2_Or_to_z_opt gor     = None.

op hybrid_ddh2_invar1
   (func : addr, guard : int fset, ghy : glob Hybrid,
    gadv : glob DDHOrAdv, gor : glob DDH2_Or,
    pt1 pt2 : port, q1 : exp) : bool =
  hybrid_ddh2_invar_static func guard ghy gadv gor /\
  glob_Hybrid_to_st ghy         = HybridStateWaitAdv1 pt1 pt2 q1 /\
  glob_DDHOrAdv_to_func_st gadv = DDHFuncStateWaitAdv1 pt1 pt2 /\
  glob_DDH2_Or_to_x_opt gor     = Some q1 /\
  glob_DDH2_Or_to_y_opt gor     = None /\
  glob_DDH2_Or_to_z_opt gor     = None.

op hybrid_ddh2_invar2
   (func : addr, guard : int fset, ghy : glob Hybrid,
    gadv : glob DDHOrAdv, gor : glob DDH2_Or,
    pt1 pt2 : port, q1 q2 q3 : exp) : bool =
  hybrid_ddh2_invar_static func guard ghy gadv gor /\
  glob_Hybrid_to_st ghy         = HybridStateWaitReq2 pt1 pt2 q2 q3 /\
  glob_DDHOrAdv_to_func_st gadv = DDHFuncStateWaitReq2 pt1 pt2 /\
  glob_DDH2_Or_to_x_opt gor     = Some q1 /\
  glob_DDH2_Or_to_y_opt gor     = Some q2 /\
  glob_DDH2_Or_to_z_opt gor     = Some q3.

op hybrid_ddh2_invar3
   (func : addr, guard : int fset, ghy : glob Hybrid,
    gadv : glob DDHOrAdv, gor : glob DDH2_Or,
    pt1 pt2 : port, q1 q2 q3 : exp) : bool =
  hybrid_ddh2_invar_static func guard ghy gadv gor /\
  glob_Hybrid_to_st ghy         = HybridStateWaitAdv2 pt1 q3 /\
  glob_DDHOrAdv_to_func_st gadv = DDHFuncStateWaitAdv2 pt1 /\
  glob_DDH2_Or_to_x_opt gor     = Some q1 /\
  glob_DDH2_Or_to_y_opt gor     = Some q2 /\
  glob_DDH2_Or_to_z_opt gor     = Some q3.

op hybrid_ddh2_invar4
   (func : addr, guard : int fset, ghy : glob Hybrid,
    gadv : glob DDHOrAdv, gor : glob DDH2_Or) : bool =
  hybrid_ddh2_invar_static func guard ghy gadv gor /\
  glob_Hybrid_to_st ghy         = HybridStateFinal /\
  glob_DDHOrAdv_to_func_st gadv = DDHFuncStateFinal.

inductive hybrid_ddh2_invar
          (func : addr, guard : int fset, ghy : glob Hybrid,
           gadv : glob DDHOrAdv, gor : glob DDH2_Or) =
  | HybridDDH2Invar0 of
      (hybrid_ddh2_invar0 func guard ghy gadv gor)
  | HybridDDH2Invar1 (pt1 pt2 : port, q1 : exp) of
      (hybrid_ddh2_invar1 func guard ghy gadv gor pt1 pt2 q1)
  | HybridDDH2Invar2 (pt1 pt2 : port, q1 q2 q3 : exp) of
      (hybrid_ddh2_invar2 func guard ghy gadv gor pt1 pt2 q1 q2 q3)
  | HybridDDH2Invar3 (pt1 pt2 : port, q1 q2 q3 : exp) of
      (hybrid_ddh2_invar3 func guard ghy gadv gor pt1 pt2 q1 q2 q3)
  | HybridDDH2Invar4 of
      (hybrid_ddh2_invar4 func guard ghy gadv gor).

module DDH2Func = DDHOrAdv(Env, Adv, DDH2_Or).DDHFunc.

local lemma Exper_Hybrid_DDH2 (func' : addr) (in_guard' : int fset) &m :
  exper_pre func' =>
  Pr[Exper(MI(Hybrid, Adv), Env).main(func', in_guard') @ &m : res] =
  Pr[DDH_Or_Game(DDH2_Or, DDHOrAdv(Env, Adv))
       .main(func', in_guard') @ &m : res].
proof.
move => ep_func'; byequiv => //; proc.
inline*; sp; wp.
seq 1 1 :
  (={glob Env, glob Adv, glob MakeInt.MI} /\
   func{1} = func' /\ func0{2} = func' /\
   in_guard{1} = in_guard' /\ in_guard0{2} = in_guard' /\
   MakeInt.MI.func{1} = func' /\
   MakeInt.MI.in_guard{1} = in_guard' /\
   Hybrid.self{1} = func' /\
   Hybrid.st{1} = HybridStateWaitReq1 /\
   DDHOrAdv.DDHFunc.self{2} = func' /\
   DDHOrAdv.DDHFunc.st{2} = DDHFuncStateWaitReq1 /\
   DDH2_Or.x_opt{2} = None /\ DDH2_Or.y_opt{2} = None /\
   DDH2_Or.z_opt{2} = None).
call (_ : true); first auto.
call
  (_ :
   ={glob Adv, glob MakeInt.MI} /\
   hybrid_ddh2_invar func' in_guard'
   (glob Hybrid){1} (glob DDHOrAdv){2} (glob DDH2_Or){2}).
proc.
if => //.
inline{1} 1; inline{2} 1; sp 3 3; wp.
while
  (={glob Adv, glob MakeInt.MI, not_done, m0, r0} /\
   hybrid_ddh2_invar func' in_guard'
   (glob Hybrid){1} (glob DDHOrAdv){2} (glob DDH2_Or){2}).
if => //.
seq 1 1 :
  (={glob Adv, glob MakeInt.MI, r0} /\
   hybrid_ddh2_invar func' in_guard'
   (glob Hybrid){1} (glob DDHOrAdv){2} (glob DDH2_Or){2}).
call
  (_ :
   ={glob Adv, glob MakeInt.MI} /\
   hybrid_ddh2_invar func' in_guard'
   (glob Hybrid){1} (glob DDHOrAdv){2} (glob DDH2_Or){2}).
exlim (glob Hybrid){1}, (glob DDHOrAdv){2}, (glob DDH2_Or){2}
  => ghy gadv gor.
(* the "!!" is a hack to make the ambient case be a boolean one *)
case @[ambient] (!! hybrid_ddh2_invar func' in_guard' ghy gadv gor) =>
  [/= [] | ?]; last exfalso; smt().
(* hybrid_ddh2_invar0 *)
move => hybrid_ddh2_invar0_ass.
sp 1 1.
match HybridStateWaitReq1 {1} 1; first auto; smt().
match DDHFuncStateWaitReq1 {2} 1; first auto; smt().
if; first smt().
match => // x1 x2.
inline{1} 1; inline{2} 1; sp 5 5.
if; first smt().
inline{2} 1; sp 0 1.
match One {2} 1; first auto.
rcondt{2} 1; first auto; smt().
seq 1 1 : (#pre /\ q1{1} = x{2}); first auto.
auto => /> &1 &2 dec_to_x1 dec_to_x2.
have eq_x1_x2 : x1 = x2.
  apply someI; by rewrite -dec_to_x1 -dec_to_x2.
progress; first smt().
rewrite
  (HybridDDH2Invar1 _ _ _ _ _
   (UC_KEDir.Pt1.ke_req1__pt1 x1) (UC_KEDir.Pt1.ke_req1__pt2 x1)
   x{2}) /#.
auto.
auto.
(* hybrid_ddh2_invar1 *)
move => pt1' pt2' q1' hybrid_ddh2_invar1_ass.
sp 1 1.
match HybridStateWaitAdv1 {1} 1; first auto; smt().
match DDHFuncStateWaitAdv1 {2} 1; first auto; smt().
if; first smt().
match => // x1 x2.
inline{1} 1; inline{2} 1; inline{2} 4.
match Two {2} 5; first auto.
rcondt{2} 5; first auto; smt().
inline{2} 8.
match Three {2} 9; first auto.
swap{1} 5 -4; swap{2} 5 -4.
rcondt{2} 9; first auto; smt().
seq 1 1 : (#pre /\ q2{1} = y{2}); first auto.
rcondt{2} 8; first auto; smt().
swap{1} 5 -4; swap{2} 8 -7.
seq 1 1 : (#pre /\ q3{1} = z0{2}); first auto.
auto => /> &1 &2 dec_to_x1 dec_to_x2.
have eq_x1_x2 : x1 = x2.
  apply someI; by rewrite -dec_to_x1 -dec_to_x2.
progress; first smt().
rewrite (HybridDDH2Invar2 _ _ _ _ _ pt1{1} pt2{1} q1{1} y{2} z0{2}) /#.
auto.
(* hybrid_ddh2_invar2 *)
move => pt1' pt2'' q1' q2' q3' hybrid_ddh2_invar2_ass.
sp 1 1.
match HybridStateWaitReq2 {1} 1; first auto; smt().
match DDHFuncStateWaitReq2 {2} 1; first auto; smt().
if; first smt().
match => // x1 x2.
inline{1} 1; inline{2} 1; inline{2} 7.
match Two {2} 8; first auto.
rcondf{2} 8; first auto; smt().
sp 8 9.
if; first smt().
auto => /> &1 &2 dec_to_x1 dec_to_x2.
have eq_x1_x2 : x1 = x2.
  apply someI; by rewrite -dec_to_x1 -dec_to_x2.
progress; first smt().
rewrite (HybridDDH2Invar3 _ _ _ _ _ pt1{2} pt2{2} q1' q2{1} q3{1}) /#.
auto.
auto.
(* hybrid_ddh2_invar3 *)
move => pt1' pt2' q1' q2' q3' hybrid_ddh2_invar3_ass.
sp 1 1.
match HybridStateWaitAdv2 {1} 1; first auto; smt().
match DDHFuncStateWaitAdv2 {2} 1; first auto; smt().
if; first smt().
match => // x1 x2.
inline{1} 1; inline{2} 1; inline{2} 3.
match Three {2} 4; first auto.
rcondt{2} 4; first auto; smt().
rcondf{2} 4; first auto; smt().
auto; smt(HybridDDH2Invar4).
auto.
(* hybrid_ddh2_invar4 *)
move => hybrid_ddh2_invar4_ass.
sp 1 1.
match HybridStateFinal {1} 1; first auto; smt().
match DDHFuncStateFinal {2} 1; first auto; smt().
auto.
auto.
conseq (_ : ={r0, MI.func} ==> ={r0, m0, not_done}) => //.
call (MakeInt.MI_after_func_equiv Hybrid DDH2Func Adv); first auto.
seq 1 1 :
  (={glob Adv, glob MakeInt.MI, r0} /\
   hybrid_ddh2_invar func' in_guard'
   (glob Hybrid){1} (glob DDHOrAdv){2} (glob DDH2_Or){2}).
call (_ : true); first auto.
conseq (_ : ={r0, MI.func} ==> ={r0, m0, not_done}) => //.
call (MakeInt.MI_after_adv_equiv Hybrid DDH2Func Adv); first auto.
auto.
auto.
auto; smt(HybridDDH2Invar0).
qed.

local lemma Exper_RFIP_Hybrid (func : addr) (in_guard : int fset) &m :
  exper_pre func =>
  `|Pr[Exper(MI(RFIP, Adv), Env).main(func, in_guard) @ &m : res] -
    Pr[Exper(MI(Hybrid, Adv), Env).main(func, in_guard) @ &m : res]| <=
  `|Pr[DDH1(DDH_Adv(Env, Adv)).main(func, in_guard) @ &m : res] -
    Pr[DDH2(DDH_Adv(Env, Adv)).main(func, in_guard) @ &m : res]|.
proof.
move => ep_func.
rewrite Exper_RFIP_RealSimp // Exper_RealSimp_DDH1 //.
by rewrite Exper_Hybrid_DDH2 // (Reduction (DDHOrAdv(Env, Adv))).
qed.

op glob_IF_to_self (g : glob IF) : addr      = g.`1.
op glob_IF_to_st   (g : glob IF) : _state_IF = g.`2.

op glob_SIM_to_st (g : glob SIM) : _state_SIM              = g.`1.
op glob_SIM_to_if_addr_opt (g : glob SIM) : addr option    = g.`2.
op glob_SIM_to_MS_if_addr_opt (g : glob SIM) : addr option = g.`3.

op hybrid_ideal_sim_invar0
   (func : addr, ghy : glob Hybrid, gif : glob IF, gsim : glob SIM) : bool =
  glob_Hybrid_to_self ghy         = func /\
  glob_IF_to_self gif             = func /\
  glob_SIM_to_if_addr_opt gsim    = None /\
  glob_SIM_to_MS_if_addr_opt gsim = None /\
  glob_Hybrid_to_st ghy           = HybridStateWaitReq1 /\
  glob_IF_to_st  gif              = _State_IF_WaitReq1 /\
  glob_SIM_to_st gsim             = _State_SIM_WaitReq1.

op hybrid_ideal_sim_invar1
   (func : addr, ghy : glob Hybrid, gif : glob IF, gsim : glob SIM,
    pt1 pt2 : port, q1 : exp) : bool =
  envport func pt1 /\ envport func pt2 /\
  glob_Hybrid_to_self ghy         = func /\
  glob_IF_to_self gif             = func /\
  glob_SIM_to_if_addr_opt gsim    = Some func /\
  glob_SIM_to_MS_if_addr_opt gsim = Some func /\
  glob_Hybrid_to_st ghy           = HybridStateWaitAdv1 pt1 pt2 q1 /\
  glob_IF_to_st  gif              = _State_IF_WaitSim1 pt1 pt2 /\
  glob_SIM_to_st gsim             = _State_SIM_WaitAdv1.

op hybrid_ideal_sim_invar2
   (func : addr, ghy : glob Hybrid, gif : glob IF, gsim : glob SIM,
    pt1 pt2 : port, q2 q3 : exp) : bool =
  envport func pt1 /\ envport func pt2 /\
  glob_Hybrid_to_self ghy         = func /\
  glob_IF_to_self gif             = func /\
  glob_SIM_to_if_addr_opt gsim    = Some func /\
  glob_SIM_to_MS_if_addr_opt gsim = Some func /\
  glob_Hybrid_to_st ghy           = HybridStateWaitReq2 pt1 pt2 q2 q3 /\
  glob_IF_to_st  gif              = _State_IF_WaitReq2 pt1 pt2 q3 /\
  glob_SIM_to_st gsim             = _State_SIM_WaitReq2 q2.

op hybrid_ideal_sim_invar3
   (func : addr, ghy : glob Hybrid, gif : glob IF, gsim : glob SIM,
    pt1 : port, q3 : exp) : bool =
  envport func pt1 /\
  glob_Hybrid_to_self ghy         = func /\
  glob_IF_to_self gif             = func /\
  glob_SIM_to_if_addr_opt gsim    = Some func /\
  glob_SIM_to_MS_if_addr_opt gsim = Some func /\
  glob_Hybrid_to_st ghy           = HybridStateWaitAdv2 pt1 q3 /\
  glob_IF_to_st  gif              = _State_IF_WaitSim2 pt1 q3 /\
  glob_SIM_to_st gsim             = _State_SIM_WaitAdv2.

op hybrid_ideal_sim_invar4
   (func : addr, ghy : glob Hybrid, gif : glob IF, gsim : glob SIM) : bool =
  glob_Hybrid_to_self ghy         = func /\
  glob_IF_to_self gif             = func /\
  glob_SIM_to_if_addr_opt gsim    = Some func /\
  glob_SIM_to_MS_if_addr_opt gsim = Some func /\
  glob_Hybrid_to_st ghy           = HybridStateFinal /\
  glob_IF_to_st  gif              = _State_IF_Final /\
  glob_SIM_to_st gsim             = _State_SIM_Final.

inductive hybrid_ideal_sim_invar
   (func : addr, ghy : glob Hybrid, gif : glob IF, gsim : glob SIM) =
  | HybridIdealSimInvar0 of
      (hybrid_ideal_sim_invar0 func ghy gif gsim)
  | HybridIdealSimInvar1 (pt1 pt2 : port, q1 : exp) of
      (hybrid_ideal_sim_invar1 func ghy gif gsim pt1 pt2 q1)
  | HybridIdealSimInvar2 (pt1 pt2 : port, q2 q3 : exp) of
      (hybrid_ideal_sim_invar2 func ghy gif gsim pt1 pt2 q2 q3)
  | HybridIdealSimInvar3 (pt1 : port, q3 : exp) of
      (hybrid_ideal_sim_invar3 func ghy gif gsim pt1 q3)
  | HybridIdealSimInvar4 of
      (hybrid_ideal_sim_invar4 func ghy gif gsim).

