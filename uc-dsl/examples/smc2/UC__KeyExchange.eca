lemma KeyExchange_RFIP_IF_advantage
    (Env <: ENV{-MI, -RFIP, -IF, -SIM, -AllCGs})
    (Adv <: ADV{-MI, -RFIP, -IF, -SIM, -AllCGs, -Env})
    (func' : addr, in_guard' : int fset) &m :
    exper_pre func' =>
    disjoint in_guard' (adv_pis_rf_info rf_info) =>
      (*adv pis of KE are disj. from in_guard'*)    
 `|Pr[Exper(MI(RFIP, Adv), Env)
         .main(func', in_guard')
           @ &m : res] -
    Pr[Exper(MI(IF, SIM(Adv)), Env)
         .main(func', in_guard')
      @ &m : res]| <=
`|Pr[DDHBound1(Env, Adv).main(func', in_guard') @ &m : res] -
  Pr[DDHBound2(Env, Adv).main(func', in_guard') @ &m : res]|
      .
  proof.
  move => pre disj.
    rewrite (RFIP_DDHBound1 Env Adv func' in_guard' &m).
trivial. trivial.
    rewrite  (IF_DDHBound2 Env Adv func' in_guard' &m).
trivial. trivial.
smt().
qed.
