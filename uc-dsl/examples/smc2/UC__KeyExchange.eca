lemma RFIP_DDHBound1
    (Env <: ENV{-MI, -RFIP, -IF, -SIM, -AllCGs})
    (Adv <: ADV{-MI, -RFIP, -IF, -SIM, -AllCGs, -Env})
    (func' : addr, in_guard' : int fset) &m :
    exper_pre func' =>
    disjoint in_guard' (adv_pis_rf_info rf_info) =>
      (*adv pis of KE are disj. from in_guard'*)    
    Pr[DDHBound1(Env, Adv).main(func', in_guard') @ &m : res] =
    Pr[Exper(MI(RFIP, Adv), Env).main(func', in_guard') @ &m : res].
    proof.
    move => exper_pre disj.
      byphoare (_ : func = func' /\ in_guard = in_guard'
      /\ glob Env = (glob Env){m}
      /\ glob Adv = (glob Adv){m}==> res) => //.
proc.
      sp.
conseq(_ : 
  func = func' /\
      in_guard= in_guard' /\
      DDH_Adv_globs.func = func /\
  DDH_Adv_globs.in_guard = in_guard /\
      (glob Env) = (glob Env){m} /\ (glob Adv) = (glob Adv){m}
      ==> _) => //.
call(_ : 
      DDH_Adv_globs.func = func' /\
  DDH_Adv_globs.in_guard = in_guard' /\
      (glob Env) = (glob Env){m} /\ (glob Adv) = (glob Adv){m}
      ==> res).
        bypr.
    move => &n.
    move => [#].
    move => f g.
rewrite -(RFIP_DDH1 Adv Env func' in_guard' &n).
        trivial. trivial. trivial. trivial.
    move => globE globA.
byequiv. sim.
trivial.  trivial. trivial.
  qed.

