local lemma Exper_Hybrid_KEIdeal_KESim_DummyAdv
            (Env <: ENV{-MI, -Hybrid, -IF, -MSCore.MS, -SIM})
            (func' : addr, in_guard' : int fset) &m :
  exper_pre func' =>
  disjoint in_guard' (fset1 _adv_if_pi) =>
  Pr[Exper(MI(Hybrid, DummyAdv), Env)
       .main(func', in_guard') @ &m : res] =
  Pr[Exper
     (MI(IF, MSCore.MS(UC_KESim, DummyAdv)), Env)
       .main(func', in_guard') @ &m : res].
