   glob_IF_to_self (glob IF){2} = func' /\
   glob_SIM_to_if_addr_opt (glob SIM){2} = Some func' /\
   glob_SIM_to_MS_if_addr_opt (glob SIM){2} = Some func' /\
   glob_Hybrid_to_st (glob Hybrid){1} = HybridStateWaitAdv1 pt1{1} pt2{1} q1{1} /\
   glob_IF_to_st  (glob IF){2} = _State_IF_WaitSim1 pt1{2} pt2{2} /\
   glob_SIM_to_st (glob SIM){2} = _State_SIM_WaitAdv1).
auto.
seq 1 1 :
  (not_done{1} /\ not_done0{2} /\ m0{1} = m3{2} /\
   m0{1} =
   (Forwarding1.UC_FwAdv.epdp__fw_obs.`enc       
