local lemma Exper_RFIP_Hybrid (func' : addr) (in_guard' : int fset) &m :
  exper_pre func' =>
  Pr[Exper(MI(RFIP, Adv), Env).main(func', in_guard') @ &m : res] =
  Pr[Exper(MI(Hybrid, Adv), Env).main(func', in_guard') @ &m : res].
proof.
move => ep_func.
apply
  (MakeInt.func_equiv_implies_exper_equal_prob
   RFIP Hybrid Adv Env func' in_guard' (rfip_hybrid_invar func') &m) => //.
by apply RFIP_Hybrid_init.
by conseq (RFIP_Hybrid_invoke func' _).
qed.

local op glob_IF_to_self (g : glob IF) : addr      = g.`1.
local op glob_IF_to_st   (g : glob IF) : _state_IF = g.`2.

local op glob_SIM_to_st (g : glob SIM) : _state_SIM              = g.`1.
local op glob_SIM_to_if_addr_opt (g : glob SIM) : addr option    = g.`2.
local op glob_SIM_to_MS_if_addr_opt (g : glob SIM) : addr option = g.`3.

local op hybrid_ideal_sim_invar0
    (func : addr, ghy : glob Hybrid, gif : glob IF, gsim : glob SIM) : bool =
  glob_Hybrid_to_self ghy         = func /\
  glob_IF_to_self gif             = func /\
  glob_SIM_to_if_addr_opt gsim    = None /\
  glob_SIM_to_MS_if_addr_opt gsim = None /\
  glob_Hybrid_to_st ghy           = HybridStateWaitReq /\
  glob_IF_to_st gif               = _State_IF_WaitReq /\
  glob_SIM_to_st gsim             = _State_SIM_WaitReq.

local op hybrid_ideal_sim_invar1
    (func : addr, ghy : glob Hybrid, gif : glob IF, gsim : glob SIM,
     pt1 pt2 : port, t : text) : bool =
  envport func pt1 /\ envport func pt2 /\
  glob_Hybrid_to_self ghy         = func /\
  glob_IF_to_self gif             = func /\
  glob_SIM_to_if_addr_opt gsim    = Some func /\
  glob_SIM_to_MS_if_addr_opt gsim = Some func /\
  glob_Hybrid_to_st ghy           = HybridStateWaitAdv1 pt1 pt2 t /\
  glob_IF_to_st gif               = _State_IF_WaitSim pt1 pt2 t /\
  glob_SIM_to_st gsim             = _State_SIM_WaitAdv1 pt1 pt2.

local op hybrid_ideal_sim_invar2
    (func : addr, ghy : glob Hybrid, gif : glob IF, gsim : glob SIM,
     pt1 pt2 : port, t : text, k : key) : bool =
  envport func pt1 /\ envport func pt2 /\
  glob_Hybrid_to_self ghy         = func /\
  glob_IF_to_self gif             = func /\
  glob_SIM_to_if_addr_opt gsim    = Some func /\
  glob_SIM_to_MS_if_addr_opt gsim = Some func /\
  glob_Hybrid_to_st ghy           = HybridStateWaitAdv2 pt1 pt2 t k /\
  glob_IF_to_st gif               = _State_IF_WaitSim pt1 pt2 t /\
  glob_SIM_to_st gsim             = _State_SIM_WaitAdv2 pt1 pt2 k.

local op hybrid_ideal_sim_invar3
    (func : addr, ghy : glob Hybrid, gif : glob IF, gsim : glob SIM,
     pt1 pt2 : port, t : text) : bool =
  envport func pt1 /\ envport func pt2 /\
  glob_Hybrid_to_self ghy         = func /\
  glob_IF_to_self gif             = func /\
  glob_SIM_to_if_addr_opt gsim    = Some func /\
  glob_SIM_to_MS_if_addr_opt gsim = Some func /\
  glob_Hybrid_to_st ghy           = HybridStateWaitAdv3 pt1 pt2 t /\
  glob_IF_to_st  gif              = _State_IF_WaitSim pt1 pt2 t /\
  glob_SIM_to_st gsim             = _State_SIM_WaitAdv3.

local op hybrid_ideal_sim_invar4
    (func : addr, ghy : glob Hybrid, gif : glob IF, gsim : glob SIM) : bool =
  glob_Hybrid_to_self ghy         = func /\
  glob_IF_to_self gif             = func /\
  glob_SIM_to_if_addr_opt gsim    = Some func /\
  glob_SIM_to_MS_if_addr_opt gsim = Some func /\
  glob_Hybrid_to_st ghy           = HybridStateFinal /\
  glob_IF_to_st gif               = _State_IF_Final /\
  glob_SIM_to_st gsim             = _State_SIM_Final.

local inductive hybrid_ideal_sim_invar
    (func : addr, ghy : glob Hybrid, gif : glob IF, gsim : glob SIM) =
  | HybridIdealSimInvar0 of
      (hybrid_ideal_sim_invar0 func ghy gif gsim)
  | HybridIdealSimInvar1 (pt1 pt2 : port, t : text) of
      (hybrid_ideal_sim_invar1 func ghy gif gsim pt1 pt2 t)
  | HybridIdealSimInvar2 (pt1 pt2 : port, t : text, k : key) of
      (hybrid_ideal_sim_invar2 func ghy gif gsim pt1 pt2 t k)
  | HybridIdealSimInvar3 (pt1 pt2 : port, t : text) of
      (hybrid_ideal_sim_invar3 func ghy gif gsim pt1 pt2 t)
  | HybridIdealSimInvar4 of
      (hybrid_ideal_sim_invar4 func ghy gif gsim).

local module SimCore = UC_SMCSim.
local module SimDA = MSCore.MS(SimCore, DummyAdv).

local op invar_SimCore  : (glob SimCore) -> bool = _invar_UC_SMCSim.
local op metric_SimCore : (glob SimCore) -> int  = _metric_UC_SMCSim.

local lemma metric_SimCore_good (g : glob SimCore) :
  invar_SimCore g => 0 <= metric_SimCore g.
proof. apply UC_SMCSim_metric_good. qed.

local lemma metric_SimCore_init:
  hoare [SimCore.init : true ==> invar_SimCore (glob SimCore)].
proof. apply UC_SMCSim_init. qed.

local lemma metric_SimCore_invoke (n : int) :
  hoare
  [SimCore.invoke :
   invar_SimCore (glob SimCore) /\ metric_SimCore (glob SimCore) = n ==>
   invar_SimCore (glob SimCore) /\
   (res <> None =>  metric_SimCore (glob SimCore) < n)].
proof. apply UC_SMCSim_invoke. qed.

local lemma Exper_Hybrid_IF_SimCore_DummyAdv
            (Env <: ENV{-MI, -Hybrid, -IF, -MSCore.MS, -SIM})
            (func' : addr, in_guard' : int fset) &m :
  exper_pre func' =>
  disjoint in_guard' (fset1 _adv_if_pi) =>
  Pr[Exper(MI(Hybrid, DummyAdv), Env)
       .main(func', in_guard') @ &m : res] =
  Pr[Exper
     (MI(IF, MSCore.MS(SimCore, DummyAdv)), Env)
       .main(func', in_guard') @ &m : res].
proof.
move => ep disj; byequiv => //; proc; last auto; inline*.
seq 7 10 :
  (={glob Env, func, in_guard, MI.func, MI.in_guard} /\
   MI.func{1} = func' /\ MI.in_guard{1} = in_guard' /\
   Hybrid.self{1} = func' /\ IF._self{2} = func' /\
   MSCore.MS.if_addr_opt{2} = None /\ SimCore.if_addr_opt{2} = None /\
   Hybrid.st{1} = HybridStateWaitReq /\
   IF._st{2} = _State_IF_WaitReq /\
   SimCore._st{2} = _State_SIM_WaitReq); first auto.
call
  (_ :
   ={MI.func, MI.in_guard} /\
     MI.func{1} = func' /\ MI.in_guard{1} = in_guard' /\
   hybrid_ideal_sim_invar func'
   (glob Hybrid){1} (glob IF){2} (glob SIM){2});
    last auto; smt(HybridIdealSimInvar0).
proc.
if => //; last auto; smt(HybridIdealSimInvar0).
inline loop; sp 3 3; wp.
rcondt{1} 1; first auto. rcondt{2} 1; first auto.
conseq
  (_ :
   ={m0, MI.func, MI.in_guard} /\ not_done{1} /\
    MI.func{1} = func' /\ MI.in_guard{1} = in_guard' /\
   main_guard MI.func{1} MI.in_guard{1} m0{1} /\
   (m0{1}.`1 = Adv => m0{1}.`2.`2 <> _adv_if_pi) /\
   hybrid_ideal_sim_invar func'
   (glob Hybrid){1} (glob IF){2} (glob SIM){2} ==>
   ={r0, MI.func, MI.in_guard} /\
    MI.func{1} = func' /\ MI.in_guard{1} = in_guard' /\
   hybrid_ideal_sim_invar func'
   (glob Hybrid){1} (glob IF){2} (glob SIM){2}) => //.
move => />;
  smt(_adv_pi_begin_gt0 in_fset1 mem_adv_pis_rf_info disjointP).
exlim (glob Hybrid){1}, (glob IF){2}, (glob SIM){2}
  => ghy gif gsim.
(* the "!!" is a hack to make the ambient case be a boolean one *)
case @[ambient] (!! hybrid_ideal_sim_invar func' ghy gif gsim) =>
  [/= [] | ?]; last exfalso; smt().
(* hybrid_ideal_sim_invar0 *)
move => hybrid_ideal_sim_invar0_ass.
if => //.
(* functionality sequence *)
inline{1} 1; inline{2} 1; sp 2 2.
match HybridStateWaitReq {1} 1; first auto; smt().
if{1}.
rcondt{2} 1; first auto; smt().
inline{2} 1; sp 0 2.
match _State_IF_WaitReq {2} 1; first auto; smt().
match => //.
seq 2 3 :
  (={r0} /\ r0{1} = None /\ ! not_done{1} /\ ! not_done{2} /\
   ={MI.func, MI.in_guard} /\
   MI.func{1} = func' /\ MI.in_guard{1} = in_guard' /\
   hybrid_ideal_sim_invar0 func'
   (glob Hybrid){1} (glob IF){2} (glob SIM){2}).
call{1} (MakeInt.MI_after_func_error Hybrid DummyAdv).
call{2} (MakeInt.MI_after_func_error IF SimDA).
auto; smt().
rcondf{1} 1; first auto. rcondf{2} 1; first auto.
auto; smt(HybridIdealSimInvar0).
move => x1 x2; seq 0 0 : (#pre /\ x1 = x2); first by auto => /> &1 &2 ->.
inline{1} 1; inline{2} 1; sp 4 4.
if; first smt().
seq 0 6 :
  (not_done{2} /\
   m0{2} =
   UC_SMC2Sim.epdp__sim_req.`enc
   (UC_SMC2Sim.mk__sim_req func' pt1{1} pt2{1}) /\
   ={pt1, pt2, t, MI.func, MI.in_guard} /\
   MI.func{1} = func' /\ MI.in_guard{1} = in_guard' /\
   envport func' pt1{1} /\ envport func' pt2{1} /\
   glob_Hybrid_to_self (glob Hybrid){1} = func' /\
   glob_IF_to_self (glob IF){2} = func' /\
   glob_SIM_to_if_addr_opt (glob SIM){2} = None /\
   glob_SIM_to_MS_if_addr_opt (glob SIM){2} = None /\
   glob_Hybrid_to_st (glob Hybrid){1} = HybridStateWaitReq /\
   glob_IF_to_st (glob IF){2} = _State_IF_WaitSim pt1{2} pt2{2} t{2} /\
   glob_SIM_to_st (glob SIM){2} = _State_SIM_WaitReq).
sp 0 5; exlim r0{2} => r0'.
call{2} (MakeInt.MI_after_func_to_adv IF SimDA r0').
auto => /> &1 &2dec_m0_to_x2 _.
have x2_eq : x2 = oget (UC_SMCDir.Pt1.epdp__smc_req.`dec m0{2}) by smt().
have /= m0_eq := UC_SMCDir.Pt1.eq_of_valid__smc_req m0{2} _; first by smt().
progress; last 9 smt(@UCListPO).
smt(_adv_pi_begin_gt0).
smt(@UCListPO).
move : H15; rewrite H14 /= /#.
rcondt{2} 1; first auto.
rcondf{2} 1; first auto; smt(@UCListPO).
inline{2} 1; sp 0 2.
rcondt{2} 1; first auto; smt().
rcondt{2} 1; first auto.
rcondt{2} 1; first auto.
inline{2} 2; sp 0 4; elim* => if_addr_opt_R.
rcondt{2} 1; first auto.
rcondf{2} 1; first auto.
inline{2} 1; sp 0 2.
rcondt{2} 1; first auto.
sp 0 1; elim* => if_addr_opt_R0.
match _State_SIM_WaitReq {2} 1; first auto.
rcondt{2} 1; first auto; smt().
inline{2} 1; sp 0 3.
seq 5 5 :
  (not_done{1} /\ not_done0{2} /\ m0{1} = m3{2} /\
   m0{1} =
   KeyExchange.UC_KEI2S.epdp__ke_sim_req1.`enc
   (KeyExchange.UC_KEI2S.mk__ke_sim_req1
    (_addr_KE func') (_intport_Pt1 func') (_intport_Pt2 func')) /\
   ={MI.func, MI.in_guard} /\
   MI.func{1} = func' /\ MI.in_guard{1} = in_guard' /\
   hybrid_ideal_sim_invar1 func' (glob Hybrid){1} (glob IF){2}
   (glob SIM){2} pt1{1} pt2{1} t{1}).
sp; exlim r0{1} => r0'.
call{1} (MakeInt.MI_after_func_to_adv Hybrid DummyAdv r0').
call{2} (MSCore.MS_after_core_continue SimCore DummyAdv r0').
auto; progress; smt(@UCListPO _adv_pi_begin_gt0).
rcondt{1} 1; first auto. rcondt{2} 1; first auto.
rcondf{1} 1; first auto; smt(@UCListPO).
rcondt{2} 1; first auto; smt().
inline{1} 1; inline{2} 1; sp 2 2.
match None {1} 1; first auto => |>;
  smt(dest_pi_gt0_implies_dec_epdp_da_from_env_fails _adv_pi_begin_gt0).
match None {2} 1; first auto.
rcondt{1} 1; first auto; progress; smt(_adv_pi_begin_gt0).
rcondt{2} 1; first auto; progress; smt(_adv_pi_begin_gt0).
seq 3 3 :
  (r0{1} = r3{2} /\ ! not_done{1} /\ ! not_done0{2} /\
   MakeInt.after_adv_to_env func' r0{1} /\
   ={MI.func, MI.in_guard} /\
   MI.func{1} = func' /\ MI.in_guard{1} = in_guard' /\
   hybrid_ideal_sim_invar1 func' (glob Hybrid){1} (glob IF){2}
   (glob SIM){2} pt1{1} pt2{1} t{1}).
sp; exlim r0{1} => r0'.
call{1} (MakeInt.MI_after_adv_to_env Hybrid DummyAdv r0').
call{2} (MSCore.MS_after_adv_return SimCore DummyAdv r0').
auto; progress; smt(@UCListPO).
rcondf{1} 1; first auto. rcondf{2} 1; first auto. sp 0 2.
seq 0 1 :
  (r0{1} = r0{2} /\ ! not_done{2} /\
   MakeInt.after_adv_to_env func' r0{1} /\
   ={MI.func, MI.in_guard} /\
   MI.func{1} = func' /\ MI.in_guard{1} = in_guard' /\
   hybrid_ideal_sim_invar1 func' (glob Hybrid){1} (glob IF){2}
   (glob SIM){2} pt1{1} pt2{1} t{1}).
exlim r0{2} => r0'.
call{2} (MakeInt.MI_after_adv_to_env IF SimDA r0').
auto.
rcondf{2} 1; first auto;
auto.
auto; smt(HybridIdealSimInvar1).
seq 4 5 :
  (={r0} /\ r0{1} = None /\ ! not_done{1} /\ ! not_done{2} /\
   ={MI.func, MI.in_guard} /\
   MI.func{1} = func' /\ MI.in_guard{1} = in_guard' /\
   hybrid_ideal_sim_invar0 func'
   (glob Hybrid){1} (glob IF){2} (glob SIM){2}).
call{1} (MakeInt.MI_after_func_error Hybrid DummyAdv).
call{2} (MakeInt.MI_after_func_error IF SimDA).
auto; smt().
rcondf{1} 1; first auto. rcondf{2} 1; first auto.
auto; smt(HybridIdealSimInvar0).
if{2}.
inline{2} 1; sp 0 2.
match _State_IF_WaitReq {2} 1; first auto; smt().
match None {2} 1; first auto;
  smt(UC_SMCDir.Pt1.eq_of_valid__smc_req).
seq 2 3 :
  (={r0} /\ ! not_done{1} /\ ! not_done{2} /\
   ={MI.func, MI.in_guard} /\
   MI.func{1} = func' /\ MI.in_guard{1} = in_guard' /\
   hybrid_ideal_sim_invar0 func' (glob Hybrid){1} (glob IF){2}
   (glob SIM){2}).
call{1} (MakeInt.MI_after_func_error Hybrid DummyAdv).
call{2} (MakeInt.MI_after_func_error IF SimDA).
auto; smt().
rcondf{1} 1; first auto. rcondf{2} 1; first auto.
auto; smt(HybridIdealSimInvar0).
seq 2 2 :
  (={r0} /\ ! not_done{1} /\ ! not_done{2} /\
   ={MI.func, MI.in_guard} /\
   MI.func{1} = func' /\ MI.in_guard{1} = in_guard' /\
   hybrid_ideal_sim_invar0 func' (glob Hybrid){1} (glob IF){2}
   (glob SIM){2}).
call{1} (MakeInt.MI_after_func_error Hybrid DummyAdv).
call{2} (MakeInt.MI_after_func_error IF SimDA).
auto; smt().
rcondf{1} 1; first auto. rcondf{2} 1; first auto.
auto; smt(HybridIdealSimInvar0).
(* adversary sequence - special case for initial states *)
seq 1 1 :
  (={r0} /\ ={MI.func, MI.in_guard} /\
   MI.func{1} = func' /\ MI.in_guard{1} = in_guard' /\
   hybrid_ideal_sim_invar0 func' (glob Hybrid){1} (glob IF){2}
   (glob SIM){2}).
exlim (glob MSCore.MS){2}, (glob SimCore){2} => gs gcs.
call (MSCore.DummyAdv_Sim_init_not_sim_adv_pi_equiv SimCore gs gcs).
auto; smt(@UCListPO).
case (MakeInt.after_adv_error func' r0{1}).
seq 1 1 :
  (={r0} /\ ! not_done{1} /\ ! not_done{2} /\
   ={MI.func, MI.in_guard} /\
   MI.func{1} = func' /\ MI.in_guard{1} = in_guard' /\
   hybrid_ideal_sim_invar0 func' (glob Hybrid){1} (glob IF){2}
   (glob SIM){2}).
call{1} (MakeInt.MI_after_adv_error Hybrid DummyAdv).
call{2} (MakeInt.MI_after_adv_error IF SimDA).
auto; smt().
rcondf{1} 1; first auto. rcondf{2} 1; first auto.
auto; smt(HybridIdealSimInvar0).
case (MakeInt.after_adv_to_env func' r0{1}).
seq 1 1 :
  (={r0} /\ ! not_done{1} /\ ! not_done{2} /\
   ={MI.func, MI.in_guard} /\
   MI.func{1} = func' /\ MI.in_guard{1} = in_guard' /\
   hybrid_ideal_sim_invar0 func' (glob Hybrid){1} (glob IF){2}
   (glob SIM){2}).
exlim r0{1} => r0'.
call{1} (MakeInt.MI_after_adv_to_env Hybrid DummyAdv r0').
call{2} (MakeInt.MI_after_adv_to_env IF SimDA r0').
auto; smt().
rcondf{1} 1; first auto. rcondf{2} 1; first auto.
auto; smt(HybridIdealSimInvar0).
seq 0 0 : (#pre /\ MakeInt.after_adv_to_func func' r0{1});
  first auto; smt().
seq 1 1 :
  (={m0} /\ not_done{1} /\ not_done{2} /\
   MakeInt.after_adv_to_func func' (Some m0{1}) /\
   ={MI.func, MI.in_guard} /\
   MI.func{1} = func' /\ MI.in_guard{1} = in_guard' /\
   hybrid_ideal_sim_invar0 func' (glob Hybrid){1} (glob IF){2}
   (glob SIM){2}).
exlim r0{1} => r0'.
call{1} (MakeInt.MI_after_adv_to_func Hybrid DummyAdv r0').
call{2} (MakeInt.MI_after_adv_to_func IF SimDA r0').
auto; smt().
rcondt{1} 1; first auto. rcondt{2} 1; first auto.
rcondt{1} 1; first auto; smt(). rcondt{2} 1; first auto; smt().
inline{1} 1; inline{2} 1; sp 2 2.
match HybridStateWaitReq {1} 1; first auto; smt().
rcondf{1} 1; first auto; progress; smt(). sp 1 0.
seq 1 0 :
  (r0{1} = None /\ ! not_done{1} /\ r1{2} = None /\
   ={MI.func, MI.in_guard} /\
   MI.func{1} = func' /\ MI.in_guard{1} = in_guard' /\
   MakeInt.after_adv_to_func func' (Some m1{2}) /\
   hybrid_ideal_sim_invar0 func'
   (glob Hybrid){1} (glob IF){2} (glob SIM){2}).
