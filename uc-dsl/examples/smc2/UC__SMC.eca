(* UC__SMC.eca *)

(* The user's part of the SMC security proof. *)

require import UCCore.

require UC___SMC.
clone include UC___SMC.

(* used in module restrictions of the lemma of UC_SMC.eca *)

module AllCGs  = {
  module UC__AllCGs_ = AllCGs_

  proc foo() = {
    var x1 <- MSCore.CombEnvAdv.func;
    var x2 <- MSCore.CombEnvAdv.in_guard;
  }
}.

section.

declare module Adv <: ADV{-MI, -RFIP, -IF, -SIM, -AllCGs}.
declare module Env <: ENV{-Adv, -MI, -RFIP, -IF, -SIM, -AllCGs}.

(* we jump directly to a hybrid functionality that is like the ideal
   functionality / simulator, but has a single state machine *)

type hybrid_state = [
  | HybridStateWaitReq
  | HybridStateWaitAdv1 of port & port & text
  | HybridStateWaitAdv2 of port & port & text & key
  | HybridStateWaitAdv3 of port & port & text
  | HybridStateFinal
].

local module Hybrid : FUNC = {
  var self : addr
  var st : hybrid_state

  proc init(self_ : addr) : unit = {
    self <- self_;
    st <- HybridStateWaitReq;
  }

  proc _State_HybridStateWaitReq_SMCDir_Pt1_smc_req
       (pt1 pt2 : port, t : text) : msg option = {
    var _r : msg option <- None;
    if (envport self pt2) {
      _r <-
        Some
        (KeyExchange.UC_KEI2S.epdp__ke_sim_req1.`enc
         {|KeyExchange.UC_KEI2S.ke_sim_req1___func = _addr_KE self;
           KeyExchange.UC_KEI2S.ke_sim_req1__pt1 = _intport_Pt1 self;
           KeyExchange.UC_KEI2S.ke_sim_req1__pt2 = _intport_Pt2 self;
          |});
      st <- HybridStateWaitAdv1 pt1 pt2 t;
    }
    else { _r <- None; }
    return _r;
  }

  proc _State_HybridStateWaitAdv1_KeyExchange_KEI2S_ke_sim_rsp
       (pt1 pt2 : port, t : text) : msg option = {
    var q : exp;
    var _r : msg option <- None;
    q <$ dexp;
    _r <-
      Some
      (KeyExchange.UC_KEI2S.epdp__ke_sim_req2.`enc
       {|KeyExchange.UC_KEI2S.ke_sim_req2___func = _addr_KE self;
        |});
    st <- HybridStateWaitAdv2 pt1 pt2 t (g ^ q);
    return _r;
  }

  proc _State_HybridStateWaitAdv2_KeyExchange_KEI2S_ke_sim_rsp
       (pt1 pt2 : port, t : text, k : key) : msg option = {
    var _r : msg option <- None;
    _r <-
      Some
        (Forwarding.UC_FwAdv.epdp__fw_obs.`enc
        {|Forwarding.UC_FwAdv.fw_obs___func = _addr_Fwd self;
          Forwarding.UC_FwAdv.fw_obs__pt1 = _intport_Pt1 self;
          Forwarding.UC_FwAdv.fw_obs__pt2 = _intport_Pt2 self;
          Forwarding.UC_FwAdv.fw_obs__u =
            KeyExpText'.KeyExp'.epdp_port_port_key_univ.`enc
            (pt1, pt2, k);
         |});
    st <- HybridStateWaitAdv3 pt1 pt2 t;
    return _r;
  }

  proc _State_HybridStateWaitAdv3_Forwarding_FwAdv_fw_ok
       (pt1 pt2 : port, t : text) : msg option = {
    var _r : msg option <- None;
    _r <-
      Some
      (UC_SMCDir.Pt2.epdp__smc_rsp.`enc
       {|UC_SMCDir.Pt2.smc_rsp___func = self;
         UC_SMCDir.Pt2.smc_rsp__pt2 = pt2;
         UC_SMCDir.Pt2.smc_rsp__pt1 = pt1;
         UC_SMCDir.Pt2.smc_rsp__t = t;
       |});
     st <- HybridStateFinal;
     return _r;
  }

  proc invoke(m : msg) : msg option = {
    var r : msg option <- None;
    match st with
    | HybridStateWaitReq => {
        if (m.`1 = Dir /\ m.`2 = _extport_dir_Pt1 self) {
          match UC_SMCDir.Pt1.epdp__smc_req.`dec m with
          | Some _x => {
              r <@
                _State_HybridStateWaitReq_SMCDir_Pt1_smc_req
                (_x.`UC_SMCDir.Pt1.smc_req__pt1,
                 _x.`UC_SMCDir.Pt1.smc_req__pt2,
                 _x.`UC_SMCDir.Pt1.smc_req__t);
            }
          | None    => { }
          end;
        }
      }
    | HybridStateWaitAdv1 pt1 pt2 t => {
        if (m.`1 = Adv /\ m.`2.`1 = _addr_KE self /\ m.`3.`1 = adv) {
          match KeyExchange.UC_KEI2S.epdp__ke_sim_rsp.`dec m with
          | Some _ => {
              r <@
                _State_HybridStateWaitAdv1_KeyExchange_KEI2S_ke_sim_rsp
                 (pt1, pt2, t);
            }
          | None   => { }
          end;
        }
      }
    | HybridStateWaitAdv2 pt1 pt2 t k => {
        if (m.`1 = Adv /\ m.`2.`1 = _addr_KE self /\ m.`3.`1 = adv) {
          match KeyExchange.UC_KEI2S.epdp__ke_sim_rsp.`dec m with
          | Some _ => {
            r <@
              _State_HybridStateWaitAdv2_KeyExchange_KEI2S_ke_sim_rsp
              (pt1, pt2, t, k);
            }
          | None   => { }
          end;
        }
      }
    | HybridStateWaitAdv3 pt1 pt2 t => {
        if (m.`1 = Adv /\ m.`2.`1 = _addr_Fwd self /\ m.`3.`1 = adv) {
          match Forwarding.UC_FwAdv.epdp__fw_ok.`dec m with
          | Some _ => {
              r <@
                _State_HybridStateWaitAdv3_Forwarding_FwAdv_fw_ok
                (pt1, pt2, t);
            }
          | None   => {  }
          end;
        }
      }
    | HybridStateFinal => { }
    end;
    return r;
  }
}.

local op invar_Hybrid (g : glob Hybrid) = true.

local op  metric_Hybrid (g : glob Hybrid) : int =
  match g.`2 with
  | HybridStateWaitReq          => 4
  | HybridStateWaitAdv1 _ _ _   => 3
  | HybridStateWaitAdv2 _ _ _ _ => 2
  | HybridStateWaitAdv3 _ _ _   => 1
  | HybridStateFinal            => 0
end.

local lemma metric_Hybrid_good (g : glob Hybrid) :
  invar_Hybrid g => 0 <= metric_Hybrid g.
proof. smt(). qed.

local lemma metric_Hybrid_init :
  hoare [Hybrid.init : true ==> invar_Hybrid (glob Hybrid)].
proof. rewrite /invar_Hybrid; auto. qed.

local lemma metric_Hybrid_invoke (n : int) :
  hoare
  [Hybrid.invoke :
   invar_Hybrid (glob Hybrid) /\
   metric_Hybrid (glob Hybrid) = n ==>
   invar_Hybrid (glob Hybrid) /\
   (res <> None => metric_Hybrid (glob Hybrid) < n)].
proof.
rewrite /invar_Hybrid /metric_Hybrid /=; proc; sp 1.
match.
if; last auto.
match; [auto | inline; auto].
if; last auto.
match; [auto | inline; auto].
if; last auto.
match; [auto | inline; auto].
if; last auto.
match; [auto | inline; auto].
auto.
qed.

local op glob_RFIP_to_self        (g : glob RFIP) : addr                  = g.`1.
local op glob_RFIP_to_st_Pt1      (g : glob RFIP) : _state_Pt1            = g.`2.
local op glob_RFIP_to_st_Pt2      (g : glob RFIP) : _state_Pt2            = g.`3.
local op glob_RFIP_to_self_Fwd    (g : glob RFIP) : addr                  = g.`4.
local op glob_RFIP_to_st_Fwd      (g : glob RFIP) : Forwarding._state_IF  = g.`5.
local op glob_RFIP_to_self_KEIF   (g : glob RFIP) : addr                  = g.`6.
local op glob_RFIP_to_st_KEIF     (g : glob RFIP) : KeyExchange._state_IF = g.`7.
local op glob_RFIP_to_self_MakeRF (g : glob RFIP) : addr                  = g.`8.

local op glob_Hybrid_to_self (g : glob Hybrid) : addr         = g.`1.
local op glob_Hybrid_to_st   (g : glob Hybrid) : hybrid_state = g.`2.

local op rfip_hybrid_invar_static
    (func : addr, grfip : glob RFIP, gh : glob Hybrid) : bool =
  glob_RFIP_to_self grfip        = func /\
  glob_RFIP_to_self_Fwd grfip    = _addr_Fwd func /\
  glob_RFIP_to_self_KEIF grfip   = _addr_KE func /\
  glob_RFIP_to_self_MakeRF grfip = func /\
  glob_Hybrid_to_self gh         = func.

local op rfip_hybrid_invar_static_ports
    (func : addr, grfip : glob RFIP, gh : glob Hybrid,
     pt1 pt2 : port) : bool =
  rfip_hybrid_invar_static func grfip gh /\
  envport func pt1 /\ envport func pt2.

local op rfip_hybrid_invar0
    (func : addr, grfip : glob RFIP, gh : glob Hybrid) : bool =
  rfip_hybrid_invar_static func grfip gh /\
  (* -- *)
  glob_RFIP_to_st_Pt1 grfip  = _State_Pt1_WaitReq /\
  glob_RFIP_to_st_Pt2 grfip  = _State_Pt2_WaitKE1 /\
  glob_RFIP_to_st_Fwd grfip  = Forwarding._State_IF_Init /\
  glob_RFIP_to_st_KEIF grfip = KeyExchange._State_IF_WaitReq1 /\
  (* -- *)
  glob_Hybrid_to_st gh       = HybridStateWaitReq.

local op rfip_hybrid_invar1
    (func : addr, grfip : glob RFIP, gh : glob Hybrid,
     pt1 pt2 : port, t : text) : bool =
  rfip_hybrid_invar_static_ports func grfip gh pt1 pt2 /\
  (* -- *)
  glob_RFIP_to_st_Pt1 grfip  = _State_Pt1_WaitKE2 pt1 pt2 t /\
  glob_RFIP_to_st_Pt2 grfip  = _State_Pt2_WaitKE1 /\
  glob_RFIP_to_st_Fwd grfip  = Forwarding._State_IF_Init /\
  glob_RFIP_to_st_KEIF grfip =
    KeyExchange._State_IF_WaitSim1 (_intport_Pt1 func)
    (_intport_Pt2 func) /\
  (* -- *)
  glob_Hybrid_to_st gh       = HybridStateWaitAdv1 pt1 pt2 t.

local op rfip_hybrid_invar2
    (func : addr, grfip : glob RFIP, gh : glob Hybrid,
     pt1 pt2 : port, t : text, q : exp, k : key) : bool =
  rfip_hybrid_invar_static_ports func grfip gh pt1 pt2 /\
  (* -- *)
  glob_RFIP_to_st_Pt1 grfip  = _State_Pt1_WaitKE2 pt1 pt2 t /\
  glob_RFIP_to_st_Pt2 grfip  = _State_Pt2_WaitFwd (g ^ q) /\
  glob_RFIP_to_st_Fwd grfip  = Forwarding._State_IF_Init /\
  glob_RFIP_to_st_KEIF grfip =
    KeyExchange._State_IF_WaitSim2 (_intport_Pt1 func) q /\
  (* -- *)
  glob_Hybrid_to_st gh       = HybridStateWaitAdv2 pt1 pt2 t k /\
  (* -- *)
  epdp_text_key.`enc t ^^ (g ^ q) = k.

local op rfip_hybrid_invar3
    (func : addr, grfip : glob RFIP, gh : glob Hybrid,
     pt1 pt2 : port, t : text, k : key) : bool =
  rfip_hybrid_invar_static_ports func grfip gh pt1 pt2 /\
  (* -- *)
  glob_RFIP_to_st_Pt1 grfip  = _State_Pt1_Final /\
  glob_RFIP_to_st_Pt2 grfip  = _State_Pt2_WaitFwd k /\
  glob_RFIP_to_st_Fwd grfip  =
    Forwarding._State_IF_Wait (_intport_Pt1 func) (_intport_Pt2 func)
    (KeyExpText'.KeyExp'.epdp_port_port_key_univ.`enc
     (pt1, pt2, epdp_text_key.`enc t ^^ k)) /\
  glob_RFIP_to_st_KEIF grfip = KeyExchange._State_IF_Final /\
  (* -- *)
  glob_Hybrid_to_st gh       = HybridStateWaitAdv3 pt1 pt2 t.

local op rfip_hybrid_invar4
    (func : addr, grfip : glob RFIP, gh : glob Hybrid) : bool =
  rfip_hybrid_invar_static func grfip gh /\
  (* -- *)
  glob_RFIP_to_st_Pt1 grfip  = _State_Pt1_Final /\
  glob_RFIP_to_st_Pt2 grfip  = _State_Pt2_Final /\
  glob_RFIP_to_st_Fwd grfip  = Forwarding._State_IF_Final /\
  glob_RFIP_to_st_KEIF grfip = KeyExchange._State_IF_Final /\
  (* -- *)
  glob_Hybrid_to_st gh       = HybridStateFinal.

local inductive rfip_hybrid_invar
    (func : addr, grfip : glob RFIP, gh : glob Hybrid) =
  | RFIPHybridInvar0 of
      (rfip_hybrid_invar0 func grfip gh)
  | RFIPHybridInvar1 (pt1 pt2 : port, t : text) of
      (rfip_hybrid_invar1 func grfip gh pt1 pt2 t)
  | RFIPHybridInvar2 (pt1 pt2 : port, t : text, q : exp, k : key) of
      (rfip_hybrid_invar2 func grfip gh pt1 pt2 t q k)
  | RFIPHybridInvar3 (pt1 pt2 : port, t : text, k : key) of
      (rfip_hybrid_invar3 func grfip gh pt1 pt2 t k)
  | RFIPHybridInvar4 of
      (rfip_hybrid_invar4 func grfip gh).

local lemma RFIP_Hybrid_init (func' : addr) :
  exper_pre func' =>
  equiv
  [RFIP.init ~ Hybrid.init :
   _self{1} = self_{2} /\ _self{1} = func' ==>
   rfip_hybrid_invar func' (glob RFIP){1} (glob Hybrid){2}].
proof.
move => ep_func'.
proc; inline; auto; smt(RFIPHybridInvar0).
qed.

local lemma RFIP_Hybrid_invoke (func' : addr) :
  exper_pre func' =>
  equiv
  [RFIP.invoke ~ Hybrid.invoke :
   ={m} /\
   (m{1}.`1 = Dir /\ func' = m{1}.`2.`1 /\ envport func' m{1}.`3 \/
    m{1}.`1 = Adv /\ func' <= m{1}.`2.`1 /\
    m{1}.`3.`1 = adv /\ 0 < m{1}.`3.`2) /\
   rfip_hybrid_invar func' (glob RFIP){1} (glob Hybrid){2} ==>
   ={res} /\
   rfip_hybrid_invar func' (glob RFIP){1} (glob Hybrid){2}].
proof.
move => ep_func'.
proc.
exlim (glob RFIP){1}, (glob Hybrid){2} => grfip gh.
(* the "!!" is a hack to make the ambient case be a boolean one *)
case @[ambient] (!! rfip_hybrid_invar func' grfip gh) =>
  [/= [] | ?]; last exfalso; smt().
(* rfip_hybrid_invar0 *)
move => rfip_hybrid_invar0_ass.
sp 1 1.
match HybridStateWaitReq {2} 1; first auto; smt().
if{2}.
rcondt{1} 1; first auto; smt().
inline{1} 1; sp 3 0.
rcondt{1} 1; first auto.
inline{1} 1; sp 2 0.
rcondf{1} 1; first auto; smt(@UCListPO).
rcondf{1} 1; first auto; smt(@UCListPO).
rcondt{1} 1; first auto; progress; smt().
inline{1} 1; sp 2 0.
match _State_Pt1_WaitReq {1} 1; first auto; smt().
match => //.
seq 3 0 :
  (grfip = (glob RFIP){1} /\ gh = (glob Hybrid){2} /\
   r0{1} = None /\ ! not_done{1} /\ r{2} = None).
call{1} (RFCore.MakeRF_after_core_error UC_SMCReal_IP); first auto.
rcondf{1} 1; first auto.
auto; smt(RFIPHybridInvar0).
move => x1 x2; inline{1} 1; inline{2} 1; sp 4 4.
if; first smt().
seq 6 3 :
  (not_done{1} /\ ={pt1, pt2, t} /\
   rfip_hybrid_invar_static_ports func' (glob RFIP){1}
   (glob Hybrid){2} pt1{1} pt2{1} /\
   glob_RFIP_to_st_Pt1 (glob RFIP){1} =
   _State_Pt1_WaitKE2 pt1{1} pt2{1} t{1} /\
   glob_RFIP_to_st_Pt2 (glob RFIP){1} = _State_Pt2_WaitKE1 /\
   glob_RFIP_to_st_Fwd (glob RFIP){1} = Forwarding._State_IF_Init /\
   glob_RFIP_to_st_KEIF (glob RFIP){1} = KeyExchange._State_IF_WaitReq1 /\
   glob_Hybrid_to_st (glob Hybrid){2} =
   HybridStateWaitAdv1 pt1{1} pt2{1} t{1} /\
   m0{1} =
   KeyExchange.UC_KEDir.Pt1.epdp__ke_req1.`enc
   (KeyExchange.UC_KEDir.Pt1.mk__ke_req1
    (_addr_KE func') (_intport_Pt1 func') (_intport_Pt2 func')) /\
   r{2} =
   Some
   (KeyExchange.UC_KEI2S.epdp__ke_sim_req1.`enc
    (KeyExchange.UC_KEI2S.mk__ke_sim_req1
     (_addr_KE func') (_intport_Pt1 func') (_intport_Pt2 func')))).
sp; exlim r0{1} => r0'.
call{1} (RFCore.MakeRF_after_core_continue UC_SMCReal_IP r0').
auto => /> &1 &2 dec_x1 dec_x2.
have -> : x1 = x2 by have : Some x1 = Some x2 by rewrite -dec_x1 -dec_x2.
have x2_eq : x2 = oget (UC_SMCDir.Pt1.epdp__smc_req.`dec m{2}) by smt().
have /# -> : UC_SMCDir.Pt1.smc_req__pt1 x2 = m{2}.`3.
  have -> /= := UC_SMCDir.Pt1.eq_of_valid__smc_req m{2} _; first smt().
  by rewrite x2_eq.
rcondt{1} 1; first auto.
inline{1} 1; sp 2 0.
rcondf{1} 1; first auto => />; smt(@UCListPO).
rcondt{1} 1; first auto => />; smt(@UCListPO).
inline{1} 1; sp 2 0.
rcondt{1} 1; first auto; progress; smt(@UCListPO).
inline{1} 1; sp 2 0.
match _State_IF_WaitReq1 {1} 1; first auto.
match Some {1} 1; first auto; progress; smt().
inline{1} 1; sp 3 0.
rcondt{1} 1; first auto.
move => &hr [#] _ -> _ dec_eq.
have -> :
  _x{hr} = oget (KeyExchange.UC_KEDir.Pt1.epdp__ke_req1.`dec _m0{hr})
  by smt().
progress; smt(@UCListPO).
seq 7 0 :
  (! not_done{1} /\ r0{1} = r{2} /\
   rfip_hybrid_invar1 func' (glob RFIP){1} (glob Hybrid){2}
   pt1{1} pt2{1} t{1}).
sp; exlim r0{1} => r0'.
call{1} (RFCore.MakeRF_after_core_return UC_SMCReal_IP r0').
auto => />; smt(_adv_pi_begin_gt0 next_of_addr_self_plus @UCListPO).
rcondf{1} 1; first auto.
auto; smt(RFIPHybridInvar1).
seq 5 0 :
  (grfip = (glob RFIP){1} /\ gh = (glob Hybrid){2} /\
   r0{1} = None /\ ! not_done{1} /\ r{2} = None).
call{1} (RFCore.MakeRF_after_core_error UC_SMCReal_IP); first auto.
rcondf{1} 1; first auto.
auto; smt(RFIPHybridInvar0).
if{1}.
inline{1} 1; sp 3 0.
rcondt{1} 1; first auto.
inline{1} 1; sp 2 0.
if{1}.
inline{1} 1; sp 2 0.
if{1}.
inline{1} 1; sp 2 0.
match _State_IF_Init {1} 1; first auto; smt().
match None {1} 1;
  first auto; smt(Forwarding.UC_FwDir.D.eq_of_valid__fw_req).
seq 4 0 :
  (grfip = (glob RFIP){1} /\ gh = (glob Hybrid){2} /\
   r0{1} = None /\ ! not_done{1} /\ r{2} = None).
call{1} (RFCore.MakeRF_after_core_error UC_SMCReal_IP); first auto.
rcondf{1} 1; first auto.
auto; smt(RFIPHybridInvar0).
seq 3 0 :
  (grfip = (glob RFIP){1} /\ gh = (glob Hybrid){2} /\
   r0{1} = None /\ ! not_done{1} /\ r{2} = None).
call{1} (RFCore.MakeRF_after_core_error UC_SMCReal_IP); first auto.
rcondf{1} 1; first auto.
auto; smt(RFIPHybridInvar0).
if{1}.
inline{1} 1; sp 2 0.
if{1}.
inline{1} 1; sp 2 0.
match _State_IF_WaitReq1 {1} 1; first auto; smt().
match None {1} 1;
  first auto; smt(KeyExchange.UC_KEDir.Pt1.eq_of_valid__ke_req1).
seq 4 0 :
  (grfip = (glob RFIP){1} /\ gh = (glob Hybrid){2} /\
   r0{1} = None /\ ! not_done{1} /\ r{2} = None).
call{1} (RFCore.MakeRF_after_core_error UC_SMCReal_IP); first auto.
rcondf{1} 1; first auto.
auto; smt(RFIPHybridInvar0).
seq 3 0 :
  (grfip = (glob RFIP){1} /\ gh = (glob Hybrid){2} /\
   r0{1} = None /\ ! not_done{1} /\ r{2} = None).
call{1} (RFCore.MakeRF_after_core_error UC_SMCReal_IP); first auto.
rcondf{1} 1; first auto.
auto; smt(RFIPHybridInvar0).
rcondf{1} 1; first auto; smt().
if{1}.
inline{1} 1; sp 2 0.
match _State_Pt2_WaitKE1 {1} 1; first auto; smt().
match{1}.
seq 3 0 :
  (grfip = (glob RFIP){1} /\ gh = (glob Hybrid){2} /\
   r0{1} = None /\ ! not_done{1} /\ r{2} = None).
call{1} (RFCore.MakeRF_after_core_error UC_SMCReal_IP); first auto.
rcondf{1} 1; first auto.
auto; smt(RFIPHybridInvar0).
rcondf{1} 1; first auto; smt(@UCListPO).
seq 3 0 :
  (grfip = (glob RFIP){1} /\ gh = (glob Hybrid){2} /\
   r0{1} = None /\ ! not_done{1} /\ r{2} = None).
call{1} (RFCore.MakeRF_after_core_error UC_SMCReal_IP); first auto.
rcondf{1} 1; first auto.
auto; smt(RFIPHybridInvar0).
seq 2 0 :
  (grfip = (glob RFIP){1} /\ gh = (glob Hybrid){2} /\
   r0{1} = None /\ ! not_done{1} /\ r{2} = None).
call{1} (RFCore.MakeRF_after_core_error UC_SMCReal_IP); first auto.
rcondf{1} 1; first auto.
auto; smt(RFIPHybridInvar0).
auto.
(* rfip_hybrid_invar1 *)
move => pt1' pt2' t' rfip_hybrid_invar1_ass.
sp 1 1.
match HybridStateWaitAdv1 {2} 1; first auto; smt().
if{2}.
rcondt{1} 1; first auto; progress; smt(@UCListPO).
inline{1} 1; sp 3 0.
rcondt{1} 1; first auto.
inline{1} 1; sp 2 0.
rcondf{1} 1; first auto; progress; smt(@UCListPO).
rcondt{1} 1; first auto; progress; smt(@UCListPO).
inline{1} 1; sp 2 0.
rcondt{1} 1; first auto; smt().
inline{1} 1; sp 2 0.
match _State_IF_WaitSim1 {1} 1; first auto; smt().
match => //.
seq 4 0 :
  (grfip = (glob RFIP){1} /\ gh = (glob Hybrid){2} /\
   r0{1} = None /\ ! not_done{1} /\ r{2} = None).
call{1} (RFCore.MakeRF_after_core_error UC_SMCReal_IP); first auto.
rcondf{1} 1; first auto.
auto; smt(RFIPHybridInvar1).
move => x1 x2; inline{1} 1; inline{2} 1; sp 3 4.
(* use of isomorphism in random sampling *)
seq 1 1 : (#pre /\ epdp_text_key.`enc t' ^^ (g ^ q{1}) = g ^ q{2}).
rnd (KeyExpText'.pad_iso_l t') (KeyExpText'.pad_iso_r t').
auto; progress.
by rewrite (KeyExpText'.pad_iso_rl t').
by rewrite (KeyExpText'.pad_iso_lr t').
by rewrite KeyExpText'.gen_to_pad_iso_l_eq.
seq 7 3 :
  (not_done{1} /\
   m0{1} =
   KeyExchange.UC_KEDir.Pt2.epdp__ke_rsp1.`enc
   (KeyExchange.UC_KEDir.Pt2.mk__ke_rsp1
    (_addr_KE func') (_intport_Pt2 func') (_intport_Pt1 func')
    (g ^ q{1})) /\
