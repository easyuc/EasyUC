local lemma Exper_Hybrid_IF_Sim
            (func' : addr, in_guard' : int fset) &m :
  exper_pre func' =>
  disjoint in_guard' (fset1 _adv_if_pi) =>
  Pr[Exper(MI(Hybrid, Adv), Env).main(func', in_guard') @ &m : res] =
  Pr[Exper(MI(IF, SIM(Adv)), Env).main(func', in_guard') @ &m : res].
proof.
move => ep disj.
have /# :
  `|Pr[Exper(MI(Hybrid, Adv), Env)
         .main(func', in_guard') @ &m : res] -
     Pr[Exper(MI(IF, SIM(Adv)), Env)
         .main(func', in_guard') @ &m : res]| <= 0%r.
  apply
  (MSCore.dummy_adversary Env Adv Hybrid IF SimCore
   invar_Hybrid metric_Hybrid
   _invar_IF _metric_IF
   invar_SimCore metric_SimCore
   func' in_guard' 0%r &m) => //.
  apply metric_Hybrid_good.
  apply metric_Hybrid_init.
  apply metric_Hybrid_invoke.
  apply IF_metric_good.
  apply IF_init.
  move => n; conseq (IF_invoke n) => &hr; smt(mem_oflist).
  apply metric_SimCore_good.
  apply metric_SimCore_init.
  apply metric_SimCore_invoke.
  by rewrite (Exper_Hybrid_IF_SimCore_DummyAdv (MSCore.CombEnvAdv(Env, Adv))).
qed.

lemma Exper_RFIP_IF_Sim (func : addr, in_guard : int fset) &m :
  exper_pre func =>
  disjoint in_guard (adv_pis_rf_info rf_info) =>
  `|Pr[Exper(MI(RFIP, Adv), Env).main(func, in_guard) @ &m : res] -
    Pr[Exper(MI(IF, SIM(Adv)), Env).main(func, in_guard) @ &m : res]| <= 0.0.
proof.
move => ep disj.
rewrite -(Exper_Hybrid_IF_Sim func in_guard &m ep _) //.
smt(in_fset1 mem_adv_pis_rf_info disjointP).
by rewrite Exper_RFIP_Hybrid.
qed.

end section.

lemma SMC_RFIP_IF_advantage
      (Env <: ENV{-MI, -RFIP, -IF, -SIM, -AllCGs})
      (Adv <: ADV{-MI, -RFIP, -IF, -SIM, -AllCGs, -Env})
      (func' : addr, in_guard' : int fset) &m :
  exper_pre func' =>
  disjoint in_guard' (adv_pis_rf_info rf_info) =>
 `|Pr[Exper(MI(RFIP, Adv), Env).main(func', in_guard') @ &m : res] -
    Pr[Exper(MI(IF, SIM(Adv)), Env).main(func', in_guard') @ &m : res]| <= 0.0.
proof.
move => ep disj; by apply (Exper_RFIP_IF_Sim Adv Env).
qed.

