clone UC_SMC2Sim_abs as UC_SMC2Sim with
  op pi = 1
proof *.

type _state_IF = [ 
  | _State_IF_Final
  | _State_IF_WaitReq
  | _State_IF_WaitSim of (port) & (port) & (text)
  
]. 

module UC_SMCIdeal : FUNC= {
  var _self : addr
  var _st : _state_IF
  proc init(self_ : addr) : unit = {
    _self <- self_; _st <- _State_IF_WaitReq;
  }
  proc _State_IF_WaitReq__SMCDir__Pt1__smc_req (pt1 : port, pt2 : port, t : text) : msg option = {
    var _r : msg option <- None;
    if (envport _self pt2) {
      _r <- Some
        (UC_SMC2Sim.epdp__sim_req.`enc
        {|
          UC_SMC2Sim.sim_req___func = _self;
          UC_SMC2Sim.sim_req___adv = adv;
          UC_SMC2Sim.sim_req__pt1 = pt1;
          UC_SMC2Sim.sim_req__pt2 = pt2;
          
        |});
      _st <- _State_IF_WaitSim (pt1) (pt2) (t);
      
    }
    else {
      _r <- None;
      
    }
    return _r;
  }
  proc _State_IF_WaitSim__SMC2Sim__sim_rsp (pt1 : port, pt2 : port, t : text) : msg option = {
    var _r : msg option <- None;
    _r <- Some
      (UC_SMCDir.Pt2.epdp__smc_rsp.`enc
      {|
        UC_SMCDir.Pt2.smc_rsp___func = _self;
        UC_SMCDir.Pt2.smc_rsp__pt2 = pt2;
        UC_SMCDir.Pt2.smc_rsp__pt1 = pt1;
        UC_SMCDir.Pt2.smc_rsp__t = t;
        
      |});
    _st <- _State_IF_Final;
    return _r;
  }
  proc parties(_m : msg) : msg option = {
    var _r : msg option <- None;
    match _st with
    | _State_IF_Final => {
      
    }
    | _State_IF_WaitReq => {
      match UC_SMCDir.Pt1.epdp__smc_req.`dec _m with
      | Some _x => {
        _r <@ _State_IF_WaitReq__SMCDir__Pt1__smc_req (_x.`UC_SMCDir.Pt1.smc_req__pt1, _x.`UC_SMCDir.Pt1.smc_req__pt2, _x.`UC_SMCDir.Pt1.smc_req__t);
      }
      | None => {
        
      }
      end;
    }
    | _State_IF_WaitSim pt1 pt2 t => {
      match UC_SMC2Sim.epdp__sim_rsp.`dec _m with
      | Some _x => {
        _r <@ _State_IF_WaitSim__SMC2Sim__sim_rsp (pt1, pt2, t);
      }
      | None => {
        
      }
      end;
    }
    end;
    return _r;
  }
  proc invoke(m : msg) : msg option = {
    var r : msg option <- None;
    if ((m.`1 = Dir /\ m.`2.`1 = _self /\ envport _self m.`3)\/ (m.`1 = Adv
                                                               /\
                                                               m.`2.`1 = _self
                                                               /\
                                                               m.`3.`1 = adv)){
      r <@ parties(m);
    }
  return r;
  }
  
}.


(*alias*)
module IF = UC_SMCIdeal.
op _invar_IF (g : glob IF) : bool = true.

 

op glob_UC_SMCIdeal_to__st (g : glob UC_SMCIdeal) / : _state_IF = g.`2.
op [smt_opaque] _metric_IF (g : glob UC_SMCIdeal) : int =
  match glob_UC_SMCIdeal_to__st g with
  | _State_IF_Final => 0
  | _State_IF_WaitReq => 2
  | _State_IF_WaitSim _ _ _ => 1
  end.
  


lemma IF_invoke (n : int) : hoare [
  UC_SMCIdeal.invoke :
  _invar_IF (glob UC_SMCIdeal) /\ _metric_IF (glob UC_SMCIdeal) = n
  ==>
  _invar_IF (glob UC_SMCIdeal) /\ 
  (res <> None =>
  _metric_IF (glob UC_SMCIdeal) < n
  /\ ((oget res).`1 = Adv => (oget res).`2.`2 \in oflist [_adv_if_pi] /\ (oget res).`3.`2 = 1))
   ].
proof. rewrite /_metric_IF /=. proc. sp 1. (*initializing return value*)
if. (*invoke guard*) inline. sp 1. sp 1. (*initializing input, return value*)
match. (*state match*)
(*state branch Final*) sp 1. skip. move => />;smt(). (*empty state match branch code*)
(*state branch WaitReq*) match. (*message match*)
sp 1. skip. move => />;smt(). (*None branch of message match, dec failed*)
sp 1. (*state param assignment, return value initialization*)sp 3. (*pattern bindings*)
if. (*if instruction*)
sp 1. sp 3. skip. move => />;smt(mem_oflist mem_rangeset in_fsetU). (*SendAndTransition instruction*)
 sp 1. sp 2. skip. move => />;smt(). (*Fail instruction*)  
(*state branch WaitSim*) match. (*message match*)
sp 1. skip. move => />;smt(). (*None branch of message match, dec failed*)
sp 4. (*state param assignment, return value initialization*)sp 1. sp 3. skip. move => />;smt(mem_oflist mem_rangeset in_fsetU). (*SendAndTransition instruction*)
 skip. smt(). (*invoke guard false*) qed. 

lemma IF_metric_good (g : glob IF) :   _invar_IF g => 0 <= _metric_IF g.
  proof. rewrite /_metric_IF /=.   smt(). qed.   lemma IF_init :
  hoare [IF.init : true ==> _invar_IF (glob IF)]. proof. proc. auto. qed. 
 


op rf_info = {| rfi_num_parties = 2; rfi_num_subfuns = 1; rfi_num_params = 1;
rfi_adv_pi_begin = _adv_pi_begin;
rfi_adv_pi_main_end = _adv_pi_begin + _adv_pi_num - 1 - KeyExchange._adv_pi_num;
rfi_adv_pi_begin_params = [_adv_pi_begin_UC_KeyExchange];
rfi_adv_pi_end_params = [_adv_pi_begin_UC_KeyExchange + KeyExchange._adv_pi_num - 1];
|}. 

op _addr_KE (self : addr) : addr = self ++ [1].

op _addr_Fwd (self : addr) : addr = self ++ [2].

op _extport_dir_Pt1 (self : addr) : port = (self, 1).
op _extport_dir_Pt2 (self : addr) : port = (self, 2).


op _intport_Pt1 (self : addr) : port = (self, 1).
op _intport_Pt2 (self : addr) : port = (self, 2).
 

type _state_Pt1 = [ 
  | _State_Pt1_Final
  | _State_Pt1_WaitKE2 of (port) & (port) & (text)
  | _State_Pt1_WaitReq
  
].
type _state_Pt2 = [ 
  | _State_Pt2_Final
  | _State_Pt2_WaitFwd of (key)
  | _State_Pt2_WaitKE1
  
].


module UC_SMCReal (KE__ : FUNC) : FUNC = {
  var _self : addr
  var _st_Pt1 : _state_Pt1
  var _st_Pt2 : _state_Pt2
  
  proc init(self_ : addr) : unit = {
    _self <- self_;
  Forwarding.IF.init(_addr_Fwd _self);
  KE__.init(_addr_KE _self);
  _st_Pt1 <- _State_Pt1_WaitReq;
  _st_Pt2 <- _State_Pt2_WaitKE1;
  }
  proc _State_Pt1_WaitKE2__KE__Pt1__ke_rsp2 (pt1 : port, pt2 : port, t : text, k : KeyExchange.key) : msg option = {
    var _r : msg option <- None;
    _r <- Some
      (Forwarding.UC_FwDir.D.epdp__fw_req.`enc
      {|
        Forwarding.UC_FwDir.D.fw_req___func = _addr_Fwd _self;
        Forwarding.UC_FwDir.D.fw_req__pt1 = _intport_Pt1 _self;
        Forwarding.UC_FwDir.D.fw_req__pt2 = _intport_Pt2 _self;
        Forwarding.UC_FwDir.D.fw_req__u = epdp_port_port_key_univ.`enc
        (pt1, pt2, epdp_text_key.`enc t ^^ k);
        
      |});
    _st_Pt1 <- _State_Pt1_Final;
    return _r;
  }
  proc _State_Pt1_WaitReq__SMCDir__Pt1__smc_req (pt1 : port, pt2 : port, t : text) : msg option = {
    var _r : msg option <- None;
    if (envport _self pt2) {
      _r <- Some
        (KeyExchange.UC_KEDir.Pt1.epdp__ke_req1.`enc
        {|
          KeyExchange.UC_KEDir.Pt1.ke_req1___func = _addr_KE _self;
          KeyExchange.UC_KEDir.Pt1.ke_req1__pt1 = _intport_Pt1 _self;
          KeyExchange.UC_KEDir.Pt1.ke_req1__pt2 = _intport_Pt2 _self;
          
        |});
      _st_Pt1 <- _State_Pt1_WaitKE2 (pt1) (pt2) (t);
      
    }
    else {
      _r <- None;
      
    }
    return _r;
  }
  proc party_Pt1(_m : msg) : msg option = {
    var _r : msg option <- None;
    match _st_Pt1 with
    | _State_Pt1_Final => {
      
    }
    | _State_Pt1_WaitKE2 pt1 pt2 t => {
      match KeyExchange.UC_KEDir.Pt1.epdp__ke_rsp2.`dec _m with
      | Some _x => {
        if (_m.`3.`1 = _addr_KE _self){
          _r <@ _State_Pt1_WaitKE2__KE__Pt1__ke_rsp2 (pt1, pt2, t, _x.`KeyExchange.UC_KEDir.Pt1.ke_rsp2__k);
        }
        
      }
      | None => {
        
      }
      end;
    }
    | _State_Pt1_WaitReq => {
      match UC_SMCDir.Pt1.epdp__smc_req.`dec _m with
      | Some _x => {
        _r <@ _State_Pt1_WaitReq__SMCDir__Pt1__smc_req (_x.`UC_SMCDir.Pt1.smc_req__pt1, _x.`UC_SMCDir.Pt1.smc_req__pt2, _x.`UC_SMCDir.Pt1.smc_req__t);
      }
      | None => {
        
      }
      end;
    }
    end;
    return _r;
  }
  proc _State_Pt2_WaitFwd__Fwd__D__fw_rsp (k : key, u : univ) : msg option = {
    var pt1 : port;
    var pt2 : port;
    var x : key;
    var _r : msg option <- None;
    match (epdp_port_port_key_univ.`dec u) with
    | None<:(int list * int) * (int list * int) * key> => {
    
      _r <- None;
      
    }
    | Some tr => {
    
      (pt1, pt2, x) <- tr;
      match (epdp_text_key.`dec (x ^^ kinv k)) with
      | None<:text> => {
      
        _r <- None;
        
      }
      | Some t => {
      
        _r <- Some
          (UC_SMCDir.Pt2.epdp__smc_rsp.`enc
          {|
            UC_SMCDir.Pt2.smc_rsp___func = _self;
            UC_SMCDir.Pt2.smc_rsp__pt2 = pt2;
            UC_SMCDir.Pt2.smc_rsp__pt1 = pt1;
            UC_SMCDir.Pt2.smc_rsp__t = t;
            
          |});
        _st_Pt2 <- _State_Pt2_Final;
        
      }
      end;
    
    }
    end;
return _r;
}
proc _State_Pt2_WaitKE1__KE__Pt2__ke_rsp1 (k : KeyExchange.key) : msg option = {
  var _r : msg option <- None;
  _r <- Some
    (KeyExchange.UC_KEDir.Pt2.epdp__ke_req2.`enc
    {|
      KeyExchange.UC_KEDir.Pt2.ke_req2___func = _addr_KE _self;
      KeyExchange.UC_KEDir.Pt2.ke_req2__pt2 = _intport_Pt2 _self;
      
    |});
  _st_Pt2 <- _State_Pt2_WaitFwd (k);
  return _r;
}
proc party_Pt2(_m : msg) : msg option = {
  var _r : msg option <- None;
  match _st_Pt2 with
  | _State_Pt2_Final => {
    
  }
  | _State_Pt2_WaitFwd k => {
    match Forwarding.UC_FwDir.D.epdp__fw_rsp.`dec _m with
    | Some _x => {
      if (_m.`3.`1 = _addr_Fwd _self){
        _r <@ _State_Pt2_WaitFwd__Fwd__D__fw_rsp (k, _x.`Forwarding.UC_FwDir.D.fw_rsp__u);
      }
      
    }
    | None => {
      
    }
    end;
  }
  | _State_Pt2_WaitKE1 => {
    match KeyExchange.UC_KEDir.Pt2.epdp__ke_rsp1.`dec _m with
    | Some _x => {
      if (_m.`3.`1 = _addr_KE _self){
        _r <@ _State_Pt2_WaitKE1__KE__Pt2__ke_rsp1 (_x.`KeyExchange.UC_KEDir.Pt2.ke_rsp1__k);
      }
      
    }
    | None => {
      
    }
    end;
  }
  end;
  return _r;
}
proc invoke(m : msg) : msg option = {
  var r : msg option <- None;
  if (_addr_Fwd _self <= m.`2.`1) {r <@ Forwarding.IF.invoke(m);}
  else {
  if (_addr_KE _self <= m.`2.`1) {r <@ KE__.invoke(m);}
  else {
  if((m.`1 = Dir /\ m.`2 = _extport_dir_Pt1 _self /\ envport _self m.`3)
  \/
  (m.`1 = Dir /\ m.`2 = _intport_Pt1 _self /\ _self < m.`3.`1))
  {r <@ party_Pt1(m);}
  else {
  if((m.`1 = Dir /\ m.`2 = _extport_dir_Pt2 _self /\ envport _self m.`3)
  \/
  (m.`1 = Dir /\ m.`2 = _intport_Pt2 _self /\ _self < m.`3.`1))
  {r <@ party_Pt2(m);}
  }
  }
  }
  return r;
  }
  
}. 
op glob_UC_SMCReal_to__st_Pt2 (g : glob UC_SMCReal) / : _state_Pt2 = g.`3.

op [smt_opaque] _metric_Pt2 (g : _state_Pt2) : int =
  match g with
  | _State_Pt2_Final => 0
  | _State_Pt2_WaitFwd _ => 1
  | _State_Pt2_WaitKE1 => 2
  end.
  


lemma _invoke_Pt2 (n : int) (KeyExchange <: FUNC)  : hoare [
  UC_SMCReal(KeyExchange).party_Pt2 :
  _metric_Pt2 (glob_UC_SMCReal_to__st_Pt2(glob UC_SMCReal)) = n ==>
  (res <> None =>
  _metric_Pt2 (glob_UC_SMCReal_to__st_Pt2(glob UC_SMCReal)) < n
   /\ ((oget res).`1 = Adv => (oget res).`2.`2 \in  adv_pis_rf_info rf_info))
]. proof. rewrite /_metric_Pt2 /=. proc. inline. (*inline procedure calls*)
 sp 1. (*initializing input, return value*) match. (*state match*)
(*state branch Final*)  skip. move => />;smt(). (*empty state match branch code*)
(*state branch WaitFwd*) match. (*message match*)
 skip. move => />;smt(). (*None branch of message match, dec failed*)
if. (*address check for internal messages*)
sp 2. (*state param assignment, return value initialization*)sp 1. (*pattern bindings*)
match. (*match instruction with 2 branches*)
(*branch None*)  sp 2. skip. move => />;smt(). (*Fail instruction*)  
(*branch Some*) sp 1. (*Assign instruction*) 
match. (*match instruction with 2 branches*)
(*branch None*)  sp 2. skip. move => />;smt(). (*Fail instruction*)  
(*branch Some*)
 sp 3. skip. move => />;smt(mem_oflist mem_rangeset in_fsetU). (*SendAndTransition instruction*)
      skip. move => />;smt(). (*address check for internal messages failed case*)
(*state branch WaitKE1*) match. (*message match*)
 skip. move => />;smt(). (*None branch of message match, dec failed*)
if. (*address check for internal messages*)
sp 1. (*state param assignment, return value initialization*)sp 1. (*pattern bindings*)
 sp 3. skip. move => />;smt(mem_oflist mem_rangeset in_fsetU). (*SendAndTransition instruction*)
  skip. move => />;smt(). (*address check for internal messages failed case*)
qed. 

op _invar_Pt2 (g : _state_Pt2) : bool = true.

lemma _metric_Pt2_good (g : _state_Pt2) :
  _invar_Pt2 g => 0 <= _metric_Pt2 g.
    proof. rewrite /_metric_Pt2 /=.
      smt(). qed.


op glob_UC_SMCReal_to__st_Pt1 (g : glob UC_SMCReal) / : _state_Pt1 = g.`2.

op [smt_opaque] _metric_Pt1 (g : _state_Pt1) : int =
  match g with
  | _State_Pt1_Final => 0
  | _State_Pt1_WaitKE2 _ _ _ => 1
  | _State_Pt1_WaitReq => 2
  end.
  


lemma _invoke_Pt1 (n : int) (KeyExchange <: FUNC)  : hoare [
  UC_SMCReal(KeyExchange).party_Pt1 :
  _metric_Pt1 (glob_UC_SMCReal_to__st_Pt1(glob UC_SMCReal)) = n ==>
  (res <> None =>
  _metric_Pt1 (glob_UC_SMCReal_to__st_Pt1(glob UC_SMCReal)) < n
   /\ ((oget res).`1 = Adv => (oget res).`2.`2 \in  adv_pis_rf_info rf_info))
]. proof. rewrite /_metric_Pt1 /=. proc. inline. (*inline procedure calls*)
 sp 1. (*initializing input, return value*) match. (*state match*)
(*state branch Final*)  skip. move => />;smt(). (*empty state match branch code*)
(*state branch WaitKE2*) match. (*message match*)
 skip. move => />;smt(). (*None branch of message match, dec failed*)
if. (*address check for internal messages*)
sp 4. (*state param assignment, return value initialization*)sp 1. (*pattern bindings*)
 sp 3. skip. move => />;smt(mem_oflist mem_rangeset in_fsetU). (*SendAndTransition instruction*)
  skip. move => />;smt(). (*address check for internal messages failed case*)
(*state branch WaitReq*) match. (*message match*)
 skip. move => />;smt(). (*None branch of message match, dec failed*)
sp 1. (*state param assignment, return value initialization*)sp 3. (*pattern bindings*)
if. (*if instruction*)
 sp 3. skip. move => />;smt(mem_oflist mem_rangeset in_fsetU). (*SendAndTransition instruction*)
  sp 2. skip. move => />;smt(). (*Fail instruction*)   qed. 

op _invar_Pt1 (g : _state_Pt1) : bool = true.

lemma _metric_Pt1_good (g : _state_Pt1) :
  _invar_Pt1 g => 0 <= _metric_Pt1 g.
    proof. rewrite /_metric_Pt1 /=.
      smt(). qed.


