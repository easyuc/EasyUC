(*all CompGlobs module, abreviation for lemma module restrictions*)
module AllCGs_ = {
module OwnCGs = UC_Composition.CompGlobs
module KeyExchangeAllCGs = KeyExchange.AllCGs
}. 
(*all IFs module, abreviation for lemma module restrictions*)
module AllIFs = {
module OwnIF = IF
module KeyExchangeAllIFs = KeyExchange.AllIFs
}. 
lemma equiv_UC_SMCReal_RP_Composed1_RP
    (Env <: ENV{-MI, -RFRP, -AllCGs_})
    (Adv <: ADV{-MI, -Env,  -RFRP, -AllCGs_})
    (func' : addr, in_guard' : int fset) &m :
  `|Pr[Exper(MI(RFRP,Adv), Env).main(func', in_guard') @ &m : res]
-
Pr[Exper(MI(UC__Rest1.MakeRFComp(UC_SMCReal_Rest1, KeyExchange.RFRP), Adv), Env).main(func', in_guard') @ &m : res]| <= 0.0
 .
 proof. 

(*change the goal to equal probabilities in order to apply byequiv*)
have H:
(
`|Pr[Exper(MI(RFRP,Adv), Env).main(func', in_guard') @ &m : res]
-
Pr[Exper(MI(UC__Rest1.MakeRFComp(UC_SMCReal_Rest1, KeyExchange.RFRP), Adv), Env).main(func', in_guard') @ &m : res]| <= 0.0
)
    <=>
(
Pr[Exper(MI(RFRP,Adv), Env).main(func', in_guard') @ &m : res]
 =
Pr[Exper(MI(UC__Rest1.MakeRFComp(UC_SMCReal_Rest1, KeyExchange.RFRP), Adv), Env).main(func', in_guard') @ &m : res]
).
smt().

apply H.
clear H.

byequiv => //. 

(*unfold Exper main procedures, put in precondition all up to Adv.init call*)
proc.
inline *.
sp.

 
 
(*Adv init call doesn't touch any of the globs, because of module restrictions*)
seq 1 1 : (={func, in_guard, glob Env,
glob Adv,
glob MI,
glob KeyExchange.RFRP,
glob UC_SMCReal
}
/\ RFCore.MakeRF.self{1} = UC_Composition.CompGlobs.mrfc_self{2}
/\ UC_SMCReal._self{1} =  UC_Composition.CompGlobs.mrfc_self{2}).
call (_ : true).
skip.
move => />.
       
(*calling ENV main doesn't make a difference in globs between left and right side*)
call (_ : ={
glob Adv,
glob MI,
glob KeyExchange.RFRP,
glob UC_SMCReal
}
/\ RFCore.MakeRF.self{1} = UC_Composition.CompGlobs.mrfc_self{2}
/\ UC_SMCReal._self{1} =  UC_Composition.CompGlobs.mrfc_self{2}
  ); last first.
skip; move => />.
       
(*unfold MI invoke to show the result is the same on both sides*)
proc.

  (*if m is not in inguard the result is the same on both sides*)
if; last first.
sp.
skip.
move => />.
move => />.

(*if m is in inguard the loop will return the same on both sides*) 
      inline loop.
(* on both sides before the while loop we have:
m0 <- m                                              
r0 <- None     
not_done <- true
      
and after the loop
r <- r0
*)
sp.
wp.
 
(*the locals and globals are the same after each iteration of the while loop*)
while (={r0, m, m0, not_done,
glob Adv,
glob MI,
glob KeyExchange.RFRP,
glob UC_SMCReal
}
/\ RFCore.MakeRF.self{1} = UC_Composition.CompGlobs.mrfc_self{2}
/\ UC_SMCReal._self{1} =  UC_Composition.CompGlobs.mrfc_self{2}); last first.
 skip; move => />.
 
(*case when (MakeInt.MI.func <= m0.`2.`1) is false is similar on both sides*)
if; last first.
sim.
move => />.
 
(*case when (MakeInt.MI.func <= m0.`2.`1) is true,
if calling invoke has the same result, the rest is similar on both sides*)
seq 1 1 : (={r0, m, m0, not_done,
glob Adv,
glob MI,
glob KeyExchange.RFRP,
glob UC_SMCReal
}
/\ RFCore.MakeRF.self{1} = UC_Composition.CompGlobs.mrfc_self{2}
/\ UC_SMCReal._self{1} =  UC_Composition.CompGlobs.mrfc_self{2}); last first.
sim.
 
(*show that MakeRF and MakeRFComp invoke have the same result*)
inline invoke.
sp.

(*the if conditions are the same, testing if real functionality is the
  destination m, in case it is not the destination the results are the same*)
if; last first.
sp. skip.
move => />.
move => />.
wp.
 
(*in case real functionality is the destination of m,
  the loops return the same result*)
inline loop.
sp.
wp.
 
(*each iteration of the wile loop has same result on both sides*)  
while (={r0, r1, r2, m, m0, m1, m2, not_done, not_done0,
glob Adv,
glob MI,
glob KeyExchange.RFRP,
glob UC_SMCReal
}
/\ RFCore.MakeRF.self{1} = UC_Composition.CompGlobs.mrfc_self{2}
/\ UC_SMCReal._self{1} =  UC_Composition.CompGlobs.mrfc_self{2}
); last first.
 skip. move => />.
 
(*we inline real functionality invoke and composed functionality invoke
to show the result is the same*)
inline{1} (1) invoke. 
inline UC_SMCReal_Rest1.invoke.
sp 2 0.
 
(*case when message is for the first parameter functionality*)
 case (UC_Composition.CompGlobs.mrfc_self{2} ++ [UC__Rest1.change_pari] <= m2{2}.`2.`1).

(*the message is not for 1. sub-functionality*)
rcondf{1} 1.
move => &m0.
skip.
move => />.
smt(not_le_other_branch).
       
(*the if conditions on both sides are equivalent and true, and result is the same*)
rcondt{1} 1.
move => &m0.
skip.
move => />.

rcondt{2} 1.
move => &m0.
skip.
move => />.

sim.

(*case when message is NOT for the first parameter*)
(*message is NOT for the first parameter on right side*)
    rcondf {2} 1.
move => &m0.
skip.
move => />.
sp 0 2.
 
(*if m is for 1. sub-functionality*)
if.
move => />.
sim.

(*message is NOT for the first parameter on left side*)
rcondf{1} 1.
move => &m0.
skip.
move => />.

(*the rest is similar*)
 sim.
 
qed.  

(*Simulator stack abreviation*)
module SIMIP(Adv : ADV) = KeyExchange.SIMCOMP(Adv).

lemma diff_Composed1_RP_Composed1_IP
    (Env <: ENV{-MI,  -AllCGs_, -RFRP, -SIMIP, -AllIFs})
    (Adv <: ADV{-MI, -AllCGs_, -Env,  -RFRP, -SIMIP, -AllIFs})
    (func' : addr, in_guard' : int fset) &m :
    exper_pre func' =>
    disjoint in_guard' (adv_pis_rf_info rf_info) =>
`|Pr[Exper(MI(UC__Rest1.MakeRFComp(UC_SMCReal_Rest1, KeyExchange.RFRP), Adv), Env).main(func', in_guard') @ &m : res]
  -
Pr[Exper(MI(UC__Rest1.MakeRFComp(UC_SMCReal_Rest1, KeyExchange.IF), KeyExchange.SIMCOMP(Adv)), Env).main(func', in_guard') @ &m : res]|
  <=
`|Pr[KeyExchange.DDH1(KeyExchange.DDH_Adv(COMPENV1(Env), Adv)).main(func' ++ [UC__Rest1.change_pari], in_guard' `|` UC__Rest1.rest_adv_pis) @ &m : res] -
  Pr[KeyExchange.DDH2(KeyExchange.DDH_Adv(COMPENV1(Env), Adv)).main(func' ++ [UC__Rest1.change_pari], in_guard' `|` UC__Rest1.rest_adv_pis) @ &m : res]|
 .
proof.
move => experpre disjguard.
apply (UC__Rest1.composition
Env (UC_SMCReal_Rest1)
(Adv) KeyExchange.RFRP
(KeyExchange.SIMCOMP(Adv))
KeyExchange.IF
_invar_Rest1
_metric_Rest1
KeyExchange._invar_RFRP
KeyExchange._metric_RFRP
KeyExchange._invar_IF
KeyExchange._metric_IF
func' in_guard'
(`|Pr[KeyExchange.DDH1(KeyExchange.DDH_Adv(COMPENV1(Env), Adv)).main(func' ++ [UC__Rest1.change_pari], in_guard' `|` UC__Rest1.rest_adv_pis) @ &m : res] -
  Pr[KeyExchange.DDH2(KeyExchange.DDH_Adv(COMPENV1(Env), Adv)).main(func' ++ [UC__Rest1.change_pari], in_guard' `|` UC__Rest1.rest_adv_pis) @ &m : res]|)
&m).
     
apply _metric_good_Rest1.
apply _init_Rest1.
apply _invoke_Rest1.

apply KeyExchange.RFRP_metric_good.
apply KeyExchange.RFRP_init.
apply KeyExchange.RFRP_invoke.

apply KeyExchange.IF_metric_good.
apply KeyExchange.IF_init.
move => n.
conseq (KeyExchange.IF_invoke n).
smt(mem_oflist mem_rangeset).
trivial.

smt(fsetUC UC__Rest1.union_change_rest_eq_all_adv_pis_of_rf_info disjoint_with_union_implies_disjoint_with_first).
apply (KeyExchange.KeyExchange_RFRP_IF_advantage
    (COMPENV1(Env))
    (Adv)
    (func' ++ [UC__Rest1.change_pari])
  (in_guard' `|` UC__Rest1.rest_adv_pis)
).
    by rewrite exper_pre_ext1.
by apply UC__Rest1.disjoint_in_guard_with_all_implies_disjoint_add_rest_with_change. 
qed.
 


lemma equiv_Composed1_IP_RFIP
(Env <: ENV{-MI, -AllCGs_, -RFIP})
(Adv <: ADV{-MI, -AllCGs_, -Env, -RFIP})
(func' : addr, in_guard' : int fset) &m :
exper_pre func' =>
disjoint in_guard' (adv_pis_rf_info rf_info)  =>
`|Pr[Exper(MI(UC__Rest1.MakeRFComp(UC_SMCReal_Rest1, KeyExchange.IF), Adv), Env).main(func', in_guard') @ &m : res]
- Pr[Exper(MI(RFIP,Adv), Env).main(func', in_guard') @ &m : res]| <= 0.0
.

proof. 
move => exper_pre disjoint.
(*change the goal to equal probabilities in order to apply byequiv*)
have H:
(
`|Pr[Exper(MI(UC__Rest1.MakeRFComp(UC_SMCReal_Rest1, KeyExchange.IF), Adv), Env).main(func', in_guard') @ &m : res]
-
Pr[Exper(MI(RFIP,Adv), Env).main(func', in_guard') @ &m : res]| <= 0.0
)
    <=>
(
Pr[Exper(MI(RFIP,Adv), Env).main(func', in_guard') @ &m : res]
 =
Pr[Exper(MI(UC__Rest1.MakeRFComp(UC_SMCReal_Rest1, KeyExchange.IF), Adv), Env).main(func', in_guard') @ &m : res]
).
smt().

apply H.
clear H.

byequiv => //. 

(*unfold Exper main procedures, put in precondition all up to Adv.init call*)
proc.

 
 (*calling MI.init on both sides results in same memories*)
   seq 1 1 : (={glob Env, func, in_guard,
glob Adv,
glob MI,
glob KeyExchange.IF,
glob UC_SMCReal
}
/\ RFCore.MakeRF.self{1} = UC_Composition.CompGlobs.mrfc_self{2}
/\ UC_SMCReal._self{1} =  UC_Composition.CompGlobs.mrfc_self{2}
).
(*inline all the inits before Adv.init*) 
inline *.
(*all init assignments before Adv.init go into precondition*)
sp.
(*calling Adv.init is similar on both sides*)
sim.
 
(*call Exper.main*)
call (_ : ={
glob Adv,
glob MI,
glob KeyExchange.IF,
glob UC_SMCReal
}
/\ RFCore.MakeRF.self{1} = UC_Composition.CompGlobs.mrfc_self{2}
/\ UC_SMCReal._self{1} =  UC_Composition.CompGlobs.mrfc_self{2}
); last first.
skip. move => />.
 
(*unfold MI.invoke*)
proc.

(*if conditions and else branches are the same on both sides*)
if; last first.
sp. skip. move => />.
move => />.

(*inline MI.loop on both sides*)
inline loop.

(*put all before and after while loop into pre and post conditions*)
sp.
wp.

while (={r0, m, m0, not_done,
glob Adv,
glob MI,
glob KeyExchange.IF,
glob UC_SMCReal
}
/\ RFCore.MakeRF.self{1} = UC_Composition.CompGlobs.mrfc_self{2}
/\ UC_SMCReal._self{1} =  UC_Composition.CompGlobs.mrfc_self{2}); last first.
skip. move => />.

(*if message destination sub-address of MI.func, prove else branch first, they are same*)
if; last first.
sim.
move => />.

(*inline invoke on both sides*)
inline{1} (1) invoke.
inline{2} (1) invoke.
sp.

(*if conditions and else branches are same on both sides*)
if; last first.
sim.
move => />.

(*inline loop on both sides*)
inline loop.
 sp.
 
(*calls after while loop are similar*)
seq 1 1 : (={m,m0,m1,m2,r0,r1,r2,not_done, not_done0,
glob Adv,
glob MI,
glob KeyExchange.IF,
glob UC_SMCReal
}
/\ RFCore.MakeRF.self{1} = UC_Composition.CompGlobs.mrfc_self{2}
/\ UC_SMCReal._self{1} =  UC_Composition.CompGlobs.mrfc_self{2}); last first.
sp.
sim.
 
(*while invariant*)
while (={m,m0,m1,m2,r0,r1,r2,not_done, not_done0,
glob Adv,
glob MI,
glob KeyExchange.IF,
glob UC_SMCReal
}
/\ RFCore.MakeRF.self{1} = UC_Composition.CompGlobs.mrfc_self{2}
/\ UC_SMCReal._self{1} =  UC_Composition.CompGlobs.mrfc_self{2}); last first.
skip. move => />.

(*case when message is for 2. parameter functionality*)
case (UC_Composition.CompGlobs.mrfc_self{2} ++ [UC__Rest1.change_pari] <= m2{2}.`2.`1).
rcondt{2} 1.
move => &m0. skip. move => />.

(*inline real functionality invoke*)
inline{1} (1) invoke.
 sp.
 
(*the message is not for 1. sub-functionality*)
rcondf{1} 1.
move => &m0. skip. move => />. smt(not_le_other_branch).
       
(*message is for 1. parameter functionality*)
rcondt{1} 1.
move => &m0. skip. move => />.

(*the rest is similar*)
sim.
 
(*case when message is NOT for 1. parameter functionality*)
rcondf{2} 1.
move => &m0. skip. move => />.

(*inline both invoke calls*)
inline{1} (1) invoke.
inline{2} (1) invoke.
sp.

(*if message is for 1. sub-functionality*)
if. move => />. sim.
       

(*message is not for 1. parameter functionality*)
rcondf{1} 1.
move => &m0. skip. move => />.

(*the rest is similar*)
sim.
 
qed.  


     lemma exper_RF_RP_IP_Pr_diff
(Env <: ENV{-MI, -AllIFs, -RFRP, -AllCGs_, -SIMIP})
    (Adv <: ADV{-MI, -Env, -AllIFs, -RFRP, -AllCGs_, -SIMIP})
    (func' : addr, in_guard' : int fset) &m :
    exper_pre func' =>
    disjoint in_guard' (adv_pis_rf_info rf_info) =>
  `|Pr[Exper(MI(RFRP,Adv), Env).main(func', in_guard') @ &m : res]
-
    Pr[Exper(MI(RFIP,SIMIP(Adv)), Env).main(func', in_guard') @ &m : res]| <=
 (

`|Pr[KeyExchange.DDH1(KeyExchange.DDH_Adv(COMPENV1(Env), Adv)).main(func' ++ [UC__Rest1.change_pari], in_guard' `|` UC__Rest1.rest_adv_pis) @ &m : res] -
  Pr[KeyExchange.DDH2(KeyExchange.DDH_Adv(COMPENV1(Env), Adv)).main(func' ++ [UC__Rest1.change_pari], in_guard' `|` UC__Rest1.rest_adv_pis) @ &m : res]|
     )
      .
     
proof.
move => exper disj.
apply (
    MakeInt.security_trans
    (RFRP)
    (UC__Rest1.MakeRFComp(UC_SMCReal_Rest1, KeyExchange.RFRP))
    (RFIP)
    (Adv)
    (Adv)
    (SIMIP(Adv))

    Env
    func' in_guard'
    (0.0)
    (`|Pr[KeyExchange.DDH1(KeyExchange.DDH_Adv(COMPENV1(Env), Adv)).main(func' ++ [UC__Rest1.change_pari], in_guard' `|` UC__Rest1.rest_adv_pis) @ &m : res] -
  Pr[KeyExchange.DDH2(KeyExchange.DDH_Adv(COMPENV1(Env), Adv)).main(func' ++ [UC__Rest1.change_pari], in_guard' `|` UC__Rest1.rest_adv_pis) @ &m : res]|)
    &m
). 
 by apply (equiv_UC_SMCReal_RP_Composed1_RP Env (Adv) func' in_guard' &m).

apply (
    MakeInt.security_trans
    (UC__Rest1.MakeRFComp(UC_SMCReal_Rest1, KeyExchange.RFRP))
    (UC__Rest1.MakeRFComp(UC_SMCReal_Rest1, KeyExchange.IF))
    (RFIP)
    (Adv)
    (KeyExchange.SIMCOMP(Adv))
    (SIMIP(Adv))

    Env
    func' in_guard'
    (`|Pr[KeyExchange.DDH1(KeyExchange.DDH_Adv(COMPENV1(Env), Adv)).main(func' ++ [UC__Rest1.change_pari], in_guard' `|` UC__Rest1.rest_adv_pis) @ &m : res] -
  Pr[KeyExchange.DDH2(KeyExchange.DDH_Adv(COMPENV1(Env), Adv)).main(func' ++ [UC__Rest1.change_pari], in_guard' `|` UC__Rest1.rest_adv_pis) @ &m : res]|)
    (0.0)
    &m
). 
 by apply (diff_Composed1_RP_Composed1_IP Env (Adv) func' in_guard' &m).

 by apply (equiv_Composed1_IP_RFIP Env (SIMIP(Adv)) func' in_guard' &m).

qed.  

 


type _state_SIM = [ 
  | _State_SIM_Final
  | _State_SIM_WaitAdv1 of (port) & (port)
  | _State_SIM_WaitAdv2 of (port) & (port) & (exp)
  | _State_SIM_WaitAdv3
  | _State_SIM_WaitReq
  
]. 

module UC_SMCSim = {
  var if_addr_opt : addr option
  var _st : _state_SIM
  proc init() : unit = {
    if_addr_opt <- None; _st <- _State_SIM_WaitReq;
    
  }
  proc _State_SIM_WaitAdv1__SMCReal__KE__KEI2S__ke_sim_rsp (pt1 : port, pt2 : port) : msg option = {
    var q : exp;
    var _r : msg option <- None;
    q <$ dexp;
    _r <- Some
      (KeyExchange.UC_KEI2S.epdp__ke_sim_req2.`enc
      {|
        KeyExchange.UC_KEI2S.ke_sim_req2___func = _addr_KE (oget if_addr_opt);
        KeyExchange.UC_KEI2S.ke_sim_req2___adv = adv;
        
      |});
    _st <- _State_SIM_WaitAdv2 (pt1) (pt2) (q);
    return _r;
  }
  proc _State_SIM_WaitAdv2__SMCReal__KE__KEI2S__ke_sim_rsp (pt1 : port, pt2 : port, q : exp) : msg option = {
    var _r : msg option <- None;
    _r <- Some
      (Forwarding.UC_FwAdv.epdp__fw_obs.`enc
      {|
        Forwarding.UC_FwAdv.fw_obs___func = _addr_Fwd (oget if_addr_opt);
        Forwarding.UC_FwAdv.fw_obs___adv = adv;
        Forwarding.UC_FwAdv.fw_obs__pt1 = _intport_Pt1 (oget if_addr_opt);
        Forwarding.UC_FwAdv.fw_obs__pt2 = _intport_Pt2 (oget if_addr_opt);
        Forwarding.UC_FwAdv.fw_obs__u = epdp_port_port_key_univ.`enc
        (pt1, pt2, g ^ q);
        
      |});
    _st <- _State_SIM_WaitAdv3;
    return _r;
  }
  proc _State_SIM_WaitAdv3__SMCReal__Fwd__FwAdv__fw_ok () : msg option = {
    var _r : msg option <- None;
    _r <- Some
      (UC_SMC2Sim.epdp__sim_rsp.`enc
      {|
        UC_SMC2Sim.sim_rsp___func = (oget if_addr_opt);
        UC_SMC2Sim.sim_rsp___adv = adv;
        
      |});
    _st <- _State_SIM_Final;
    return _r;
  }
  proc _State_SIM_WaitReq__SMC2Sim__sim_req (pt1 : port, pt2 : port) : msg option = {
    var _r : msg option <- None;
    _r <- Some
      (KeyExchange.UC_KEI2S.epdp__ke_sim_req1.`enc
      {|
        KeyExchange.UC_KEI2S.ke_sim_req1___func = _addr_KE (oget if_addr_opt);
        KeyExchange.UC_KEI2S.ke_sim_req1___adv = adv;
        KeyExchange.UC_KEI2S.ke_sim_req1__pt1 = _intport_Pt1
                                                  (oget if_addr_opt);
        KeyExchange.UC_KEI2S.ke_sim_req1__pt2 = _intport_Pt2
                                                  (oget if_addr_opt);
        
      |});
    _st <- _State_SIM_WaitAdv1 (pt1) (pt2);
    return _r;
  }
  proc invoke(_m : msg) : msg option = {
    var _r : msg option <- None;
    if (if_addr_opt = None) {if_addr_opt <- Some _m.`3.`1;}
    match _st with
    | _State_SIM_Final => {
      
    }
    | _State_SIM_WaitAdv1 pt1 pt2 => {
      if ((_m.`3.`1 = adv) /\ (_m.`2.`1 = _addr_KE (oget if_addr_opt)) /\ (KeyExchange.UC_KEI2S.epdp__ke_sim_rsp.`dec _m) <> None)
      {
        _r <@ _State_SIM_WaitAdv1__SMCReal__KE__KEI2S__ke_sim_rsp (pt1, pt2);
      }
      
    }
    | _State_SIM_WaitAdv2 pt1 pt2 q => {
      if ((_m.`3.`1 = adv) /\ (_m.`2.`1 = _addr_KE (oget if_addr_opt)) /\ (KeyExchange.UC_KEI2S.epdp__ke_sim_rsp.`dec _m) <> None)
      {
        _r <@ _State_SIM_WaitAdv2__SMCReal__KE__KEI2S__ke_sim_rsp (pt1, pt2, q);
      }
      
    }
    | _State_SIM_WaitAdv3 => {
      if ((_m.`3.`1 = adv) /\ (_m.`2.`1 = _addr_Fwd (oget if_addr_opt)) /\ (Forwarding.UC_FwAdv.epdp__fw_ok.`dec _m) <> None)
      {
        _r <@ _State_SIM_WaitAdv3__SMCReal__Fwd__FwAdv__fw_ok ();
      }
      
    }
    | _State_SIM_WaitReq => {
      if ((_m.`3.`1 = (oget if_addr_opt)) /\ (_m.`2.`1 = adv) /\ (UC_SMC2Sim.epdp__sim_req.`dec _m) <> None)
      {
        _r <@ _State_SIM_WaitReq__SMC2Sim__sim_req ((oget (UC_SMC2Sim.epdp__sim_req.`dec _m)).`UC_SMC2Sim.sim_req__pt1, (oget (UC_SMC2Sim.epdp__sim_req.`dec _m)).`UC_SMC2Sim.sim_req__pt2);
      }
      
    }
    end;
    return _r;
  }
  
}.


op _invar_UC_SMCSim (g : glob UC_SMCSim) : bool = true.

 

op glob_UC_SMCSim_to__st (g : glob UC_SMCSim) / : _state_SIM = g.`1.
op [smt_opaque] _metric_UC_SMCSim (g : glob UC_SMCSim) : int =
  match glob_UC_SMCSim_to__st g with
  | _State_SIM_Final => 0
  | _State_SIM_WaitAdv1 _ _ => 3
  | _State_SIM_WaitAdv2 _ _ _ => 2
  | _State_SIM_WaitAdv3 => 1
  | _State_SIM_WaitReq => 4
  end.
  


lemma UC_SMCSim_invoke (n : int) : hoare [
  UC_SMCSim.invoke :
  _invar_UC_SMCSim (glob UC_SMCSim) /\ _metric_UC_SMCSim (glob UC_SMCSim) = n
  ==>
  res <> None =>
  _metric_UC_SMCSim (glob UC_SMCSim) < n
   ].
proof. rewrite /_metric_UC_SMCSim /=. proc.
sp 1. (*initializing return value*)
seq 1 : (#pre /\ UC_SMCSim.if_addr_opt <> None). sp 1. auto;smt(). (*if_addr_opt initialized after first message is received*)
inline. match. (*state match*)
(*state branch Final*) skip. move => />;smt(). (*empty state match branch code*)
(*state branch WaitAdv1*) if;last first. (*message guard*)
skip. move => />;smt(). (*message guard failed*)
sp 3. (*state param assignment, return value initialization*)seq 1 : (#pre). rnd. skip. move => />;smt(). (*Sample instruction*)
 sp 1. sp 2. skip. move => />;smt(). (*SendAndTransition instruction*) 
(*state branch WaitAdv2*) if;last first. (*message guard*)
skip. move => />;smt(). (*message guard failed*)
sp 4. (*state param assignment, return value initialization*)sp 1. sp 2. skip. move => />;smt(). (*SendAndTransition instruction*)
 (*state branch WaitAdv3*) if;last first. (*message guard*)
skip. move => />;smt(). (*message guard failed*)
sp 1. (*state param assignment, return value initialization*)sp 1. sp 2. skip. move => />;smt(). (*SendAndTransition instruction*)
 (*state branch WaitReq*) if;last first. (*message guard*)
skip. move => />;smt(). (*message guard failed*)
sp 1. (*state param assignment, return value initialization*)sp 2. (*pattern bindings*)
sp 1. sp 2. skip. move => />;smt(). (*SendAndTransition instruction*)  
qed. 

lemma UC_SMCSim_metric_good (g : glob UC_SMCSim) :
  _invar_UC_SMCSim g => 0 <= _metric_UC_SMCSim g.
  proof. rewrite /_metric_UC_SMCSim /=.   smt(). qed.  
lemma UC_SMCSim_init :
  hoare [UC_SMCSim.init : true ==> _invar_UC_SMCSim (glob UC_SMCSim)].
proof. proc. auto. qed. 
 

clone Simulator as MSCore with
op sim_adv_pi <- _adv_if_pi
proof *.
realize sim_adv_pi_ge1. smt(_adv_pi_begin_gt0). qed.
module SIM(Adv : ADV) = MSCore.MS(UC_SMCSim, Adv).


