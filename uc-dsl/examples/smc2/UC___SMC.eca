op glob_UC_SMCReal_RP_to_own(g : glob UC_SMCReal_RP) / : glob UC_SMCReal =
(g.`1, g.`2, g.`3, g.`4, g.`5).

op glob_UC_SMCReal_RP_to_KeyExchange(g : glob UC_SMCReal_RP) / : glob KeyExchange.RFRP =
(g.`6, g.`7, g.`8, g.`9, g.`10, g.`11, g.`12, g.`13).

