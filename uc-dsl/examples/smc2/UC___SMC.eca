(g.`4, g.`5).

 op [smt_opaque] _metric_RP (g : glob UC_SMCReal_RP) : int =
 KeyExchange._metric_RFRP(glob_UC_SMCReal_RP_to_KeyExchange g)
+_metric_Pt1(glob_UC_SMCReal_to__st_Pt1 (glob_UC_SMCReal_RP_to_own g))
+_metric_Pt2(glob_UC_SMCReal_to__st_Pt2 (glob_UC_SMCReal_RP_to_own g))
+Forwarding._metric_IF(glob_UC_SMCReal_to_Fwd (glob_UC_SMCReal_RP_to_own g))
.

lemma _invoke_RP (n : int)  : hoare [
  UC_SMCReal_RP.invoke :
  _metric_RP (glob UC_SMCReal_RP) = n
  ==>
  (res <> None =>
  _metric_RP (glob UC_SMCReal_RP) < n
/\ ((oget res).`1 = Adv => (oget res).`2.`2 \in  adv_pis_rf_info rf_info))].
proof.
rewrite /_metric_RP /=.
  proc.
  sp 1.
  if.
  exlim (Forwarding._metric_IF(glob_UC_SMCReal_to_Fwd(glob_UC_SMCReal_RP_to_own(glob UC_SMCReal_RP)))) => _sub_metric.
  call (Forwarding.IF_invoke _sub_metric ).
  skip.
  smt(mem_adv_pis_rf_info mem_oflist).
  if.
  exlim (KeyExchange._metric_RFRP(glob_UC_SMCReal_RP_to_KeyExchange((glob UC_SMCReal_RP)))) => _sub_metric.
  call (KeyExchange.RFRP_invoke _sub_metric ).
  skip.
  smt(mem_adv_pis_rf_info mem_oflist).
  if.
  exlim (_metric_Pt1(glob_UC_SMCReal_to__st_Pt1(glob_UC_SMCReal_RP_to_own(glob UC_SMCReal_RP)))) => _sub_metric.
  call (_invoke_Pt1 _sub_metric  KeyExchange.RFRP).
  skip.
  smt().
  if.
  exlim (_metric_Pt2(glob_UC_SMCReal_to__st_Pt2(glob_UC_SMCReal_RP_to_own(glob UC_SMCReal_RP)))) => _sub_metric.
  call (_invoke_Pt2 _sub_metric  KeyExchange.RFRP).
  skip.
  smt().
  skip.
  smt().
qed.

 op _invar_RP (g : glob UC_SMCReal_RP) : bool =
  KeyExchange._invar_RFRP(glob_UC_SMCReal_RP_to_KeyExchange g)
/\_invar_Pt1(glob_UC_SMCReal_to__st_Pt1 (glob_UC_SMCReal_RP_to_own g))
/\_invar_Pt2(glob_UC_SMCReal_to__st_Pt2 (glob_UC_SMCReal_RP_to_own g))
/\Forwarding._invar_IF(glob_UC_SMCReal_to_Fwd (glob_UC_SMCReal_RP_to_own g))
.

lemma _metric_good_RP (g : glob UC_SMCReal_RP) :
_invar_RP g => 0 <= _metric_RP g.
proof.
rewrite /_metric_RP /=.
rewrite /_invar_RP /=.
smt(
KeyExchange.RFRP_metric_good
Forwarding.IF_metric_good
_metric_Pt1_good
_metric_Pt2_good
).
qed.

