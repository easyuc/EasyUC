module UC_SMCReal_Rest1  : FUNC = {
  proc init(self_ : addr) : unit = {
    UC_SMCReal._self <- self_;
  Forwarding.IF.init(_addr_Fwd UC_SMCReal._self);
  UC_SMCReal._st_Pt1 <- _State_Pt1_WaitReq;
  UC_SMCReal._st_Pt2 <- _State_Pt2_WaitKE1;
  }
  proc _State_Pt1_WaitKE2__KE__Pt1__ke_rsp2 (pt1 : port, pt2 : port, t : text, k : KeyExchange.key) : msg option = {
    var _r : msg option <- None;
    _r <- Some
      (Forwarding.UC_FwDir.D.epdp__fw_req.`enc
      {|
        Forwarding.UC_FwDir.D.fw_req___func = _addr_Fwd UC_SMCReal._self;
        Forwarding.UC_FwDir.D.fw_req__pt1 = _intport_Pt1 UC_SMCReal._self;
        Forwarding.UC_FwDir.D.fw_req__pt2 = _intport_Pt2 UC_SMCReal._self;
        Forwarding.UC_FwDir.D.fw_req__u = epdp_port_port_key_univ.`enc
        (pt1, pt2, epdp_text_key.`enc t ^^ k);
        
      |});
    UC_SMCReal._st_Pt1 <- _State_Pt1_Final;
    return _r;
  }
  proc _State_Pt1_WaitReq__SMCDir__Pt1__smc_req (pt1 : port, pt2 : port, t : text) : msg option = {
    var _r : msg option <- None;
    if (envport UC_SMCReal._self pt2) {
      _r <- Some
        (KeyExchange.UC_KEDir.Pt1.epdp__ke_req1.`enc
        {|
          KeyExchange.UC_KEDir.Pt1.ke_req1___func = _addr_KE UC_SMCReal._self;
          KeyExchange.UC_KEDir.Pt1.ke_req1__pt1 = _intport_Pt1 UC_SMCReal._self;
          KeyExchange.UC_KEDir.Pt1.ke_req1__pt2 = _intport_Pt2
                                                    UC_SMCReal._self;
          
        |});
      UC_SMCReal._st_Pt1 <- _State_Pt1_WaitKE2 (pt1) (pt2) (t);
      
    }
    else {
      _r <- None;
      
    }
    return _r;
  }
  proc party_Pt1(_m : msg) : msg option = {
    var _r : msg option <- None;
    match UC_SMCReal._st_Pt1 with
    | _State_Pt1_Final => {
      
    }
    | _State_Pt1_WaitKE2 pt1 pt2 t => {
      match KeyExchange.UC_KEDir.Pt1.epdp__ke_rsp2.`dec _m with
      | Some _x => {
        if (_m.`3.`1 = _addr_KE UC_SMCReal._self){
          _r <@ _State_Pt1_WaitKE2__KE__Pt1__ke_rsp2 (pt1, pt2, t, _x.`KeyExchange.UC_KEDir.Pt1.ke_rsp2__k);
        }
        
      }
      | None => {
        
      }
      end;
    }
    | _State_Pt1_WaitReq => {
      match UC_SMCDir.Pt1.epdp__smc_req.`dec _m with
      | Some _x => {
        _r <@ _State_Pt1_WaitReq__SMCDir__Pt1__smc_req (_x.`UC_SMCDir.Pt1.smc_req__pt1, _x.`UC_SMCDir.Pt1.smc_req__pt2, _x.`UC_SMCDir.Pt1.smc_req__t);
      }
      | None => {
        
      }
      end;
    }
    end;
    return _r;
  }
  proc _State_Pt2_WaitFwd__Fwd__D__fw_rsp (k : key, u : univ) : msg option = {
    var pt1 : port;
    var pt2 : port;
    var x : key;
    var _r : msg option <- None;
    match (epdp_port_port_key_univ.`dec u) with
    | None<:(int list * int) * (int list * int) * key> => {
    
      _r <- None;
      
    }
    | Some tr => {
    
      (pt1, pt2, x) <- tr;
      match (epdp_text_key.`dec (x ^^ kinv k)) with
      | None<:text> => {
      
        _r <- None;
        
      }
      | Some t => {
      
        _r <- Some
          (UC_SMCDir.Pt2.epdp__smc_rsp.`enc
          {|
            UC_SMCDir.Pt2.smc_rsp___func = UC_SMCReal._self;
            UC_SMCDir.Pt2.smc_rsp__pt2 = pt2;
            UC_SMCDir.Pt2.smc_rsp__pt1 = pt1;
            UC_SMCDir.Pt2.smc_rsp__t = t;
            
          |});
        UC_SMCReal._st_Pt2 <- _State_Pt2_Final;
        
      }
      end;
    
    }
    end;
return _r; }
proc _State_Pt2_WaitKE1__KE__Pt2__ke_rsp1 (k : KeyExchange.key) : msg option = {
  var _r : msg option <- None;
  _r <- Some
    (KeyExchange.UC_KEDir.Pt2.epdp__ke_req2.`enc
    {|
      KeyExchange.UC_KEDir.Pt2.ke_req2___func = _addr_KE UC_SMCReal._self;
      KeyExchange.UC_KEDir.Pt2.ke_req2__pt2 = _intport_Pt2 UC_SMCReal._self;
      
    |});
  UC_SMCReal._st_Pt2 <- _State_Pt2_WaitFwd (k);
  return _r; } proc party_Pt2(_m : msg) : msg option = {
  var _r : msg option <- None;
  match UC_SMCReal._st_Pt2 with
  | _State_Pt2_Final => {
    
  }
  | _State_Pt2_WaitFwd k => {
    match Forwarding.UC_FwDir.D.epdp__fw_rsp.`dec _m with
    | Some _x => {
      if (_m.`3.`1 = _addr_Fwd UC_SMCReal._self){
        _r <@ _State_Pt2_WaitFwd__Fwd__D__fw_rsp (k, _x.`Forwarding.UC_FwDir.D.fw_rsp__u);
      }
      
    }
    | None => {
      
    }
    end;
  }
  | _State_Pt2_WaitKE1 => {
    match KeyExchange.UC_KEDir.Pt2.epdp__ke_rsp1.`dec _m with
    | Some _x => {
      if (_m.`3.`1 = _addr_KE UC_SMCReal._self){
        _r <@ _State_Pt2_WaitKE1__KE__Pt2__ke_rsp1 (_x.`KeyExchange.UC_KEDir.Pt2.ke_rsp1__k);
      }
      
    }
    | None => {
      
    }
    end;
  }
  end;
  return _r; } proc invoke(m : msg) : msg option = {
  var r : msg option <- None;
  if (_addr_Fwd UC_SMCReal._self <= m.`2.`1) {r <@ Forwarding.IF.invoke(m);}
  else {
  if((m.`1 = Dir /\ m.`2 = _extport_dir_Pt1 UC_SMCReal._self /\
     envport UC_SMCReal._self m.`3)
  \/
  (m.`1 = Dir /\ m.`2 = _intport_Pt1 UC_SMCReal._self /\
  UC_SMCReal._self < m.`3.`1))
  {r <@ party_Pt1(m);}
  else {
  if((m.`1 = Dir /\ m.`2 = _extport_dir_Pt2 UC_SMCReal._self /\
     envport UC_SMCReal._self m.`3)
  \/
  (m.`1 = Dir /\ m.`2 = _intport_Pt2 UC_SMCReal._self /\
  UC_SMCReal._self < m.`3.`1))
  {r <@ party_Pt2(m);}
  }
  }
  return r;
  }
  
}. 

clone UC_Composition.Composition as UC__Rest1 with
op change_pari = 1,
op rf_info <- rf_info
proof *.
realize rf_info_valid. smt(_adv_pi_begin_gt0). qed.
realize change_pari_valid. smt(). qed.


lemma _invoke_Pt2_Rest1 (n : int)  : hoare [
  UC_SMCReal_Rest1.party_Pt2 :
  _metric_Pt2 (glob_UC_SMCReal_to__st_Pt2(glob UC_SMCReal)) = n ==>
  (res <> None =>
  _metric_Pt2 (glob_UC_SMCReal_to__st_Pt2(glob UC_SMCReal)) < n
   /\ ((oget res).`1 = Adv => (oget res).`2.`2 \in  UC__Rest1.rest_adv_pis))
]. proof. rewrite /_metric_Pt2 /=. proc. inline. (*inline procedure calls*)
 sp 1. (*initializing input, return value*) match. (*state match*)
(*state branch Final*)  skip. move => />;smt(). (*empty state match branch code*)
(*state branch WaitFwd*) match. (*message match*)
 skip. move => />;smt(). (*None branch of message match, dec failed*)
if. (*address check for internal messages*)
sp 2. (*state param assignment, return value initialization*)sp 1. (*pattern bindings*)
match. (*match instruction with 2 branches*)
(*branch None*)  sp 2. skip. move => />;smt(). (*Fail instruction*)  
(*branch Some*) sp 1. (*Assign instruction*) 
match. (*match instruction with 2 branches*)
(*branch None*)  sp 2. skip. move => />;smt(). (*Fail instruction*)  
(*branch Some*)
 sp 3. skip. move => />;smt(mem_oflist mem_rangeset in_fsetU). (*SendAndTransition instruction*)
      skip. move => />;smt(). (*address check for internal messages failed case*)
(*state branch WaitKE1*) match. (*message match*)
 skip. move => />;smt(). (*None branch of message match, dec failed*)
if. (*address check for internal messages*)
sp 1. (*state param assignment, return value initialization*)sp 1. (*pattern bindings*)
 sp 3. skip. move => />;smt(mem_oflist mem_rangeset in_fsetU). (*SendAndTransition instruction*)
  skip. move => />;smt(). (*address check for internal messages failed case*)
qed. 

lemma _invoke_Pt1_Rest1 (n : int)  : hoare [
  UC_SMCReal_Rest1.party_Pt1 :
  _metric_Pt1 (glob_UC_SMCReal_to__st_Pt1(glob UC_SMCReal)) = n ==>
  (res <> None =>
  _metric_Pt1 (glob_UC_SMCReal_to__st_Pt1(glob UC_SMCReal)) < n
   /\ ((oget res).`1 = Adv => (oget res).`2.`2 \in  UC__Rest1.rest_adv_pis))
]. proof. rewrite /_metric_Pt1 /=. proc. inline. (*inline procedure calls*)
 sp 1. (*initializing input, return value*) match. (*state match*)
(*state branch Final*)  skip. move => />;smt(). (*empty state match branch code*)
(*state branch WaitKE2*) match. (*message match*)
 skip. move => />;smt(). (*None branch of message match, dec failed*)
if. (*address check for internal messages*)
sp 4. (*state param assignment, return value initialization*)sp 1. (*pattern bindings*)
 sp 3. skip. move => />;smt(mem_oflist mem_rangeset in_fsetU). (*SendAndTransition instruction*)
  skip. move => />;smt(). (*address check for internal messages failed case*)
(*state branch WaitReq*) match. (*message match*)
 skip. move => />;smt(). (*None branch of message match, dec failed*)
sp 1. (*state param assignment, return value initialization*)sp 3. (*pattern bindings*)
if. (*if instruction*)
 sp 3. skip. move => />;smt(mem_oflist mem_rangeset in_fsetU). (*SendAndTransition instruction*)
  sp 2. skip. move => />;smt(). (*Fail instruction*)   qed. 

op glob_UC_SMCReal_Rest1_to_own(g : glob UC_SMCReal_Rest1) / : glob UC_SMCReal =
(g.`1, g.`2, g.`3, g.`4, g.`5).

 op [smt_opaque] _metric_Rest1 (g : glob UC_SMCReal_Rest1) : int =
 _metric_Pt1(glob_UC_SMCReal_to__st_Pt1 (glob_UC_SMCReal_Rest1_to_own g))
+_metric_Pt2(glob_UC_SMCReal_to__st_Pt2 (glob_UC_SMCReal_Rest1_to_own g))
+Forwarding._metric_IF(glob_UC_SMCReal_to_Fwd (glob_UC_SMCReal_Rest1_to_own g))
.

lemma _invoke_Rest1 (n : int)  : hoare [
  UC_SMCReal_Rest1.invoke :
  _metric_Rest1 (glob UC_SMCReal_Rest1) = n
  ==>
  (res <> None =>
  _metric_Rest1 (glob UC_SMCReal_Rest1) < n
/\ ((oget res).`1 = Adv => (oget res).`2.`2 \in  UC__Rest1.rest_adv_pis))].
proof.
rewrite /_metric_Rest1 /=.
  proc.
  sp 1.
  if.
  exlim (Forwarding._metric_IF(glob_UC_SMCReal_to_Fwd(glob_UC_SMCReal_Rest1_to_own(glob UC_SMCReal_Rest1)))) => _sub_metric.
  call (Forwarding.IF_invoke _sub_metric ).
  skip.
  smt(UC__Rest1.in_rest_adv_pis_by_main mem_oflist).
  if.
  exlim (_metric_Pt1(glob_UC_SMCReal_to__st_Pt1(glob_UC_SMCReal_Rest1_to_own(glob UC_SMCReal_Rest1)))) => _sub_metric.
  call (_invoke_Pt1_Rest1 _sub_metric ).
  skip.
  smt().
  if.
  exlim (_metric_Pt2(glob_UC_SMCReal_to__st_Pt2(glob_UC_SMCReal_Rest1_to_own(glob UC_SMCReal_Rest1)))) => _sub_metric.
  call (_invoke_Pt2_Rest1 _sub_metric ).
  skip.
  smt().
  skip.
  smt().
qed.

 op _invar_Rest1 (g : glob UC_SMCReal_Rest1) : bool =
  _invar_Pt1(glob_UC_SMCReal_to__st_Pt1 (glob_UC_SMCReal_Rest1_to_own g))
/\_invar_Pt2(glob_UC_SMCReal_to__st_Pt2 (glob_UC_SMCReal_Rest1_to_own g))
/\Forwarding._invar_IF(glob_UC_SMCReal_to_Fwd (glob_UC_SMCReal_Rest1_to_own g))
.

lemma _metric_good_Rest1 (g : glob UC_SMCReal_Rest1) :
_invar_Rest1 g => 0 <= _metric_Rest1 g.
proof.
rewrite /_metric_Rest1 /=.
rewrite /_invar_Rest1 /=.
smt(
Forwarding.IF_metric_good
_metric_Pt1_good
_metric_Pt2_good
).
qed.

lemma _init_Rest1 :
hoare [ UC_SMCReal_Rest1.init : true ==> _invar_Rest1 (glob UC_SMCReal_Rest1)].
proof. proc. sp. wp.
call (Forwarding.IF_init).
skip.
rewrite /_invar_Rest1 /=.
smt().
qed.

 
(*abbreviation for 1. composed environment*)
