clone UC_SMC2IF_to_Sim_abs as UC_SMC2IF_to_Sim with
  op pi = 1
proof *.

type _state_IF = [ 
  | _State_IF_Final
  | _State_IF_WaitReq1
  | _State_IF_WaitReq2 of (port) & (port)
  | _State_IF_WaitSim1 of (port) & (port) & (text1)
  | _State_IF_WaitSim2 of (port) & (text2)
  
]. 

module UC_SMC2Ideal : FUNC= {
  var _self : addr
  var _st : _state_IF
  proc init(self_ : addr) : unit = {
    _self <- self_; _st <- _State_IF_WaitReq1;
  }
  proc _State_IF_WaitReq1__SMC2Dir__Pt1__smc_req (pt1 : port, pt2 : port, t : text1) : msg option = {
    var _r : msg option <- None;
    if (envport _self pt2) {
      _r <- Some
        (UC_SMC2IF_to_Sim.epdp__sim_req1.`enc
        {|
          UC_SMC2IF_to_Sim.sim_req1___func = _self;
          UC_SMC2IF_to_Sim.sim_req1___adv = adv;
          UC_SMC2IF_to_Sim.sim_req1__pt1 = pt1;
          UC_SMC2IF_to_Sim.sim_req1__pt2 = pt2;
          
        |});
      _st <- _State_IF_WaitSim1 (pt1) (pt2) (t);
      
    }
    else {
      _r <- None;
      
    }
    return _r;
  }
  proc _State_IF_WaitReq2__SMC2Dir__Pt2__smc_req (pt1 : port, pt2 : port, pt2' : port, t : text2) : msg option = {
    var _r : msg option <- None;
    if (pt2' = pt2) {
      _r <- Some
        (UC_SMC2IF_to_Sim.epdp__sim_req2.`enc
        {|
          UC_SMC2IF_to_Sim.sim_req2___func = _self;
          UC_SMC2IF_to_Sim.sim_req2___adv = adv;
          
        |});
      _st <- _State_IF_WaitSim2 (pt1) (t);
      
    }
    else {
      _r <- None;
      
    }
    return _r;
  }
  proc _State_IF_WaitSim1__SMC2IF_to_Sim__sim_rsp (pt1 : port, pt2 : port, t : text1) : msg option = {
    var _r : msg option <- None;
    _r <- Some
      (UC_SMC2Dir.Pt2.epdp__smc_rsp.`enc
      {|
        UC_SMC2Dir.Pt2.smc_rsp___func = _self;
        UC_SMC2Dir.Pt2.smc_rsp__pt2 = pt2;
        UC_SMC2Dir.Pt2.smc_rsp__pt1 = pt1;
        UC_SMC2Dir.Pt2.smc_rsp__t = t;
        
      |});
    _st <- _State_IF_WaitReq2 (pt1) (pt2);
    return _r;
  }
  proc _State_IF_WaitSim2__SMC2IF_to_Sim__sim_rsp (pt1 : port, t : text2) : msg option = {
    var _r : msg option <- None;
    _r <- Some
      (UC_SMC2Dir.Pt1.epdp__smc_rsp.`enc
      {|
        UC_SMC2Dir.Pt1.smc_rsp___func = _self;
        UC_SMC2Dir.Pt1.smc_rsp__pt1 = pt1;
        UC_SMC2Dir.Pt1.smc_rsp__t = t;
        
      |});
    _st <- _State_IF_Final;
    return _r;
  }
  proc parties(_m : msg) : msg option = {
    var _r : msg option <- None;
    match _st with
    | _State_IF_Final => {
      
    }
    | _State_IF_WaitReq1 => {
      match UC_SMC2Dir.Pt1.epdp__smc_req.`dec _m with
      | Some _x => {
        _r <@ _State_IF_WaitReq1__SMC2Dir__Pt1__smc_req (_x.`UC_SMC2Dir.Pt1.smc_req__pt1, _x.`UC_SMC2Dir.Pt1.smc_req__pt2, _x.`UC_SMC2Dir.Pt1.smc_req__t);
      }
      | None => {
        
      }
      end;
    }
    | _State_IF_WaitReq2 pt1 pt2 => {
      match UC_SMC2Dir.Pt2.epdp__smc_req.`dec _m with
      | Some _x => {
        _r <@ _State_IF_WaitReq2__SMC2Dir__Pt2__smc_req (pt1, pt2, _x.`UC_SMC2Dir.Pt2.smc_req__pt2, _x.`UC_SMC2Dir.Pt2.smc_req__t);
      }
      | None => {
        
      }
      end;
    }
    | _State_IF_WaitSim1 pt1 pt2 t => {
      match UC_SMC2IF_to_Sim.epdp__sim_rsp.`dec _m with
      | Some _x => {
        _r <@ _State_IF_WaitSim1__SMC2IF_to_Sim__sim_rsp (pt1, pt2, t);
      }
      | None => {
        
      }
      end;
    }
    | _State_IF_WaitSim2 pt1 t => {
      match UC_SMC2IF_to_Sim.epdp__sim_rsp.`dec _m with
      | Some _x => {
        _r <@ _State_IF_WaitSim2__SMC2IF_to_Sim__sim_rsp (pt1, t);
      }
      | None => {
        
      }
      end;
    }
    end;
    return _r;
  }
  proc invoke(m : msg) : msg option = {
    var r : msg option <- None;
    if ((m.`1 = Dir /\ m.`2.`1 = _self /\ envport _self m.`3)\/ (m.`1 = Adv
                                                               /\
                                                               m.`2.`1 = _self
                                                               /\
                                                               m.`3.`1 = adv)){
      r <@ parties(m);
    }
  return r;
  }
  
}.


(*alias*)
module IF = UC_SMC2Ideal.
op _invar_IF (g : glob IF) : bool = true.

 

op glob_UC_SMC2Ideal_to__st (g : glob UC_SMC2Ideal) / : _state_IF = g.`2.
op [smt_opaque] _metric_IF (g : glob UC_SMC2Ideal) : int =
  match glob_UC_SMC2Ideal_to__st g with
  | _State_IF_Final => 0
  | _State_IF_WaitReq1 => 4
  | _State_IF_WaitReq2 _ _ => 2
  | _State_IF_WaitSim1 _ _ _ => 3
  | _State_IF_WaitSim2 _ _ => 1
  end.
  


lemma IF_invoke (n : int) : hoare [
  UC_SMC2Ideal.invoke :
  _invar_IF (glob UC_SMC2Ideal) /\ _metric_IF (glob UC_SMC2Ideal) = n
  ==>
  _invar_IF (glob UC_SMC2Ideal) /\ 
  (res <> None =>
  _metric_IF (glob UC_SMC2Ideal) < n
  /\ ((oget res).`1 = Adv => (oget res).`2.`2 \in oflist [_adv_if_pi] /\ (oget res).`3.`2 = 1))
   ].
proof. rewrite /_metric_IF /=. proc. sp 1. (*initializing return value*)
if. (*invoke guard*) inline. sp 1. sp 1. (*initializing input, return value*)
match. (*state match*)
(*state branch Final*) sp 1. skip. move => />;smt(). (*empty state match branch code*)
(*state branch WaitReq1*) match. (*message match*)
sp 1. skip. move => />;smt(). (*None branch of message match, dec failed*)
sp 1. (*state param assignment, return value initialization*)sp 3. (*pattern bindings*)
if. (*if instruction*)
sp 1. sp 3. skip. move => />;smt(mem_oflist mem_rangeset in_fsetU). (*SendAndTransition instruction*)
 sp 1. sp 2. skip. move => />;smt(). (*Fail instruction*)  
(*state branch WaitReq2*) match. (*message match*)
sp 1. skip. move => />;smt(). (*None branch of message match, dec failed*)
sp 3. (*state param assignment, return value initialization*)sp 2. (*pattern bindings*)
if. (*if instruction*)
sp 1. sp 3. skip. move => />;smt(mem_oflist mem_rangeset in_fsetU). (*SendAndTransition instruction*)
 sp 1. sp 2. skip. move => />;smt(). (*Fail instruction*)  
(*state branch WaitSim1*) match. (*message match*)
sp 1. skip. move => />;smt(). (*None branch of message match, dec failed*)
sp 4. (*state param assignment, return value initialization*)sp 1. sp 3. skip. move => />;smt(mem_oflist mem_rangeset in_fsetU). (*SendAndTransition instruction*)
 (*state branch WaitSim2*) match. (*message match*)
sp 1. skip. move => />;smt(). (*None branch of message match, dec failed*)
sp 3. (*state param assignment, return value initialization*)sp 1. sp 3. skip. move => />;smt(mem_oflist mem_rangeset in_fsetU). (*SendAndTransition instruction*)
 skip. smt(). (*invoke guard false*) qed. 

lemma IF_metric_good (g : glob IF) :   _invar_IF g => 0 <= _metric_IF g.
  proof. rewrite /_metric_IF /=.   smt(). qed.   lemma IF_init :
  hoare [IF.init : true ==> _invar_IF (glob IF)]. proof. proc. auto. qed. 
 


op rf_info = {| rfi_num_parties = 2; rfi_num_subfuns = 2; rfi_num_params = 2;
rfi_adv_pi_begin = _adv_pi_begin;
rfi_adv_pi_main_end = _adv_pi_begin + _adv_pi_num - 1 - SMC1._adv_pi_num - SMC2._adv_pi_num;
rfi_adv_pi_begin_params = [_adv_pi_begin_UC_SMC1; _adv_pi_begin_UC_SMC2];
rfi_adv_pi_end_params = [_adv_pi_begin_UC_SMC1 + SMC1._adv_pi_num - 1; _adv_pi_begin_UC_SMC2 + SMC2._adv_pi_num - 1];
|}. 

op _addr_SMC1 (self : addr) : addr = self ++ [1].
op _addr_SMC2 (self : addr) : addr = self ++ [2].

op _addr_Fwd1 (self : addr) : addr = self ++ [3].
op _addr_Fwd2 (self : addr) : addr = self ++ [4].

op _extport_dir_Pt1 (self : addr) : port = (self, 1).
op _extport_dir_Pt2 (self : addr) : port = (self, 2).


op _intport_Pt1 (self : addr) : port = (self, 1).
op _intport_Pt2 (self : addr) : port = (self, 2).
 

type _state_Pt1 = [ 
  | _State_Pt1_Final
  | _State_Pt1_WaitFwd2 of (port) & (text1)
  | _State_Pt1_WaitReq
  | _State_Pt1_WaitSMC2 of (port)
  
].
type _state_Pt2 = [ 
  | _State_Pt2_Final
  | _State_Pt2_WaitFwd1
  | _State_Pt2_WaitReq of (port)
  | _State_Pt2_WaitSMC1 of (port) & (port)
  
].


module UC_SMC2Real (SMC1__ : FUNC, SMC2__ : FUNC) : FUNC = {
  var _self : addr
  var _st_Pt1 : _state_Pt1
  var _st_Pt2 : _state_Pt2
  
  proc init(self_ : addr) : unit = {
    _self <- self_;
  Forwarding1.IF.init(_addr_Fwd1 _self);
  Forwarding2.IF.init(_addr_Fwd2 _self);
  SMC1__.init(_addr_SMC1 _self);
  SMC2__.init(_addr_SMC2 _self);
  _st_Pt1 <- _State_Pt1_WaitReq;
  _st_Pt2 <- _State_Pt2_WaitFwd1;
  }
  proc _State_Pt1_WaitFwd2__Fwd2__D__fw_rsp (pt1 : port, t : text1) : msg option = {
    var _r : msg option <- None;
    _r <- Some
      (SMC1.UC_SMCDir.Pt1.epdp__smc_req.`enc
      {|
        SMC1.UC_SMCDir.Pt1.smc_req___func = _addr_SMC1 _self;
        SMC1.UC_SMCDir.Pt1.smc_req__pt1 = _intport_Pt1 _self;
        SMC1.UC_SMCDir.Pt1.smc_req__pt2 = _intport_Pt2 _self;
        SMC1.UC_SMCDir.Pt1.smc_req__t = t;
        
      |});
    _st_Pt1 <- _State_Pt1_WaitSMC2 (pt1);
    return _r;
  }
  proc _State_Pt1_WaitReq__SMC2Dir__Pt1__smc_req (pt1 : port, pt2 : port, t : text1) : msg option = {
    var _r : msg option <- None;
    if (envport _self pt2) {
      _r <- Some
        (Forwarding1.UC_FwDir.D.epdp__fw_req.`enc
        {|
          Forwarding1.UC_FwDir.D.fw_req___func = _addr_Fwd1 _self;
          Forwarding1.UC_FwDir.D.fw_req__pt1 = _intport_Pt1 _self;
          Forwarding1.UC_FwDir.D.fw_req__pt2 = _intport_Pt2 _self;
          Forwarding1.UC_FwDir.D.fw_req__u = epdp_port_port_univ.`enc
          (pt1, pt2);
          
        |});
      _st_Pt1 <- _State_Pt1_WaitFwd2 (pt1) (t);
      
    }
    else {
      _r <- None;
      
    }
    return _r;
  }
  proc _State_Pt1_WaitSMC2__SMC2__Pt2__smc_rsp (pt1 : port, t : SMC2.text) : msg option = {
    var _r : msg option <- None;
    _r <- Some
      (UC_SMC2Dir.Pt1.epdp__smc_rsp.`enc
      {|
        UC_SMC2Dir.Pt1.smc_rsp___func = _self;
        UC_SMC2Dir.Pt1.smc_rsp__pt1 = pt1;
        UC_SMC2Dir.Pt1.smc_rsp__t = t;
        
      |});
    _st_Pt1 <- _State_Pt1_Final;
    return _r;
  }
  proc party_Pt1(_m : msg) : msg option = {
    var _r : msg option <- None;
    match _st_Pt1 with
    | _State_Pt1_Final => {
      
    }
    | _State_Pt1_WaitFwd2 pt1 t => {
      match Forwarding2.UC_FwDir.D.epdp__fw_rsp.`dec _m with
      | Some _x => {
        if (_m.`3.`1 = _addr_Fwd2 _self){
          _r <@ _State_Pt1_WaitFwd2__Fwd2__D__fw_rsp (pt1, t);
        }
        
      }
      | None => {
        
      }
      end;
    }
    | _State_Pt1_WaitReq => {
      match UC_SMC2Dir.Pt1.epdp__smc_req.`dec _m with
      | Some _x => {
        _r <@ _State_Pt1_WaitReq__SMC2Dir__Pt1__smc_req (_x.`UC_SMC2Dir.Pt1.smc_req__pt1, _x.`UC_SMC2Dir.Pt1.smc_req__pt2, _x.`UC_SMC2Dir.Pt1.smc_req__t);
      }
      | None => {
        
      }
      end;
    }
    | _State_Pt1_WaitSMC2 pt1 => {
      match SMC2.UC_SMCDir.Pt2.epdp__smc_rsp.`dec _m with
      | Some _x => {
        if (_m.`3.`1 = _addr_SMC2 _self){
          _r <@ _State_Pt1_WaitSMC2__SMC2__Pt2__smc_rsp (pt1, _x.`SMC2.UC_SMCDir.Pt2.smc_rsp__t);
        }
        
      }
      | None => {
        
      }
      end;
    }
    end;
    return _r;
  }
  proc _State_Pt2_WaitFwd1__Fwd1__D__fw_rsp (u : univ) : msg option = {
    var pt1 : port;
    var pt2 : port;
    var _r : msg option <- None;
    (pt1, pt2) <- oget (epdp_port_port_univ.`dec u);
    _r <- Some
      (Forwarding2.UC_FwDir.D.epdp__fw_req.`enc
      {|
        Forwarding2.UC_FwDir.D.fw_req___func = _addr_Fwd2 _self;
        Forwarding2.UC_FwDir.D.fw_req__pt1 = _intport_Pt2 _self;
        Forwarding2.UC_FwDir.D.fw_req__pt2 = _intport_Pt1 _self;
        Forwarding2.UC_FwDir.D.fw_req__u = [];
        
      |});
    _st_Pt2 <- _State_Pt2_WaitSMC1 (pt1) (pt2);
    return _r;
  }
  proc _State_Pt2_WaitReq__SMC2Dir__Pt2__smc_req (pt2 : port, pt2' : port, t : text2) : msg option = {
    var _r : msg option <- None;
    if (pt2' = pt2) {
      _r <- Some
        (SMC2.UC_SMCDir.Pt1.epdp__smc_req.`enc
        {|
          SMC2.UC_SMCDir.Pt1.smc_req___func = _addr_SMC2 _self;
          SMC2.UC_SMCDir.Pt1.smc_req__pt1 = _intport_Pt2 _self;
          SMC2.UC_SMCDir.Pt1.smc_req__pt2 = _intport_Pt1 _self;
          SMC2.UC_SMCDir.Pt1.smc_req__t = t;
          
        |});
      _st_Pt2 <- _State_Pt2_Final;
      
    }
    else {
      _r <- None;
      
    }
    return _r;
  }
  proc _State_Pt2_WaitSMC1__SMC1__Pt2__smc_rsp (pt1 : port, pt2 : port, t : SMC1.text) : msg option = {
    var _r : msg option <- None;
    _r <- Some
      (UC_SMC2Dir.Pt2.epdp__smc_rsp.`enc
      {|
        UC_SMC2Dir.Pt2.smc_rsp___func = _self;
        UC_SMC2Dir.Pt2.smc_rsp__pt2 = pt2;
        UC_SMC2Dir.Pt2.smc_rsp__pt1 = pt1;
        UC_SMC2Dir.Pt2.smc_rsp__t = t;
        
      |});
    _st_Pt2 <- _State_Pt2_WaitReq (pt2);
    return _r;
  }
  proc party_Pt2(_m : msg) : msg option = {
    var _r : msg option <- None;
    match _st_Pt2 with
    | _State_Pt2_Final => {
      
    }
    | _State_Pt2_WaitFwd1 => {
      match Forwarding1.UC_FwDir.D.epdp__fw_rsp.`dec _m with
      | Some _x => {
        if (_m.`3.`1 = _addr_Fwd1 _self){
          _r <@ _State_Pt2_WaitFwd1__Fwd1__D__fw_rsp (_x.`Forwarding1.UC_FwDir.D.fw_rsp__u);
        }
        
      }
      | None => {
        
      }
      end;
