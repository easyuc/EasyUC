       (*if conditions are the same on both sides, and else branches are similar*)
if; last first.
(*both sides are similar*)
sim
/
(UC_Composition.CompGlobs.mrfc_self{1} = UC_SMC2Real._self{1}
/\ UC_Composition.CompGlobs.mrfc_self{2} = UC_SMC2Real._self{2})
:
(={r0, m, m0, not_done,
glob Adv,
glob MI,
glob SMC1.IF,
glob SMC2.RFRP,
glob UC_SMC2Real
}).

       
move => />.

       (*after_func is similar on both sides*)
seq 1 1 : (={r0, m, m0, not_done,
glob Adv,
glob MI,
glob SMC1.IF,
glob SMC2.RFRP,
