(*all init assignments before Adv.init go into precondition*)
sp.
(*both sides are similar*)
sim
/
(UC_Composition.CompGlobs.mrfc_self{1} = UC_SMC2Real._self{1}
/\ UC_Composition.CompGlobs.mrfc_self{2} = UC_SMC2Real._self{2})
:
(={glob Env, func, in_guard,
glob Adv,
glob MI,
glob SMC1.IF,
glob SMC2.RFRP,
glob UC_SMC2Real
}).

       
 
       (*call Exper.main*)
