        if (_addr_Fwd2 UC_SMC2Real._self <= m.`2.`1)
        {r <@ Forwarding2.IF.invoke(m);}
        else {
        if (_addr_SMC1 UC_SMC2Real._self <= m.`2.`1) {r <@ SMC1__.invoke(m);}
        else {
        if((m.`1 = Dir /\ m.`2 = _extport_dir_Pt1 UC_SMC2Real._self /\
           envport UC_SMC2Real._self m.`3)
        \/
        (m.`1 = Dir /\ m.`2 = _intport_Pt1 UC_SMC2Real._self /\
        UC_SMC2Real._self < m.`3.`1))
        {r <@ party_Pt1(m);}
        else {
        if((m.`1 = Dir /\ m.`2 = _extport_dir_Pt2 UC_SMC2Real._self /\
           envport UC_SMC2Real._self m.`3)
        \/
        (m.`1 = Dir /\ m.`2 = _intport_Pt2 UC_SMC2Real._self /\
        UC_SMC2Real._self < m.`3.`1))
        {r <@ party_Pt2(m);}
        }
        }
        }
        }
        return r;
        }
        
      }.
     
clone UC_Composition.Composition as UC__Rest2 with
op change_pari = 2,
op rf_info <- rf_info
proof *.
realize rf_info_valid. smt(_adv_pi_begin_gt0). qed.
realize change_pari_valid. smt(). qed.

     lemma _invoke_Pt2_Rest2 (n : int) (SMC1 <: FUNC)  : hoare [
       UC_SMC2Real_Rest2(SMC1).party_Pt2 :
       _metric_Pt2 (glob_UC_SMC2Real_to__st_Pt2(glob UC_SMC2Real)) = n ==>
       (res <> None =>
       _metric_Pt2 (glob_UC_SMC2Real_to__st_Pt2(glob UC_SMC2Real)) < n
        /\ ((oget res).`1 = Adv => (oget res).`2.`2 \in  UC__Rest2.rest_adv_pis))
     ].
     proof. rewrite /_metric_Pt2 /=. proc. inline. (*inline procedure calls*)
      sp 1. (*initializing input, return value*) match. (*state match*)
     (*state branch Final*)  skip. move => />;smt(). (*empty state match branch code*)
     (*state branch WaitFwd1*) match. (*message match*)
      skip. move => />;smt(). (*None branch of message match, dec failed*)
     if. (*address check for internal messages*)
     sp 1. (*state param assignment, return value initialization*)sp 1. (*pattern bindings*)
     sp 1. (*Assign instruction*) 
      sp 3. skip. move => />;smt(mem_oflist mem_rangeset in_fsetU). (*SendAndTransition instruction*)
       skip. move => />;smt(). (*address check for internal messages failed case*)
     (*state branch WaitReq*) match. (*message match*)
      skip. move => />;smt(). (*None branch of message match, dec failed*)
     sp 2. (*state param assignment, return value initialization*)sp 2. (*pattern bindings*)
     if. (*if instruction*)
      sp 3. skip. move => />;smt(mem_oflist mem_rangeset in_fsetU). (*SendAndTransition instruction*)
       sp 2. skip. move => />;smt(). (*Fail instruction*)  
     (*state branch WaitSMC1*) match. (*message match*)
      skip. move => />;smt(). (*None branch of message match, dec failed*)
     if. (*address check for internal messages*)
     sp 3. (*state param assignment, return value initialization*)sp 1. (*pattern bindings*)
      sp 3. skip. move => />;smt(mem_oflist mem_rangeset in_fsetU). (*SendAndTransition instruction*)
       skip. move => />;smt(). (*address check for internal messages failed case*)
     qed. 
     
     lemma _invoke_Pt1_Rest2 (n : int) (SMC1 <: FUNC)  : hoare [
       UC_SMC2Real_Rest2(SMC1).party_Pt1 :
       _metric_Pt1 (glob_UC_SMC2Real_to__st_Pt1(glob UC_SMC2Real)) = n ==>
       (res <> None =>
       _metric_Pt1 (glob_UC_SMC2Real_to__st_Pt1(glob UC_SMC2Real)) < n
        /\ ((oget res).`1 = Adv => (oget res).`2.`2 \in  UC__Rest2.rest_adv_pis))
     ].
     proof. rewrite /_metric_Pt1 /=. proc. inline. (*inline procedure calls*)
      sp 1. (*initializing input, return value*) match. (*state match*)
     (*state branch Final*)  skip. move => />;smt(). (*empty state match branch code*)
     (*state branch WaitFwd2*) match. (*message match*)
      skip. move => />;smt(). (*None branch of message match, dec failed*)
     if. (*address check for internal messages*)
     sp 3. (*state param assignment, return value initialization*) sp 3. skip. move => />;smt(mem_oflist mem_rangeset in_fsetU). (*SendAndTransition instruction*)
       skip. move => />;smt(). (*address check for internal messages failed case*)
     (*state branch WaitReq*) match. (*message match*)
      skip. move => />;smt(). (*None branch of message match, dec failed*)
     sp 1. (*state param assignment, return value initialization*)sp 3. (*pattern bindings*)
     if. (*if instruction*)
      sp 3. skip. move => />;smt(mem_oflist mem_rangeset in_fsetU). (*SendAndTransition instruction*)
       sp 2. skip. move => />;smt(). (*Fail instruction*)  
     (*state branch WaitSMC2*) match. (*message match*)
      skip. move => />;smt(). (*None branch of message match, dec failed*)
     if. (*address check for internal messages*)
     sp 2. (*state param assignment, return value initialization*)sp 1. (*pattern bindings*)
      sp 3. skip. move => />;smt(mem_oflist mem_rangeset in_fsetU). (*SendAndTransition instruction*)
       skip. move => />;smt(). (*address check for internal messages failed case*)
     qed. 
     
     (*abbreviation for UC_SMC2Real_Rest2 with  parameters*)
     module UC_SMC2Real_Rest2_P = UC_SMC2Real_Rest2(SMC1.IF).
     
     op glob_UC_SMC2Real_Rest2_P_to_own(g : glob UC_SMC2Real_Rest2_P) / : glob UC_SMC2Real =
     (g.`1, g.`2, g.`3, g.`4, g.`5, g.`6, g.`7).
     
     op glob_UC_SMC2Real_Rest2_P_to_SMC1(g : glob UC_SMC2Real_Rest2_P) / : glob SMC1.IF =
     (g.`8, g.`9).
     
      op [smt_opaque] _metric_Rest2 (g : glob UC_SMC2Real_Rest2_P) : int =
      SMC1._metric_IF(glob_UC_SMC2Real_Rest2_P_to_SMC1 g)
     +_metric_Pt1(glob_UC_SMC2Real_to__st_Pt1 (glob_UC_SMC2Real_Rest2_P_to_own g))
     +_metric_Pt2(glob_UC_SMC2Real_to__st_Pt2 (glob_UC_SMC2Real_Rest2_P_to_own g))
     +Forwarding1._metric_IF(glob_UC_SMC2Real_to_Fwd1 (glob_UC_SMC2Real_Rest2_P_to_own g))
     +Forwarding2._metric_IF(glob_UC_SMC2Real_to_Fwd2 (glob_UC_SMC2Real_Rest2_P_to_own g))
     .
     
     lemma _invoke_Rest2 (n : int)  : hoare [
       UC_SMC2Real_Rest2_P.invoke :
       _metric_Rest2 (glob UC_SMC2Real_Rest2_P) = n
       ==>
       (res <> None =>
       _metric_Rest2 (glob UC_SMC2Real_Rest2_P) < n
     /\ ((oget res).`1 = Adv => (oget res).`2.`2 \in  UC__Rest2.rest_adv_pis))].
     proof.
     rewrite /_metric_Rest2 /=.
       proc.
       sp 1.
       if.
       exlim (Forwarding1._metric_IF(glob_UC_SMC2Real_to_Fwd1(glob_UC_SMC2Real_Rest2_P_to_own(glob UC_SMC2Real_Rest2_P)))) => _sub_metric.
       call (Forwarding1.IF_invoke _sub_metric ).
       skip.
       smt(mem_oflist mem_rangeset iota0 iota1 fset0U fsetU0 in_fsetU).
       if.
       exlim (Forwarding2._metric_IF(glob_UC_SMC2Real_to_Fwd2(glob_UC_SMC2Real_Rest2_P_to_own(glob UC_SMC2Real_Rest2_P)))) => _sub_metric.
       call (Forwarding2.IF_invoke _sub_metric ).
       skip.
       smt(mem_oflist mem_rangeset iota0 iota1 fset0U fsetU0 in_fsetU).
       if.
       exlim (SMC1._metric_IF(glob_UC_SMC2Real_Rest2_P_to_SMC1((glob UC_SMC2Real_Rest2_P)))) => _sub_metric.
       call (SMC1.IF_invoke _sub_metric ).
       skip.
       smt(mem_oflist mem_rangeset iota0 iota1 fset0U fsetU0 in_fsetU).
       if.
       exlim (_metric_Pt1(glob_UC_SMC2Real_to__st_Pt1(glob_UC_SMC2Real_Rest2_P_to_own(glob UC_SMC2Real_Rest2_P)))) => _sub_metric.
       call (_invoke_Pt1_Rest2 _sub_metric  SMC1.IF).
       skip.
       smt().
       if.
       exlim (_metric_Pt2(glob_UC_SMC2Real_to__st_Pt2(glob_UC_SMC2Real_Rest2_P_to_own(glob UC_SMC2Real_Rest2_P)))) => _sub_metric.
       call (_invoke_Pt2_Rest2 _sub_metric  SMC1.IF).
       skip.
       smt().
       skip.
       smt().
     qed.
     
      op _invar_Rest2 (g : glob UC_SMC2Real_Rest2_P) : bool =
       SMC1._invar_IF(glob_UC_SMC2Real_Rest2_P_to_SMC1 g)
     /\_invar_Pt1(glob_UC_SMC2Real_to__st_Pt1 (glob_UC_SMC2Real_Rest2_P_to_own g))
     /\_invar_Pt2(glob_UC_SMC2Real_to__st_Pt2 (glob_UC_SMC2Real_Rest2_P_to_own g))
     /\Forwarding1._invar_IF(glob_UC_SMC2Real_to_Fwd1 (glob_UC_SMC2Real_Rest2_P_to_own g))
     /\Forwarding2._invar_IF(glob_UC_SMC2Real_to_Fwd2 (glob_UC_SMC2Real_Rest2_P_to_own g))
     .
     
     lemma _metric_good_Rest2 (g : glob UC_SMC2Real_Rest2_P) :
     _invar_Rest2 g => 0 <= _metric_Rest2 g.
     proof.
     rewrite /_metric_Rest2 /=.
     rewrite /_invar_Rest2 /=.
     smt(
     SMC1.IF_metric_good
     Forwarding1.IF_metric_good
     Forwarding2.IF_metric_good
     _metric_Pt1_good
     _metric_Pt2_good
     ).
     qed.
     
     lemma _init_Rest2 :
     hoare [ UC_SMC2Real_Rest2_P.init : true ==> _invar_Rest2 (glob UC_SMC2Real_Rest2_P)].
     proof. proc. sp. wp.
     call (SMC1.IF_init).
     call (Forwarding2.IF_init).
     call (Forwarding1.IF_init).
     skip.
     rewrite /_invar_Rest2 /=.
     smt().
     qed.
     
