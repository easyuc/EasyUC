type _state_SIM = [ 
  | _State_SIM_Final
  | _State_SIM_WaitAdv1
  | _State_SIM_WaitAdv2
  | _State_SIM_WaitAdv3
  | _State_SIM_WaitAdv4
  | _State_SIM_WaitReq1
  | _State_SIM_WaitReq2
  
]. 

module UC_SMC2Sim = {
  var if_addr_opt : addr option
  var _st : _state_SIM
  proc init() : unit = {
    if_addr_opt <- None; _st <- _State_SIM_WaitReq1;
    
  }
  proc _State_SIM_WaitAdv1__SMC2Real__Fwd1__FwAdv__fw_ok () : msg option = {
    var _r : msg option <- None;
    _r <- Some
      (Forwarding2.UC_FwAdv.epdp__fw_obs.`enc
      {|
        Forwarding2.UC_FwAdv.fw_obs___func = _addr_Fwd2 (oget if_addr_opt);
        Forwarding2.UC_FwAdv.fw_obs___adv = adv;
        Forwarding2.UC_FwAdv.fw_obs__pt1 = _intport_Pt2 (oget if_addr_opt);
        Forwarding2.UC_FwAdv.fw_obs__pt2 = _intport_Pt1 (oget if_addr_opt);
        Forwarding2.UC_FwAdv.fw_obs__u = [];
        
      |});
    _st <- _State_SIM_WaitAdv2;
    return _r;
  }
  proc _State_SIM_WaitAdv2__SMC2Real__Fwd2__FwAdv__fw_ok () : msg option = {
    var _r : msg option <- None;
    _r <- Some
      (SMC1.UC_SMC2Sim.epdp__sim_req.`enc
      {|
        SMC1.UC_SMC2Sim.sim_req___func = _addr_SMC1 (oget if_addr_opt);
        SMC1.UC_SMC2Sim.sim_req___adv = adv;
        SMC1.UC_SMC2Sim.sim_req__pt1 = _intport_Pt1 (oget if_addr_opt);
        SMC1.UC_SMC2Sim.sim_req__pt2 = _intport_Pt2 (oget if_addr_opt);
        
      |});
    _st <- _State_SIM_WaitAdv3;
    return _r;
  }
  proc _State_SIM_WaitAdv3__SMC2Real__SMC1__SMC2Sim__sim_rsp () : msg option = {
    var _r : msg option <- None;
    _r <- Some
      (UC_SMC2IF_to_Sim.epdp__sim_rsp.`enc
      {|
        UC_SMC2IF_to_Sim.sim_rsp___func = (oget if_addr_opt);
        UC_SMC2IF_to_Sim.sim_rsp___adv = adv;
        
      |});
    _st <- _State_SIM_WaitReq2;
    return _r;
  }
  proc _State_SIM_WaitAdv4__SMC2Real__SMC2__SMC2Sim__sim_rsp () : msg option = {
    var _r : msg option <- None;
    _r <- Some
      (UC_SMC2IF_to_Sim.epdp__sim_rsp.`enc
      {|
        UC_SMC2IF_to_Sim.sim_rsp___func = (oget if_addr_opt);
        UC_SMC2IF_to_Sim.sim_rsp___adv = adv;
        
      |});
    _st <- _State_SIM_Final;
    return _r;
  }
  proc _State_SIM_WaitReq1__SMC2IF_to_Sim__sim_req1 (pt1 : port, pt2 : port) : msg option = {
    var _r : msg option <- None;
    _r <- Some
      (Forwarding1.UC_FwAdv.epdp__fw_obs.`enc
      {|
        Forwarding1.UC_FwAdv.fw_obs___func = _addr_Fwd1 (oget if_addr_opt);
        Forwarding1.UC_FwAdv.fw_obs___adv = adv;
        Forwarding1.UC_FwAdv.fw_obs__pt1 = _intport_Pt1 (oget if_addr_opt);
        Forwarding1.UC_FwAdv.fw_obs__pt2 = _intport_Pt2 (oget if_addr_opt);
        Forwarding1.UC_FwAdv.fw_obs__u = epdp_port_port_univ.`enc (pt1, pt2);
        
      |});
    _st <- _State_SIM_WaitAdv1;
    return _r;
  }
  proc _State_SIM_WaitReq2__SMC2IF_to_Sim__sim_req2 () : msg option = {
    var _r : msg option <- None;
    _r <- Some
      (SMC2.UC_SMC2Sim.epdp__sim_req.`enc
      {|
        SMC2.UC_SMC2Sim.sim_req___func = _addr_SMC2 (oget if_addr_opt);
        SMC2.UC_SMC2Sim.sim_req___adv = adv;
        SMC2.UC_SMC2Sim.sim_req__pt1 = _intport_Pt2 (oget if_addr_opt);
        SMC2.UC_SMC2Sim.sim_req__pt2 = _intport_Pt1 (oget if_addr_opt);
        
      |});
    _st <- _State_SIM_WaitAdv4;
    return _r;
  }
  proc invoke(_m : msg) : msg option = {
    var _r : msg option <- None;
    if (if_addr_opt = None) {if_addr_opt <- Some _m.`3.`1;}
    match _st with
    | _State_SIM_Final => {
      
    }
    | _State_SIM_WaitAdv1 => {
      if ((_m.`3.`1 = adv) /\ (_m.`2.`1 = _addr_Fwd1 (oget if_addr_opt)) /\ (Forwarding1.UC_FwAdv.epdp__fw_ok.`dec _m) <> None)
      {
        _r <@ _State_SIM_WaitAdv1__SMC2Real__Fwd1__FwAdv__fw_ok ();
      }
      
    }
    | _State_SIM_WaitAdv2 => {
      if ((_m.`3.`1 = adv) /\ (_m.`2.`1 = _addr_Fwd2 (oget if_addr_opt)) /\ (Forwarding2.UC_FwAdv.epdp__fw_ok.`dec _m) <> None)
      {
        _r <@ _State_SIM_WaitAdv2__SMC2Real__Fwd2__FwAdv__fw_ok ();
      }
      
    }
    | _State_SIM_WaitAdv3 => {
      if ((_m.`3.`1 = adv) /\ (_m.`2.`1 = _addr_SMC1 (oget if_addr_opt)) /\ (SMC1.UC_SMC2Sim.epdp__sim_rsp.`dec _m) <> None)
      {
        _r <@ _State_SIM_WaitAdv3__SMC2Real__SMC1__SMC2Sim__sim_rsp ();
      }
      
    }
    | _State_SIM_WaitAdv4 => {
      if ((_m.`3.`1 = adv) /\ (_m.`2.`1 = _addr_SMC2 (oget if_addr_opt)) /\ (SMC2.UC_SMC2Sim.epdp__sim_rsp.`dec _m) <> None)
      {
        _r <@ _State_SIM_WaitAdv4__SMC2Real__SMC2__SMC2Sim__sim_rsp ();
      }
      
    }
    | _State_SIM_WaitReq1 => {
      if ((_m.`3.`1 = (oget if_addr_opt)) /\ (_m.`2.`1 = adv) /\ (UC_SMC2IF_to_Sim.epdp__sim_req1.`dec _m) <> None)
      {
        _r <@ _State_SIM_WaitReq1__SMC2IF_to_Sim__sim_req1 ((oget (UC_SMC2IF_to_Sim.epdp__sim_req1.`dec _m)).`UC_SMC2IF_to_Sim.sim_req1__pt1, (oget (UC_SMC2IF_to_Sim.epdp__sim_req1.`dec _m)).`UC_SMC2IF_to_Sim.sim_req1__pt2);
      }
      
    }
    | _State_SIM_WaitReq2 => {
      if ((_m.`3.`1 = (oget if_addr_opt)) /\ (_m.`2.`1 = adv) /\ (UC_SMC2IF_to_Sim.epdp__sim_req2.`dec _m) <> None)
      {
        _r <@ _State_SIM_WaitReq2__SMC2IF_to_Sim__sim_req2 ();
      }
      
    }
    end;
    return _r;
  }
  
}.


op _invar_UC_SMC2Sim (g : glob UC_SMC2Sim) : bool = true.

 

op glob_UC_SMC2Sim_to__st (g : glob UC_SMC2Sim) / : _state_SIM = g.`1.
op [smt_opaque] _metric_UC_SMC2Sim (g : glob UC_SMC2Sim) : int =
  match glob_UC_SMC2Sim_to__st g with
  | _State_SIM_Final => 0
  | _State_SIM_WaitAdv1 => 5
  | _State_SIM_WaitAdv2 => 4
  | _State_SIM_WaitAdv3 => 3
  | _State_SIM_WaitAdv4 => 1
  | _State_SIM_WaitReq1 => 6
  | _State_SIM_WaitReq2 => 2
  end.
  


lemma UC_SMC2Sim_invoke (n : int) : hoare [
  UC_SMC2Sim.invoke :
  _invar_UC_SMC2Sim (glob UC_SMC2Sim) /\ _metric_UC_SMC2Sim (glob UC_SMC2Sim) = n
  ==>
  res <> None =>
  _metric_UC_SMC2Sim (glob UC_SMC2Sim) < n
   ].
proof. rewrite /_metric_UC_SMC2Sim /=. proc.
sp 1. (*initializing return value*)
seq 1 : (#pre /\ UC_SMC2Sim.if_addr_opt <> None). sp 1. auto;smt(). (*if_addr_opt initialized after first message is received*)
inline. match. (*state match*)
(*state branch Final*) sp 1. skip. move => />;smt(). (*empty state match branch code*)
(*state branch WaitAdv1*) if;last first. (*message guard*)
sp 1. skip. move => />;smt(). (*message guard failed*)
sp 1. (*state param assignment, return value initialization*)sp 1. sp 2. skip. move => />;smt(). (*SendAndTransition instruction*)
 (*state branch WaitAdv2*) if;last first. (*message guard*)
sp 1. skip. move => />;smt(). (*message guard failed*)
sp 1. (*state param assignment, return value initialization*)sp 1. sp 2. skip. move => />;smt(). (*SendAndTransition instruction*)
 (*state branch WaitAdv3*) if;last first. (*message guard*)
sp 1. skip. move => />;smt(). (*message guard failed*)
sp 1. (*state param assignment, return value initialization*)sp 1. sp 2. skip. move => />;smt(). (*SendAndTransition instruction*)
 (*state branch WaitAdv4*) if;last first. (*message guard*)
sp 1. skip. move => />;smt(). (*message guard failed*)
sp 1. (*state param assignment, return value initialization*)sp 1. sp 2. skip. move => />;smt(). (*SendAndTransition instruction*)
 (*state branch WaitReq1*) if;last first. (*message guard*)
sp 1. skip. move => />;smt(). (*message guard failed*)
sp 1. (*state param assignment, return value initialization*)sp 2. (*pattern bindings*)
sp 1. sp 2. skip. move => />;smt(). (*SendAndTransition instruction*) 
(*state branch WaitReq2*) if;last first. (*message guard*)
sp 1. skip. move => />;smt(). (*message guard failed*)
sp 1. (*state param assignment, return value initialization*)sp 1. sp 2. skip. move => />;smt(). (*SendAndTransition instruction*)
 qed. 

lemma UC_SMC2Sim_metric_good (g : glob UC_SMC2Sim) :
  _invar_UC_SMC2Sim g => 0 <= _metric_UC_SMC2Sim g.
  proof. rewrite /_metric_UC_SMC2Sim /=.   smt(). qed.  
lemma UC_SMC2Sim_init :
  hoare [UC_SMC2Sim.init : true ==> _invar_UC_SMC2Sim (glob UC_SMC2Sim)].
proof. proc. auto. qed. 
 

clone Simulator as MSCore with
op sim_adv_pi <- _adv_if_pi
proof *.
realize sim_adv_pi_ge1. smt(_adv_pi_begin_gt0). qed.
module SIM(Adv : ADV) = MSCore.MS(UC_SMC2Sim, Adv).


