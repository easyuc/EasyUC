}
/\ UC_Composition.CompGlobs.mrfc_self{1} = UC_SMC2Real._self{1}
/\ UC_Composition.CompGlobs.mrfc_self{2} = UC_SMC2Real._self{2}
); last first.
skip. move => />.

       (*after_par_or_rest are similar on both sides*)
seq 1 1 : (={r0, r1, r2, m, m0, m1, m2, not_done, not_done0,
glob Adv,
glob MI,
