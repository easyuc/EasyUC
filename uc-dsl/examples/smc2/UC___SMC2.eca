       Pr[Exper(MI(UC__Rest2.MakeRFComp(UC_SMC2Real_Rest2_P, SMC2.RFRP), Adv), Env).main(func', in_guard') @ &m : res]| <= 0.0
  <= 0.0
    .
     proof.
        move => exper_pre disjoint.
 
       
(*change the goal to equal probabilities in order to apply byequiv*)
have H:
(
`|Pr[Exper(MI(UC__Rest1.MakeRFComp(UC_SMC2Real_Rest1_P, SMC1.IF), Adv), Env).main(func', in_guard') @ &m : res]
       -
       Pr[Exper(MI(UC__Rest2.MakeRFComp(UC_SMC2Real_Rest2_P, SMC2.RFRP), Adv), Env).main(func', in_guard') @ &m : res]| <= 0.0
)
    <=>
(
Pr[Exper(MI(UC__Rest1.MakeRFComp(UC_SMC2Real_Rest1_P, SMC1.IF), Adv), Env).main(func', in_guard') @ &m : res]
 =
Pr[Exper(MI(UC__Rest2.MakeRFComp(UC_SMC2Real_Rest2_P, SMC2.RFRP), Adv), Env).main(func', in_guard') @ &m : res]
).
