lemma equiv_Composed1_IP_Composed2_RP
(Env <: ENV{-MI,  -AllCGs_, -RFRP, -AllIFs})
(Adv <: ADV{-MI, -AllCGs_, -Env, -RFRP, -AllIFs})
(func' : addr, in_guard' : int fset) &m :
exper_pre func' =>
disjoint in_guard' (adv_pis_rf_info rf_info)  =>
`|Pr[Exper(MI(UC__Rest1.MakeRFComp(UC_SMC2Real_Rest1_P, SMC1.IF), Adv), Env).main(func', in_guard') @ &m : res]
