glob SMC1.IF,
glob SMC2.RFRP,
glob UC_SMC2Real
}).

       
move => />.
 
       (*case when message is NOT for the 1. parameter functionality*)
rcondf{1} 0.
move => &m0. skip. move => />.

(*case when message is for the 2. parameter functionality*)
case (UC_Composition.CompGlobs.mrfc_self{2} ++ [UC__Rest2.change_pari] <= m2{2}.`2.`1).
rcondt{2} 0.
move => &m0. skip. move => />.

(*inline left invoke*)
inline{1} (1) invoke.
sp.

       (*the message is not for 1. sub-functionality*)
rcondf{1} 0.
move => &m0. skip. move => />. smt(not_le_other_branch).
       
       (*the message is not for 2. sub-functionality*)
rcondf{1} 0.
move => &m0. skip. move => />. smt(not_le_other_branch).
       
       (*message is for 2. parameter functionality*)
rcondt{1} 0.
move => &m0. skip. move => />.
(*both sides are similar*)
sim
/
(UC_Composition.CompGlobs.mrfc_self{1} = UC_SMC2Real._self{1}
/\ UC_Composition.CompGlobs.mrfc_self{2} = UC_SMC2Real._self{2})
:
(={r0, r1, r2, m, m0, m1, m2, not_done, not_done0,
glob Adv,
glob MI,
glob SMC1.IF,
glob SMC2.RFRP,
glob UC_SMC2Real
}).

       

       (*case when message is NOT for the 2. parameter functionality*)
rcondf{2} 0.
move => &m0. skip. move => />.

(*inline both invokes*)
inline{1} (1) invoke.
inline{2} (1) invoke.
sp. wp.
 
       (*if message is for 1. sub-functionality*)
if. move => />. sim.
       
       (*if message is for 2. sub-functionality*)
if. move => />. sim.
       
       
(*message is not for 1. parameter functionality*)
rcondf{2} 0.
move => &m0. skip. move => />.

(*message is not for 2. parameter functionality*)
rcondf{1} 0.
move => &m0. skip. move => />.

(*the rest is similar*)
sim.

       qed.  
       
