); last first.
(*both sides are similar*)
sim
/
(UC_Composition.CompGlobs.mrfc_self{1} = UC_SMC2Real._self{1}
/\ UC_Composition.CompGlobs.mrfc_self{2} = UC_SMC2Real._self{2})
:
(={r0, m, m0, not_done,
glob Adv,
glob MI,
glob SMC1.IF,
glob SMC2.RFRP,
glob UC_SMC2Real
}).

       

       (*inline invoke, put everything before and after if into pre/post conditions*)
inline invoke.
sp. wp.

(*if conditions and else branches are the same on both sides*)
if; last first.
skip. move => />.
move => />.

(*inline composed RF loop, put everything before and after if into pre/post conditions*)
inline loop.
sp. wp.

       (*while invariant*)
while (={r0, r1, r2, m, m0, m1, m2, not_done, not_done0,
glob Adv,
glob MI,
