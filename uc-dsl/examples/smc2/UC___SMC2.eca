abstract theory UC_SMC2IF_to_Sim_abs.

op pi : int.

op _SMC2 =  [83; 77; 67; 50]. (*SMC2 as ascii array*)

type _sim_req1 =
{
  sim_req1___func : addr;
  sim_req1___adv : addr;
  (*data*)
  sim_req1__pt1 : port;
  sim_req1__pt2 : port;
}.
op _sim_req1 =  [115; 105; 109; 95; 114; 101; 113; 49]. (*sim_req1 as ascii
array*)

op _tag__sim_req1 =  TagBasic _SMC2 _sim_req1.
op enc__sim_req1 (x : _sim_req1) : msg =
(Adv, (x.`sim_req1___adv, _adv_if_pi), (x.`sim_req1___func, pi),
_tag__sim_req1,
 (Top.UCUniv.epdp_pair_univ<:port, port> (epdp_port_univ) (epdp_port_univ)).`enc
(x.`sim_req1__pt1, x.`sim_req1__pt2))
.
op [opaque smt_opaque] dec__sim_req1 (m : msg) : _sim_req1 option =
  let (mod, pt1, pt2, tag, v) = m
  in (mod = Dir \/ pt1.`2 <> _adv_if_pi \/ pt2.`2 <> pi \/ tag <>
  _tag__sim_req1) ?
    None :
    match
    (Top.UCUniv.epdp_pair_univ<:port, port> (epdp_port_univ) (epdp_port_univ)).`dec
    v with
    | None   => None
    | Some p =>
      let (sim_req1__pt1 ,sim_req1__pt2) = p in
      Some
      {|
        sim_req1___func = pt2.`1; sim_req1___adv = pt1.`1;
        sim_req1__pt1 = sim_req1__pt1;
        sim_req1__pt2 = sim_req1__pt2;
      |}
    end
.

op epdp__sim_req1 = {|enc = enc__sim_req1; dec = dec__sim_req1|}.

lemma valid_epdp__sim_req1 : valid_epdp epdp__sim_req1.
proof.
apply epdp_intro.
move => x.
rewrite /epdp__sim_req1 /= /dec__sim_req1 /enc__sim_req1 /=.
by case x.
move => [mod [pt2_1 pt2_2] [pt1_1 pt1_2] tag v] u.
rewrite /epdp__sim_req1 /dec__sim_req1 /enc__sim_req1 /=.
case (mod = Dir \/ pt2_2 <> _adv_if_pi \/ pt1_2 <> pi \/ tag <> _tag__sim_req1) => //.
rewrite !negb_or /= not_dir.
move => [#] -> -> -> -> match_eq_some /=.
have val_v :
  (Top.UCUniv.epdp_pair_univ<:port, port> (epdp_port_univ) (epdp_port_univ)).`dec v =
  Some (u.`sim_req1__pt1 ,u.`sim_req1__pt2).
  move : match_eq_some.
  case ((Top.UCUniv.epdp_pair_univ<:port, port> (epdp_port_univ)
                                                                (epdp_port_univ)).`dec v) => //.
  by case.
move : match_eq_some.
rewrite val_v /= => <- /=.
apply epdp_dec_enc => //.
qed.

hint simplify [eqtrue] valid_epdp__sim_req1.
hint rewrite epdp : valid_epdp__sim_req1.

lemma eq_of_valid__sim_req1 (m : msg) :
  is_valid epdp__sim_req1 m =>
  m =
  let x = oget (epdp__sim_req1.`dec m) in
(Adv, (x.`sim_req1___adv, _adv_if_pi), (x.`sim_req1___func, pi),
_tag__sim_req1,
 (Top.UCUniv.epdp_pair_univ<:port, port> (epdp_port_univ) (epdp_port_univ)).`enc
(x.`sim_req1__pt1, x.`sim_req1__pt2)).
proof.
rewrite /is_valid.
move => val_m.
have [] x : exists (x : _sim_req1), epdp__sim_req1.`dec m = Some x.
