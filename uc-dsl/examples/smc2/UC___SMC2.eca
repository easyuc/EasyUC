glob UC_SMC2Real
}).

       

       (*case when message is for the 1. parameter functionality*)
case (UC_Composition.CompGlobs.mrfc_self{1} ++ [UC__Rest1.change_pari] <= m2{1}.`2.`1).
rcondt{1} 0.
move => &m0. skip. move => />.

(*message is not for right parameter functionality*)
rcondf{2} 0.
move => &m0. skip. move => />. smt(not_le_other_branch).

(*inline right invoke*)
