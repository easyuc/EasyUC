op _adv_pi_num : int = 3 + SMC1._adv_pi_num + SMC2._adv_pi_num.

abstract theory UC_SMC2Pt1_abs.

op pi : int.

op _SMC2 =  [83; 77; 67; 50]. (*SMC2 as ascii array*)

type _smc_req =
{
  smc_req___func : addr;
  smc_req__pt1 : port;
  (*data*)
  smc_req__pt2 : port;
  smc_req__t : text1;
}.
op _smc_req =  [115; 109; 99; 95; 114; 101; 113]. (*smc_req as ascii array*)

op _tag__smc_req =  TagBasic _SMC2 _smc_req.
op enc__smc_req (x : _smc_req) : msg =
(Dir, (x.`smc_req___func, pi), x.`smc_req__pt1, _tag__smc_req,
 (Top.UCUniv.epdp_pair_univ<:port, text1> (epdp_port_univ) (epdp_text1_univ)).`enc
(x.`smc_req__pt2, x.`smc_req__t))
.
op [opaque smt_opaque] dec__smc_req (m : msg) : _smc_req option =
  let (mod, pt1, pt2, tag, v) = m
  in (mod = Adv \/ pt1.`2 <> pi \/ tag <> _tag__smc_req) ?
    None :
    match
    (Top.UCUniv.epdp_pair_univ<:port, text1> (epdp_port_univ)
                                                             (epdp_text1_univ)).`dec
    v with
    | None   => None
    | Some p =>
      let (smc_req__pt2 ,smc_req__t) = p in
      Some
      {|
        smc_req___func = pt1.`1; smc_req__pt1 = pt2;
        smc_req__pt2 = smc_req__pt2;
        smc_req__t = smc_req__t;
      |}
    end
.

op epdp__smc_req = {|enc = enc__smc_req; dec = dec__smc_req|}.

lemma valid_epdp__smc_req : valid_epdp epdp__smc_req.
proof.
apply epdp_intro.
move => x.
rewrite /epdp__smc_req /= /dec__smc_req /enc__smc_req /=.
by case x.
move => [mod [pt1_1 pt1_2] pt2 tag v] u.
rewrite /epdp__smc_req /dec__smc_req /enc__smc_req /=.
case (mod = Adv \/ pt1_2 <> pi \/ tag <> _tag__smc_req) => //.
rewrite !negb_or /= not_adv.
move => [#] -> -> -> match_eq_some /=.
have val_v :
  (Top.UCUniv.epdp_pair_univ<:port, text1> (epdp_port_univ) (epdp_text1_univ)).`dec v =
  Some (u.`smc_req__pt2 ,u.`smc_req__t).
  move : match_eq_some.
  case ((Top.UCUniv.epdp_pair_univ<:port, text1> (epdp_port_univ)
                                                                 (epdp_text1_univ)).`dec v) => //.
  by case.
move : match_eq_some.
rewrite val_v /= => <- /=.
apply epdp_dec_enc => //.
qed.

hint simplify [eqtrue] valid_epdp__smc_req.
hint rewrite epdp : valid_epdp__smc_req.

lemma eq_of_valid__smc_req (m : msg) :
  is_valid epdp__smc_req m =>
  m =
  let x = oget (epdp__smc_req.`dec m) in
(Dir, (x.`smc_req___func, pi), x.`smc_req__pt1, _tag__smc_req,
 (Top.UCUniv.epdp_pair_univ<:port, text1> (epdp_port_univ) (epdp_text1_univ)).`enc
(x.`smc_req__pt2, x.`smc_req__t)).
proof.
rewrite /is_valid.
move => val_m.
have [] x : exists (x : _smc_req), epdp__smc_req.`dec m = Some x.
  exists (oget (dec__smc_req m)); rewrite -some_oget; smt(); smt().
case x => x1 x2 x3 x4.
move => /(epdp_dec_enc _ _ _ valid_epdp__smc_req) <-.
by rewrite !epdp.
qed.

type _smc_rsp =
{
  smc_rsp___func : addr;
  smc_rsp__pt1 : port;
  (*data*)
  smc_rsp__t : text2;
}.
op _smc_rsp =  [115; 109; 99; 95; 114; 115; 112]. (*smc_rsp as ascii array*)

op _tag__smc_rsp =  TagBasic _SMC2 _smc_rsp.
op enc__smc_rsp (x : _smc_rsp) : msg =
(Dir, x.`smc_rsp__pt1, (x.`smc_rsp___func, pi), _tag__smc_rsp,
 (epdp_text2_univ).`enc x.`smc_rsp__t)
.
op [opaque smt_opaque] dec__smc_rsp (m : msg) : _smc_rsp option =
  let (mod, pt1, pt2, tag, v) = m
  in (mod = Adv \/ pt2.`2 <> pi \/ tag <> _tag__smc_rsp) ?
    None :
    match (epdp_text2_univ).`dec v with
    | None   => None
    | Some p =>
      let smc_rsp__t = p in
      Some
      {|
        smc_rsp___func = pt2.`1; smc_rsp__pt1 = pt1;
        smc_rsp__t = smc_rsp__t;
      |}
    end
.

op epdp__smc_rsp = {|enc = enc__smc_rsp; dec = dec__smc_rsp|}.

lemma valid_epdp__smc_rsp : valid_epdp epdp__smc_rsp.
proof.
apply epdp_intro.
move => x.
rewrite /epdp__smc_rsp /= /dec__smc_rsp /enc__smc_rsp /=.
by case x.
move => [mod pt2 [pt1_1 pt1_2] tag v] u.
rewrite /epdp__smc_rsp /dec__smc_rsp /enc__smc_rsp /=.
case (mod = Adv \/ pt1_2 <> pi \/ tag <> _tag__smc_rsp) => //.
rewrite !negb_or /= not_adv.
move => [#] -> -> -> match_eq_some /=.
have val_v :
  (epdp_text2_univ).`dec v =
  Some (u.`smc_rsp__t).
  move : match_eq_some.
  case ((epdp_text2_univ).`dec v) => //.
move : match_eq_some.
rewrite val_v /= => <- /=.
apply epdp_dec_enc => //.
qed.

hint simplify [eqtrue] valid_epdp__smc_rsp.
hint rewrite epdp : valid_epdp__smc_rsp.

lemma eq_of_valid__smc_rsp (m : msg) :
  is_valid epdp__smc_rsp m =>
  m =
  let x = oget (epdp__smc_rsp.`dec m) in
(Dir, x.`smc_rsp__pt1, (x.`smc_rsp___func, pi), _tag__smc_rsp,
 (epdp_text2_univ).`enc x.`smc_rsp__t).
proof.
rewrite /is_valid.
move => val_m.
have [] x : exists (x : _smc_rsp), epdp__smc_rsp.`dec m = Some x.
  exists (oget (dec__smc_rsp m)); rewrite -some_oget; smt(); smt().
case x => x1 x2 x3.
move => /(epdp_dec_enc _ _ _ valid_epdp__smc_rsp) <-.
by rewrite !epdp.
qed.

end UC_SMC2Pt1_abs.



