op _KeyExchange =  [75; 101; 121; 69; 120; 99; 104; 97; 110; 103; 101].
(*KeyExchange as ascii array*)

type _ke_sim_req1 =
{
  ke_sim_req1___func : addr;
  ke_sim_req1___adv : addr;
  (*data*)
  ke_sim_req1__pt1 : port;
  ke_sim_req1__pt2 : port;
}.
op _ke_sim_req1 =  [107; 101; 95; 115; 105; 109; 95; 114; 101; 113; 49].
(*ke_sim_req1 as ascii array*)

op _tag__ke_sim_req1 =  TagBasic _KeyExchange _ke_sim_req1.
op enc__ke_sim_req1 (x : _ke_sim_req1) : msg =
(Adv, (x.`ke_sim_req1___adv, _adv_if_pi), (x.`ke_sim_req1___func, pi),
