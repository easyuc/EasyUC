op _adv_pi_num : int = 3.

abstract theory UC_KEDirPt1_abs.

op pi : int.

op _KeyExchange =  [75; 101; 121; 69; 120; 99; 104; 97; 110; 103; 101].
(*KeyExchange as ascii array*)

type _ke_req1 =
{
  ke_req1___func : addr;
  ke_req1__pt1 : port;
  (*data*)
  ke_req1__pt2 : port;
}.
op _ke_req1 =  [107; 101; 95; 114; 101; 113; 49]. (*ke_req1 as ascii array*)

op _tag__ke_req1 =  TagBasic _KeyExchange _ke_req1.
op enc__ke_req1 (x : _ke_req1) : msg =
(Dir, (x.`ke_req1___func, pi), x.`ke_req1__pt1, _tag__ke_req1,
 (epdp_port_univ).`enc x.`ke_req1__pt2)
.
op [opaque smt_opaque] dec__ke_req1 (m : msg) : _ke_req1 option =
  let (mod, pt1, pt2, tag, v) = m
  in (mod = Adv \/ pt1.`2 <> pi \/ tag <> _tag__ke_req1) ?
    None :
    match (epdp_port_univ).`dec v with
    | None   => None
    | Some p =>
      let ke_req1__pt2 = p in
      Some
      {|
        ke_req1___func = pt1.`1; ke_req1__pt1 = pt2;
        ke_req1__pt2 = ke_req1__pt2;
      |}
    end
.

op epdp__ke_req1 = {|enc = enc__ke_req1; dec = dec__ke_req1|}.

lemma valid_epdp__ke_req1 : valid_epdp epdp__ke_req1.
proof.
apply epdp_intro.
move => x.
rewrite /epdp__ke_req1 /= /dec__ke_req1 /enc__ke_req1 /=.
by case x.
move => [mod [pt1_1 pt1_2] pt2 tag v] u.
rewrite /epdp__ke_req1 /dec__ke_req1 /enc__ke_req1 /=.
case (mod = Adv \/ pt1_2 <> pi \/ tag <> _tag__ke_req1) => //.
rewrite !negb_or /= not_adv.
move => [#] -> -> -> match_eq_some /=.
have val_v :
  (epdp_port_univ).`dec v =
  Some (u.`ke_req1__pt2).
  move : match_eq_some.
  case ((epdp_port_univ).`dec v) => //.
move : match_eq_some.
rewrite val_v /= => <- /=.
apply epdp_dec_enc => //.
qed.

hint simplify [eqtrue] valid_epdp__ke_req1.
hint rewrite epdp : valid_epdp__ke_req1.

lemma eq_of_valid__ke_req1 (m : msg) :
  is_valid epdp__ke_req1 m =>
  m =
  let x = oget (epdp__ke_req1.`dec m) in
(Dir, (x.`ke_req1___func, pi), x.`ke_req1__pt1, _tag__ke_req1,
 (epdp_port_univ).`enc x.`ke_req1__pt2).
proof.
rewrite /is_valid.
move => val_m.
have [] x : exists (x : _ke_req1), epdp__ke_req1.`dec m = Some x.
  exists (oget (dec__ke_req1 m)); rewrite -some_oget; smt(); smt().
case x => x1 x2 x3.
move => /(epdp_dec_enc _ _ _ valid_epdp__ke_req1) <-.
by rewrite !epdp.
qed.

type _ke_rsp2 =
{
  ke_rsp2___func : addr;
  ke_rsp2__pt1 : port;
  (*data*)
  ke_rsp2__k : key;
}.
op _ke_rsp2 =  [107; 101; 95; 114; 115; 112; 50]. (*ke_rsp2 as ascii array*)

op _tag__ke_rsp2 =  TagBasic _KeyExchange _ke_rsp2.
op enc__ke_rsp2 (x : _ke_rsp2) : msg =
(Dir, x.`ke_rsp2__pt1, (x.`ke_rsp2___func, pi), _tag__ke_rsp2,
 (epdp_key_univ).`enc x.`ke_rsp2__k)
.
op [opaque smt_opaque] dec__ke_rsp2 (m : msg) : _ke_rsp2 option =
  let (mod, pt1, pt2, tag, v) = m
  in (mod = Adv \/ pt2.`2 <> pi \/ tag <> _tag__ke_rsp2) ?
    None :
    match (epdp_key_univ).`dec v with
    | None   => None
    | Some p =>
      let ke_rsp2__k = p in
      Some
      {|
        ke_rsp2___func = pt2.`1; ke_rsp2__pt1 = pt1;
        ke_rsp2__k = ke_rsp2__k;
      |}
    end
.

op epdp__ke_rsp2 = {|enc = enc__ke_rsp2; dec = dec__ke_rsp2|}.

lemma valid_epdp__ke_rsp2 : valid_epdp epdp__ke_rsp2.
proof.
apply epdp_intro.
move => x.
rewrite /epdp__ke_rsp2 /= /dec__ke_rsp2 /enc__ke_rsp2 /=.
by case x.
move => [mod pt2 [pt1_1 pt1_2] tag v] u.
rewrite /epdp__ke_rsp2 /dec__ke_rsp2 /enc__ke_rsp2 /=.
case (mod = Adv \/ pt1_2 <> pi \/ tag <> _tag__ke_rsp2) => //.
rewrite !negb_or /= not_adv.
move => [#] -> -> -> match_eq_some /=.
have val_v :
  (epdp_key_univ).`dec v =
  Some (u.`ke_rsp2__k).
  move : match_eq_some.
  case ((epdp_key_univ).`dec v) => //.
move : match_eq_some.
rewrite val_v /= => <- /=.
apply epdp_dec_enc => //.
qed.

hint simplify [eqtrue] valid_epdp__ke_rsp2.
hint rewrite epdp : valid_epdp__ke_rsp2.

lemma eq_of_valid__ke_rsp2 (m : msg) :
  is_valid epdp__ke_rsp2 m =>
  m =
  let x = oget (epdp__ke_rsp2.`dec m) in
(Dir, x.`ke_rsp2__pt1, (x.`ke_rsp2___func, pi), _tag__ke_rsp2,
 (epdp_key_univ).`enc x.`ke_rsp2__k).
proof.
rewrite /is_valid.
move => val_m.
have [] x : exists (x : _ke_rsp2), epdp__ke_rsp2.`dec m = Some x.
  exists (oget (dec__ke_rsp2 m)); rewrite -some_oget; smt(); smt().
case x => x1 x2 x3.
move => /(epdp_dec_enc _ _ _ valid_epdp__ke_rsp2) <-.
by rewrite !epdp.
qed.

end UC_KEDirPt1_abs.



