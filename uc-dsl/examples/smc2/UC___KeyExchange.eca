require UC_Forwarding.

require KeyExp.

require import UCCore.

require UCComposition.

clone UCComposition as UC_Composition.

type key.

op (^^) : key -> key -> key.

op kid : key.

op kinv : key -> key.

axiom kmulA (x y z : key) : x ^^ y ^^ z = x ^^ (y ^^ z).

axiom kid_l (x : key) : kid ^^ x = x.

axiom kid_r (x : key) : x ^^ kid = x.

axiom kinv_l (x : key) : kinv x ^^ x = kid.

axiom kinv_r (x : key) : x ^^ kinv x = kid.

type exp.

op e : exp.

op ( * ) : exp -> exp -> exp.

axiom mulC (q r : exp) : q * r = r * q.

axiom mulA (q r s : exp) : q * r * s = q * (r * s).

op epdp_exp_univ : (exp, univ) epdp.

axiom valid_epdp_exp_univ : valid_epdp epdp_exp_univ.

op [full uniform lossless] dexp : exp Distr.distr.

op g : key.

op (^) : key -> exp -> key.

axiom double_exp_gen (q1 q2 : exp) : g ^ q1 ^ q2 = g ^ (q1 * q2).

axiom gen_surj (x : key) : exists (q : exp), x = g ^ q.

axiom gen_inj (q r : exp) : g ^ q = g ^ r => q = r.

op _adv_pi_begin : int.

axiom _adv_pi_begin_gt0 : 0 < _adv_pi_begin.


op _adv_if_pi : int = _adv_pi_begin.


clone import KeyExp as KeyExp' with
  type key <- key,
  op (^^) : key -> key -> key <- (^^),
  op kid : key <- kid,
  op kinv : key -> key <- kinv,
  type exp <- exp,
  op e : exp <- e,
  op ( * ) : exp -> exp -> exp <- ( * ),
  op epdp_exp_univ : (exp, univ) epdp <- epdp_exp_univ,
  op dexp : exp Distr.distr <- dexp,
  op g : key <- g,
  op (^) : key -> exp -> key <- (^)
proof *.
(* BEGIN USER FILL *)
realize kmulA. smt. qed. 
realize kid_l. smt. qed.
realize kid_r. smt. qed.
realize kinv_l. smt. qed.
realize kinv_r. smt. qed.
realize mulC. smt. qed.
realize mulA. smt. qed.
realize valid_epdp_exp_univ. smt. qed.
realize dexp_ll. smt. qed.
realize dexp_uni. smt. qed.
realize dexp_fu. smt. qed.
realize double_exp_gen. smt. qed.
realize gen_surj. smt. qed.
realize gen_inj. smt. qed.
(* END USER FILL *)

clone UC_Forwarding as Forwarding1 with
  op _adv_if_pi <- _adv_pi_begin + 1
proof *.
(* BEGIN USER FILL *)
realize _adv_if_pi_gt0. smt. qed.
(* END USER FILL *)

clone UC_Forwarding as Forwarding2 with
  op _adv_if_pi <- _adv_pi_begin + 2
proof *.
