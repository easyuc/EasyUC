local lemma Exper_RFIP_Hybrid (func' : addr) (in_guard' : int fset) &m :
  exper_pre func' =>
  Pr[Exper(MI(RFIP, Adv), Env).main(func', in_guard') @ &m : res] =
  Pr[Exper(MI(Hybrid, Adv), Env).main(func', in_guard') @ &m : res].
proof.
move => ep_func.
apply
  (MakeInt.func_equiv_implies_exper_equal_prob
   RFIP Hybrid Adv Env func' in_guard' (rfip_rfips_invar func') &m) => //.
by apply RFIP_Hybrid_init.
by conseq (RFIP_Hybrid_invoke func' _).
qed.

local op glob_IF_to_self (g : glob IF) : addr      = g.`1.
local op glob_IF_to_st   (g : glob IF) : _state_IF = g.`2.

local op glob_SIM_to_st (g : glob SIM) : _state_SIM              = g.`1.
local op glob_SIM_to_if_addr_opt (g : glob SIM) : addr option    = g.`2.
local op glob_SIM_to_MS_if_addr_opt (g : glob SIM) : addr option = g.`3.

local op hybrid_ideal_sim_invar0
    (func : addr, gh : glob Hybrid, gif : glob IF,
     gsim : glob SIM) : bool =
  glob_Hybrid_to_self gh          = func /\
  glob_IF_to_self gif             = func /\
  glob_SIM_to_if_addr_opt gsim    = None /\
  glob_SIM_to_MS_if_addr_opt gsim = None /\
  glob_Hybrid_to_st gh            = HybridStateWaitReq1 /\
  glob_IF_to_st gif               = _State_IF_WaitReq1 /\
  glob_SIM_to_st gsim             = _State_SIM_WaitReq1.

local op hybrid_ideal_sim_invar1
    (func : addr, gh : glob Hybrid, gif : glob IF,
     gsim : glob SIM, pt1 pt2 : port, t1 : text1) : bool =
  envport func pt1 /\ envport func pt2 /\
  glob_Hybrid_to_self gh          = func /\
  glob_IF_to_self gif             = func /\
  glob_SIM_to_if_addr_opt gsim    = Some func /\
  glob_SIM_to_MS_if_addr_opt gsim = Some func /\
  glob_Hybrid_to_st gh            = HybridStateWaitAdv1 pt1 pt2 t1 /\
  glob_IF_to_st gif               = _State_IF_WaitSim1 pt1 pt2 t1 /\
  glob_SIM_to_st gsim             = _State_SIM_WaitAdv1.

local op hybrid_ideal_sim_invar2
    (func : addr, gh : glob Hybrid, gif : glob IF,
     gsim : glob SIM, pt1 pt2 : port, t1 : text1) : bool =
  envport func pt1 /\ envport func pt2 /\
  glob_Hybrid_to_self gh          = func /\
  glob_IF_to_self gif             = func /\
  glob_SIM_to_if_addr_opt gsim    = Some func /\
  glob_SIM_to_MS_if_addr_opt gsim = Some func /\
  glob_Hybrid_to_st gh            = HybridStateWaitAdv2 pt1 pt2 t1 /\
  glob_IF_to_st gif               = _State_IF_WaitSim1 pt1 pt2 t1 /\
  glob_SIM_to_st gsim             = _State_SIM_WaitAdv2.

local op hybrid_ideal_sim_invar3
    (func : addr, gh : glob Hybrid, gif : glob IF,
     gsim : glob SIM, pt1 pt2 : port, t1 : text1) : bool =
  envport func pt1 /\ envport func pt2 /\
  glob_Hybrid_to_self gh          = func /\
  glob_IF_to_self gif             = func /\
  glob_SIM_to_if_addr_opt gsim    = Some func /\
  glob_SIM_to_MS_if_addr_opt gsim = Some func /\
  glob_Hybrid_to_st gh            = HybridStateWaitAdv3 pt1 pt2 t1 /\
  glob_IF_to_st gif               = _State_IF_WaitSim1 pt1 pt2 t1 /\
  glob_SIM_to_st gsim             = _State_SIM_WaitAdv3.

local op hybrid_ideal_sim_invar4
    (func : addr, gh : glob Hybrid, gif : glob IF,
     gsim : glob SIM, pt1 pt2 : port) : bool =
  envport func pt1 /\ envport func pt2 /\
  glob_Hybrid_to_self gh          = func /\
  glob_IF_to_self gif             = func /\
  glob_SIM_to_if_addr_opt gsim    = Some func /\
  glob_SIM_to_MS_if_addr_opt gsim = Some func /\
  glob_Hybrid_to_st gh            = HybridStateWaitReq2 pt1 pt2 /\
  glob_IF_to_st gif               = _State_IF_WaitReq2 pt1 pt2 /\
  glob_SIM_to_st gsim             = _State_SIM_WaitReq2.

local op hybrid_ideal_sim_invar5
    (func : addr, gh : glob Hybrid, gif : glob IF,
     gsim : glob SIM, pt1 : port, t2 : text2) : bool =
  envport func pt1 /\
  glob_Hybrid_to_self gh          = func /\
  glob_IF_to_self gif             = func /\
  glob_SIM_to_if_addr_opt gsim    = Some func /\
  glob_SIM_to_MS_if_addr_opt gsim = Some func /\
  glob_Hybrid_to_st gh            = HybridStateWaitAdv4 pt1 t2 /\
  glob_IF_to_st gif               = _State_IF_WaitSim2 pt1 t2 /\
  glob_SIM_to_st gsim             = _State_SIM_WaitAdv4.

local op hybrid_ideal_sim_invar6
    (func : addr, gh : glob Hybrid, gif : glob IF,
     gsim : glob SIM) : bool =
  glob_Hybrid_to_self gh          = func /\
  glob_IF_to_self gif             = func /\
  glob_SIM_to_if_addr_opt gsim    = Some func /\
  glob_SIM_to_MS_if_addr_opt gsim = Some func /\
  glob_Hybrid_to_st gh            = HybridStateFinal /\
  glob_IF_to_st gif               = _State_IF_Final /\
  glob_SIM_to_st gsim             = _State_SIM_Final.

local inductive hybrid_ideal_sim_invar
    (func : addr, gh : glob Hybrid, gif : glob IF, gsim : glob SIM) =
  | HybridIdealSimInvar0 of
      (hybrid_ideal_sim_invar0 func gh gif gsim)
  | HybridIdealSimInvar1 (pt1 pt2 : port, t1 : text1) of
      (hybrid_ideal_sim_invar1 func gh gif gsim pt1 pt2 t1)
  | HybridIdealSimInvar2 (pt1 pt2 : port, t1 : text1) of
      (hybrid_ideal_sim_invar2 func gh gif gsim pt1 pt2 t1)
  | HybridIdealSimInvar3 (pt1 pt2 : port, t1 : text1) of
      (hybrid_ideal_sim_invar3 func gh gif gsim pt1 pt2 t1)
  | HybridIdealSimInvar4 (pt1 pt2 : port) of
      (hybrid_ideal_sim_invar4 func gh gif gsim pt1 pt2)
  | HybridIdealSimInvar5 (pt1 : port, t2 : text2) of
      (hybrid_ideal_sim_invar5 func gh gif gsim pt1 t2)
  | HybridIdealSimInvar6 of
      (hybrid_ideal_sim_invar6 func gh gif gsim).

local module SimCore = UC_SMC2Sim.
local module SimDA   = MSCore.MS(SimCore, DummyAdv).

local op invar_SimCore  : (glob SimCore) -> bool = _invar_UC_SMC2Sim.
local op metric_SimCore : (glob SimCore) -> int  = _metric_UC_SMC2Sim.

local lemma metric_SimCore_good (g : glob SimCore) :
  invar_SimCore g => 0 <= metric_SimCore g.
proof. apply UC_SMC2Sim_metric_good. qed.

local lemma metric_SimCore_init:
  hoare [SimCore.init : true ==> invar_SimCore (glob SimCore)].
proof. apply UC_SMC2Sim_init. qed.

local lemma metric_SimCore_invoke (n : int) :
  hoare
  [SimCore.invoke :
   invar_SimCore (glob SimCore) /\ metric_SimCore (glob SimCore) = n ==>
   invar_SimCore (glob SimCore) /\
   (res <> None =>  metric_SimCore (glob SimCore) < n)].
proof. apply UC_SMC2Sim_invoke. qed.

