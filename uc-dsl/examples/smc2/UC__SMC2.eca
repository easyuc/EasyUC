(* UC__SMC2.eca *)

(* The user's part of the SMC2 security proof. *)

require import UCCore.

require import EPDPAux.

require UC___SMC2.
clone include UC___SMC2.

(* used in module restrictions of the lemma of UC_SMC2.eca *)

module AllCGs  = {
  module UC__AllCGs_ = AllCGs_

  proc foo() = {
    var x1 <- MSCore.CombEnvAdv.func;
    var x2 <- MSCore.CombEnvAdv.in_guard;
  }
}.

section.

declare module Adv <: ADV{-MI, -RFIP, -IF, -SIM, -AllCGs}.
declare module Env <: ENV{-Adv, -MI, -RFIP, -IF, -SIM, -AllCGs}.

(* our hybrid is a simplified, single-state machine version of RFIP *)

local type hybrid_state = [
  | HybridStateWaitReq1
  | HybridStateWaitAdv1 of port & port & text1
  | HybridStateWaitAdv2 of port & port & text1
  | HybridStateWaitAdv3 of port & port & text1
  | HybridStateWaitReq2 of port & port
  | HybridStateWaitAdv4 of port & text2
  | HybridStateFinal
].

local module Hybrid : FUNC = {
  var self : addr
  var st : hybrid_state

  proc init(self_ : addr) : unit = {
    self <- self_;
    st <- HybridStateWaitReq1;
  }

  proc state_HybridStateWaitReq1_SMC2Dir_Pt1_smc_req
       (pt1 : port, pt2 : port, t1 : text1) : msg option = {
    var r : msg option <- None;
    if (envport self pt2) {
      r <-
        Some
        (Forwarding1.UC_FwAdv.epdp__fw_obs.`enc
         {|Forwarding1.UC_FwAdv.fw_obs___func = _addr_Fwd1 self;
           Forwarding1.UC_FwAdv.fw_obs__pt1   = _intport_Pt1 self;
           Forwarding1.UC_FwAdv.fw_obs__pt2   = _intport_Pt2 self;
           Forwarding1.UC_FwAdv.fw_obs__u     =
             epdp_port_port_univ.`enc (pt1, pt2);
          |});
      st <- HybridStateWaitAdv1 pt1 pt2 t1;
    }
    return r;
  }

  proc state_HybridStateWaitAdv1_Forwarding1_FwAdv_fw_ok
       (pt1 : port, pt2 : port, t1 : text1) : msg option = {
    var r : msg option <- None;
    r <-
      Some
      (Forwarding2.UC_FwAdv.epdp__fw_obs.`enc
       {|Forwarding2.UC_FwAdv.fw_obs___func = _addr_Fwd2 self;
         Forwarding2.UC_FwAdv.fw_obs__pt1   = _intport_Pt2 self;
         Forwarding2.UC_FwAdv.fw_obs__pt2   = _intport_Pt1 self;
         Forwarding2.UC_FwAdv.fw_obs__u     = [];
        |});
    st <- HybridStateWaitAdv2 pt1 pt2 t1;
    return r;
  }

  proc state_HybridStateWaitAdv2_Forwarding2_FwAdv_fw_ok
       (pt1 : port, pt2 : port, t1 : text1) : msg option = {
    var r : msg option <- None;
    r <-
      Some
      (SMC1.UC_SMC2Sim.epdp__sim_req.`enc
       {|SMC1.UC_SMC2Sim.sim_req___func = _addr_SMC1 self;
         SMC1.UC_SMC2Sim.sim_req__pt1   = _intport_Pt1 self;
         SMC1.UC_SMC2Sim.sim_req__pt2   = _intport_Pt2 self;
        |});
    st <- HybridStateWaitAdv3 pt1 pt2 t1;
    return r;
  }

  proc state_HybridStateWaitAdv3_SMC1_SMC2Sim_sim_rsp
       (pt1 : port, pt2 : port, t1 : text1) : msg option = {
    var r : msg option <- None;
    r <- Some
      (UC_SMC2Dir.Pt2.epdp__smc_rsp.`enc
      {|UC_SMC2Dir.Pt2.smc_rsp___func = self;
        UC_SMC2Dir.Pt2.smc_rsp__pt2   = pt2;
        UC_SMC2Dir.Pt2.smc_rsp__pt1   = pt1;
        UC_SMC2Dir.Pt2.smc_rsp__t     = t1;
       |});
    st <- HybridStateWaitReq2 pt1 pt2;
    return r;
  }

  proc state_HybridStateWaitReq2_SMC2Dir_Pt2_smc_req
       (pt1 : port, pt2 : port,
        pt2' : port, t2 : text2) : msg option = {
    var r : msg option <- None;
    if (pt2' = pt2) {
      r <-
        Some
        (SMC2.UC_SMC2Sim.epdp__sim_req.`enc
         {|SMC2.UC_SMC2Sim.sim_req___func = _addr_SMC2 self;
           SMC2.UC_SMC2Sim.sim_req__pt1   = _intport_Pt2 self;
           SMC2.UC_SMC2Sim.sim_req__pt2   = _intport_Pt1 self;
          |});
      st <- HybridStateWaitAdv4 pt1 t2;
     }
     return r;
  }

  proc state_HybridStateWaitAdv4_SMC2_SMC2Sim_sim_rsp
       (pt1 : port, t2 : text2) : msg option = {
    var r : msg option <- None;
    r <-
      Some
      (UC_SMC2Dir.Pt1.epdp__smc_rsp.`enc
       {|UC_SMC2Dir.Pt1.smc_rsp___func = self;
         UC_SMC2Dir.Pt1.smc_rsp__pt1   = pt1;
         UC_SMC2Dir.Pt1.smc_rsp__t     = t2;
        |});
    st <- HybridStateFinal;
    return r;
  }

  proc invoke(m : msg) : msg option = {
    var r : msg option <- None;
    match st with
    | HybridStateWaitReq1            => {
        if (m.`1 = Dir /\ m.`2 = _extport_dir_Pt1 self) {
          match UC_SMC2Dir.Pt1.epdp__smc_req.`dec m with
          | Some x => {
              r <@
                state_HybridStateWaitReq1_SMC2Dir_Pt1_smc_req
                (x.`UC_SMC2Dir.Pt1.smc_req__pt1,
                 x.`UC_SMC2Dir.Pt1.smc_req__pt2,
                 x.`UC_SMC2Dir.Pt1.smc_req__t);
            }
          | None   => { }
          end;
        }
      }
    | HybridStateWaitAdv1 pt1 pt2 t1 => {
        if (m.`1 = Adv /\ m.`2.`1 = _addr_Fwd1 self /\ m.`3.`1 = adv) {
          match Forwarding1.UC_FwAdv.epdp__fw_ok.`dec m with
          | Some _ => {
              r <@
                state_HybridStateWaitAdv1_Forwarding1_FwAdv_fw_ok
                (pt1, pt2, t1);
            }
          | None   => {  }
          end;
        }
      }
    | HybridStateWaitAdv2 pt1 pt2 t1 => {
        if (m.`1 = Adv /\ m.`2.`1 = _addr_Fwd2 self /\ m.`3.`1 = adv) {
          match Forwarding2.UC_FwAdv.epdp__fw_ok.`dec m with
          | Some _ => {
            r <@
              state_HybridStateWaitAdv2_Forwarding2_FwAdv_fw_ok
              (pt1, pt2, t1);
            }
          | None   => { }
          end;
        }
      }
    | HybridStateWaitAdv3 pt1 pt2 t1 => {
        if (m.`1 = Adv /\ m.`2.`1 = _addr_SMC1 self /\ m.`3.`1 = adv) {
          match SMC1.UC_SMC2Sim.epdp__sim_rsp.`dec m with
          | Some _ => {
              r <@
                state_HybridStateWaitAdv3_SMC1_SMC2Sim_sim_rsp
                (pt1, pt2, t1);
            }
          | None   => {  }
          end;
        }
      }
    | HybridStateWaitReq2 pt1 pt2    => {
        if (m.`1 = Dir /\ m.`2 = _extport_dir_Pt2 self) {
          match UC_SMC2Dir.Pt2.epdp__smc_req.`dec m with
          | Some x => {
              r <@
                state_HybridStateWaitReq2_SMC2Dir_Pt2_smc_req
                (pt1, pt2,
                 x.`UC_SMC2Dir.Pt2.smc_req__pt2,
                 x.`UC_SMC2Dir.Pt2.smc_req__t);
            }
          | None   => {  }
          end;
        }
      }
    | HybridStateWaitAdv4 pt1 t2     => {
        if (m.`1 = Adv /\ m.`2.`1 = _addr_SMC2 self /\ m.`3.`1 = adv) {
          match SMC2.UC_SMC2Sim.epdp__sim_rsp.`dec m with
          | Some _ => {
              r <@
                state_HybridStateWaitAdv4_SMC2_SMC2Sim_sim_rsp
                (pt1, t2);
            }
          | None   => {  }
          end;
        }
      }
    | HybridStateFinal               => { }
    end;
    return r;
  }
}.

local op invar_Hybrid (g : glob Hybrid) = true.

local op  metric_Hybrid (g : glob Hybrid) : int =
  match g.`2 with
  | HybridStateWaitReq1       => 6
  | HybridStateWaitAdv1 _ _ _ => 5
  | HybridStateWaitAdv2 _ _ _ => 4
  | HybridStateWaitAdv3 _ _ _ => 3
  | HybridStateWaitReq2 _ _   => 2
  | HybridStateWaitAdv4 _ _   => 1
  | HybridStateFinal          => 0
end.

local lemma metric_Hybrid_good (g : glob Hybrid) :
  invar_Hybrid g => 0 <= metric_Hybrid g.
proof. smt(). qed.

local lemma metric_Hybrid_init :
  hoare [Hybrid.init : true ==> invar_Hybrid (glob Hybrid)].
proof. rewrite /invar_Hybrid; auto. qed.

local lemma metric_Hybrid_invoke (n : int) :
  hoare
  [Hybrid.invoke :
   invar_Hybrid (glob Hybrid) /\
   metric_Hybrid (glob Hybrid) = n ==>
   invar_Hybrid (glob Hybrid) /\
   (res <> None => metric_Hybrid (glob Hybrid) < n)].
proof.
rewrite /invar_Hybrid /metric_Hybrid /=; proc; sp 1.
match.
if; last auto.
match; [auto | inline; auto].
if; last auto.
match; [auto | inline; auto].
if; last auto.
match; [auto | inline; auto].
if; last auto.
match; [auto | inline; auto].
if; last auto.
match; [auto | inline; auto].
if; last auto.
match; [auto | inline; auto].
auto.
qed.

local op glob_RFIP_to_self        (g : glob RFIP) : addr                  = g.`1.
local op glob_RFIP_to_st_Pt1      (g : glob RFIP) : _state_Pt1            = g.`2.
local op glob_RFIP_to_st_Pt2      (g : glob RFIP) : _state_Pt2            = g.`3.
local op glob_RFIP_to_self_Fwd1   (g : glob RFIP) : addr                  = g.`4.
local op glob_RFIP_to_st_Fwd1     (g : glob RFIP) : Forwarding1._state_IF = g.`5.
local op glob_RFIP_to_self_Fwd2   (g : glob RFIP) : addr                  = g.`6.
local op glob_RFIP_to_st_Fwd2     (g : glob RFIP) : Forwarding2._state_IF = g.`7.
local op glob_RFIP_to_self_MakeRF (g : glob RFIP) : addr                  = g.`8.
local op glob_RFIP_to_self_SMC1IF (g : glob RFIP) : addr                  = g.`9.
local op glob_RFIP_to_st_SMC1IF   (g : glob RFIP) : SMC1._state_IF        = g.`10.
local op glob_RFIP_to_self_SMC2IF (g : glob RFIP) : addr                  = g.`11.
local op glob_RFIP_to_st_SMC2IF   (g : glob RFIP) : SMC2._state_IF        = g.`12.

local op glob_Hybrid_to_self (g : glob Hybrid) : addr            = g.`1.
local op glob_Hybrid_to_st   (g : glob Hybrid) : hybrid_state = g.`2.

local op rfip_rfips_invar_static
    (func : addr, grfip : glob RFIP, gh : glob Hybrid) : bool =
  glob_RFIP_to_self grfip        = func /\
  glob_RFIP_to_self_Fwd1 grfip   = _addr_Fwd1 func /\
  glob_RFIP_to_self_Fwd2 grfip   = _addr_Fwd2 func /\
  glob_RFIP_to_self_MakeRF grfip = func /\
  glob_RFIP_to_self_SMC1IF grfip = _addr_SMC1 func /\
  glob_RFIP_to_self_SMC2IF grfip = _addr_SMC2 func /\
  glob_Hybrid_to_self gh         = func.

local op rfip_rfips_invar_static_ports
    (func : addr, grfip : glob RFIP, gh : glob Hybrid,
     pt1 pt2 : port) : bool =
  rfip_rfips_invar_static func grfip gh /\
  envport func pt1 /\ envport func pt2.

local op rfip_rfips_invar0
    (func : addr, grfip : glob RFIP, gh : glob Hybrid) : bool =
  rfip_rfips_invar_static func grfip gh /\
  glob_RFIP_to_st_Pt1 grfip      = _State_Pt1_WaitReq /\
  glob_RFIP_to_st_Pt2 grfip      = _State_Pt2_WaitFwd1 /\
  glob_RFIP_to_st_Fwd1 grfip     = Forwarding1._State_IF_Init /\
  glob_RFIP_to_st_Fwd2 grfip     = Forwarding2._State_IF_Init /\
  glob_RFIP_to_st_SMC1IF grfip   = SMC1._State_IF_WaitReq /\
  glob_RFIP_to_st_SMC2IF grfip   = SMC2._State_IF_WaitReq /\
  (* -- *)
  glob_Hybrid_to_st gh           = HybridStateWaitReq1.

local op rfip_rfips_invar1
    (func : addr, grfip : glob RFIP, gh : glob Hybrid,
     pt1 pt2 : port, t1 : text1) : bool =
  rfip_rfips_invar_static_ports func grfip gh pt1 pt2 /\
  glob_RFIP_to_st_Pt1 grfip      = _State_Pt1_WaitFwd2 pt1 t1 /\
  glob_RFIP_to_st_Pt2 grfip      = _State_Pt2_WaitFwd1 /\
  glob_RFIP_to_st_Fwd1 grfip     =
    Forwarding1._State_IF_Wait
    (_intport_Pt1 func) (_intport_Pt2 func)
    (epdp_port_port_univ.`enc (pt1, pt2)) /\
  glob_RFIP_to_st_Fwd2 grfip     = Forwarding2._State_IF_Init /\
  glob_RFIP_to_st_SMC1IF grfip   = SMC1._State_IF_WaitReq /\
  glob_RFIP_to_st_SMC2IF grfip   = SMC2._State_IF_WaitReq /\
  (* -- *)
  glob_Hybrid_to_st gh           = HybridStateWaitAdv1 pt1 pt2 t1.

local op rfip_rfips_invar2
    (func : addr, grfip : glob RFIP, gh : glob Hybrid,
     pt1 pt2 : port, t1 : text1) : bool =
  rfip_rfips_invar_static_ports func grfip gh pt1 pt2 /\
  glob_RFIP_to_st_Pt1 grfip      = _State_Pt1_WaitFwd2 pt1 t1 /\
  glob_RFIP_to_st_Pt2 grfip      = _State_Pt2_WaitSMC1 pt1 pt2 /\
  glob_RFIP_to_st_Fwd1 grfip     = Forwarding1._State_IF_Final /\
  glob_RFIP_to_st_Fwd2 grfip     =
    Forwarding2._State_IF_Wait (_intport_Pt2 func) (_intport_Pt1 func) [] /\
  glob_RFIP_to_st_SMC1IF grfip   = SMC1._State_IF_WaitReq /\
  glob_RFIP_to_st_SMC2IF grfip   = SMC2._State_IF_WaitReq /\
  (* -- *)
  glob_Hybrid_to_st gh           = HybridStateWaitAdv2 pt1 pt2 t1.

local op rfip_rfips_invar3
    (func : addr, grfip : glob RFIP, gh : glob Hybrid,
     pt1 pt2 : port, t1 : text1) : bool =
  rfip_rfips_invar_static_ports func grfip gh pt1 pt2 /\
  glob_RFIP_to_st_Pt1 grfip      = _State_Pt1_WaitSMC2 pt1 /\
  glob_RFIP_to_st_Pt2 grfip      = _State_Pt2_WaitSMC1 pt1 pt2 /\
  glob_RFIP_to_st_Fwd1 grfip     = Forwarding1._State_IF_Final /\
  glob_RFIP_to_st_Fwd2 grfip     = Forwarding2._State_IF_Final /\
  glob_RFIP_to_st_SMC1IF grfip   =
    SMC1._State_IF_WaitSim
    (_intport_Pt1 func) (_intport_Pt2 func) t1 /\
  glob_RFIP_to_st_SMC2IF grfip   = SMC2._State_IF_WaitReq /\
  (* -- *)
  glob_Hybrid_to_st gh           = HybridStateWaitAdv3 pt1 pt2 t1.

local op rfip_rfips_invar4
    (func : addr, grfip : glob RFIP, gh : glob Hybrid,
     pt1 pt2 : port) : bool =
  rfip_rfips_invar_static_ports func grfip gh pt1 pt2 /\
  glob_RFIP_to_st_Pt1 grfip      = _State_Pt1_WaitSMC2 pt1 /\
  glob_RFIP_to_st_Pt2 grfip      = _State_Pt2_WaitReq pt2 /\
  glob_RFIP_to_st_Fwd1 grfip     = Forwarding1._State_IF_Final /\
  glob_RFIP_to_st_Fwd2 grfip     = Forwarding2._State_IF_Final /\
  glob_RFIP_to_st_SMC1IF grfip   = SMC1._State_IF_Final /\
  glob_RFIP_to_st_SMC2IF grfip   = SMC2._State_IF_WaitReq /\
  (* -- *)
  glob_Hybrid_to_st gh           = HybridStateWaitReq2 pt1 pt2.

local op rfip_rfips_invar5
    (func : addr, grfip : glob RFIP, gh : glob Hybrid,
     pt1 : port, t2 : text2) : bool =
  rfip_rfips_invar_static func grfip gh /\
  envport func pt1 /\
  glob_RFIP_to_st_Pt1 grfip      = _State_Pt1_WaitSMC2 pt1 /\
  glob_RFIP_to_st_Pt2 grfip      = _State_Pt2_Final /\
  glob_RFIP_to_st_Fwd1 grfip     = Forwarding1._State_IF_Final /\
  glob_RFIP_to_st_Fwd2 grfip     = Forwarding2._State_IF_Final /\
  glob_RFIP_to_st_SMC1IF grfip   = SMC1._State_IF_Final /\
  glob_RFIP_to_st_SMC2IF grfip   =
    SMC2._State_IF_WaitSim
    (_intport_Pt2 func) (_intport_Pt1 func) t2 /\
  (* -- *)
  glob_Hybrid_to_st gh           = HybridStateWaitAdv4 pt1 t2.

local op rfip_rfips_invar6
    (func : addr, grfip : glob RFIP, gh : glob Hybrid) : bool =
  rfip_rfips_invar_static func grfip gh /\
  glob_RFIP_to_st_Pt1 grfip      = _State_Pt1_Final /\
  glob_RFIP_to_st_Pt2 grfip      = _State_Pt2_Final /\
  glob_RFIP_to_st_Fwd1 grfip     = Forwarding1._State_IF_Final /\
  glob_RFIP_to_st_Fwd2 grfip     = Forwarding2._State_IF_Final /\
  glob_RFIP_to_st_SMC1IF grfip   = SMC1._State_IF_Final /\
  glob_RFIP_to_st_SMC2IF grfip   = SMC2._State_IF_Final /\
  (* -- *)
  glob_Hybrid_to_st gh           = HybridStateFinal.

local inductive rfip_rfips_invar
    (func : addr, grfip : glob RFIP, gh : glob Hybrid) =
  | RFIP_RFIPS_Invar0 of
      (rfip_rfips_invar0 func grfip gh)
  | RFIP_RFIPS_Invar1 (pt1 pt2 : port, t1 : text1) of
      (rfip_rfips_invar1 func grfip gh pt1 pt2 t1)
  | RFIP_RFIPS_Invar2 (pt1 pt2 : port, t1 : text1) of
      (rfip_rfips_invar2 func grfip gh pt1 pt2 t1)
  | RFIP_RFIPS_Invar3 (pt1 pt2 : port, t1 : text1) of
      (rfip_rfips_invar3 func grfip gh pt1 pt2 t1)
  | RFIP_RFIPS_Invar4 (pt1 pt2 : port) of
      (rfip_rfips_invar4 func grfip gh pt1 pt2)
  | RFIP_RFIPS_Invar5 (pt1 : port, t2 : text2) of
      (rfip_rfips_invar5 func grfip gh pt1 t2)
  | RFIP_RFIPS_Invar6 of
      (rfip_rfips_invar6 func grfip gh).

local lemma RFIP_Hybrid_init (func' : addr) :
  exper_pre func' =>
  equiv
  [RFIP.init ~ Hybrid.init :
   _self{1} = self_{2} /\ _self{1} = func' ==>
   rfip_rfips_invar func' (glob RFIP){1} (glob Hybrid){2}].
proof.
move => ep_func'.
proc; inline; auto; smt(RFIP_RFIPS_Invar0).
qed.

local module RFIP_RFCore = UC_SMC2Real(SMC1.IF, SMC2.IF).

local lemma RFIP_Hybrid_invoke (func' : addr) :
  exper_pre func' =>
  equiv
  [RFIP.invoke ~ Hybrid.invoke :
   ={m} /\
   (m{1}.`1 = Dir /\ func' = m{1}.`2.`1 /\ envport func' m{1}.`3 \/
    m{1}.`1 = Adv /\ func' <= m{1}.`2.`1 /\
    m{1}.`3.`1 = adv /\ 0 < m{1}.`3.`2) /\
   rfip_rfips_invar func' (glob RFIP){1} (glob Hybrid){2} ==>
   ={res} /\
   rfip_rfips_invar func' (glob RFIP){1} (glob Hybrid){2}].
proof.
move => ep_func'.
proc.
exlim (glob RFIP){1}, (glob Hybrid){2} => grfip gh.
(* the "!!" is a hack to make the ambient case be a boolean one *)
case @[ambient] (!! rfip_rfips_invar func' grfip gh) =>
  [/= [] | ?]; last exfalso; smt().
(* rfip_rfips_invar0 *)
move => rfip_rfips_invar0_ass.
sp 1 1.
match HybridStateWaitReq1 {2} 1; first auto; smt().
if{2}.
rcondt{1} 1; first auto; smt().
inline{1} 1; sp 3 0.
rcondt{1} 1; first auto.
inline{1} 1; sp 2 0.
rcondf{1} 1; first auto; smt(@UCListPO).
rcondf{1} 1; first auto; smt(@UCListPO).
rcondf{1} 1; first auto; smt(@UCListPO).
rcondf{1} 1; first auto; smt(@UCListPO).
rcondt{1} 1; first auto; progress; smt().
inline{1} 1; sp 2 0.
match _State_Pt1_WaitReq {1} 1; first auto; smt().
match => //.
seq 3 0 :
  (! not_done{1} /\ r0{1} = None /\ r{2} = None /\
   rfip_rfips_invar0 func' (glob RFIP){1} (glob Hybrid){2}).
call{1} (RFCore.MakeRF_after_core_error RFIP_RFCore); first auto.
rcondf{1} 1; first auto.
auto; smt(RFIP_RFIPS_Invar0).
move => x1 x2; inline{1} 1; inline{2} 1; sp 4 4.
seq 0 0 :
  (#pre /\ x1 = x2 /\
   m{1} = 
   (Dir, (UC_SMC2Dir.Pt1.smc_req___func x1, UC_SMC2Dir.Pt1.pi),
    UC_SMC2Dir.Pt1.smc_req__pt1 x1, UC_SMC2Dir.Pt1._tag__smc_req,
    (epdp_pair_univ epdp_port_univ SMC2Aux'.epdp_text1_univ).`enc
     (UC_SMC2Dir.Pt1.smc_req__pt2 x1, UC_SMC2Dir.Pt1.smc_req__t x1))).
auto => />; smt(UC_SMC2Dir.Pt1.eq_of_valid__smc_req).
if; first smt().
seq 6 3 :
  (not_done{1} /\ ={pt1, pt2} /\ t{1} = t1{2} /\
   rfip_rfips_invar_static_ports func' (glob RFIP){1}
   (glob Hybrid){2} pt1{1} pt2{1} /\
   glob_RFIP_to_st_Pt1 (glob RFIP){1} =
     _State_Pt1_WaitFwd2 pt1{1} t{1} /\
   glob_RFIP_to_st_Pt2 (glob RFIP){1} = _State_Pt2_WaitFwd1 /\
   glob_RFIP_to_st_Fwd1 (glob RFIP){1} = Forwarding1._State_IF_Init /\
   glob_RFIP_to_st_Fwd2 (glob RFIP){1} = Forwarding2._State_IF_Init /\
   glob_RFIP_to_st_SMC1IF (glob RFIP){1} = SMC1._State_IF_WaitReq /\
   glob_RFIP_to_st_SMC2IF (glob RFIP){1} = SMC2._State_IF_WaitReq /\
   glob_Hybrid_to_st (glob Hybrid){2} =
     HybridStateWaitAdv1 pt1{2} pt2{2} t1{2} /\
   m0{1} =
   Forwarding1.UC_FwDir.D.epdp__fw_req.`enc
   (Forwarding1.UC_FwDir.D.mk__fw_req
    (_addr_Fwd1 func') (_intport_Pt1 func') (_intport_Pt2 func')
    (epdp_port_port_univ.`enc (pt1{1}, pt2{1}))) /\
   r{2} =
   Some
   (Forwarding1.UC_FwAdv.epdp__fw_obs.`enc
