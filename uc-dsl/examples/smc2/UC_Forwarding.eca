hint simplify [eqtrue] valid_epdp__fw_rsp.
hint rewrite epdp : valid_epdp__fw_rsp.

lemma eq_of_valid__fw_rsp (m : msg) :
  is_valid epdp__fw_rsp m =>
  m =
  let x = oget (epdp__fw_rsp.`dec m) in
(Dir, x.`fw_rsp__pt2, (x.`fw_rsp___func, pi), _tag__fw_rsp,
 (Top.UCUniv.epdp_pair_univ<:port, univ> (epdp_port_univ)
                                                         (Top.UCEncoding.epdp_id)).`enc
(x.`fw_rsp__pt1, x.`fw_rsp__u)).
proof.
rewrite /is_valid.
move => val_m.
have [] x : exists (x : _fw_rsp), epdp__fw_rsp.`dec m = Some x.
  exists (oget (dec__fw_rsp m)); rewrite -some_oget; smt(); smt().
case x => x1 x2 x3 x4.
move => /(epdp_dec_enc _ _ _ valid_epdp__fw_rsp) <-.
