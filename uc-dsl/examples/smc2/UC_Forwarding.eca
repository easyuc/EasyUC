require import UCCore.

require UCComposition.

clone UCComposition as UC_Composition.



op _adv_if_pi : int.

axiom _adv_if_pi_gt0 : 0 < _adv_if_pi.

abstract theory UC_FwDir'_abs.

op pi : int.

op _Forwarding =  [70; 111; 114; 119; 97; 114; 100; 105; 110; 103].
(*Forwarding as ascii array*)

type _fw_req =
{
  fw_req___func : addr;
  fw_req__pt1 : port;
  (*data*)
  fw_req__pt2 : port;
  fw_req__u : univ;
}.
op _fw_req =  [102; 119; 95; 114; 101; 113]. (*fw_req as ascii array*)

op _tag__fw_req =  TagBasic _Forwarding _fw_req.
op enc__fw_req (x : _fw_req) : msg =
(Dir, (x.`fw_req___func, pi), x.`fw_req__pt1, _tag__fw_req,
 (Top.UCUniv.epdp_pair_univ<:port, univ> (epdp_port_univ)
                                                         (Top.UCEncoding.epdp_id)).`enc
(x.`fw_req__pt2, x.`fw_req__u))
.
op [opaque smt_opaque] dec__fw_req (m : msg) : _fw_req option =
  let (mod, pt1, pt2, tag, v) = m
  in (mod = Adv \/ pt1.`2 <> pi \/ tag <> _tag__fw_req) ?
    None :
    match
    (Top.UCUniv.epdp_pair_univ<:port, univ> (epdp_port_univ)
                                                            (Top.UCEncoding.epdp_id)).`dec
    v with
    | None   => None
    | Some p =>
      let (fw_req__pt2 ,fw_req__u) = p in
      Some
      {|
        fw_req___func = pt1.`1; fw_req__pt1 = pt2;
        fw_req__pt2 = fw_req__pt2;
        fw_req__u = fw_req__u;
      |}
    end
.

op epdp__fw_req = {|enc = enc__fw_req; dec = dec__fw_req|}.

lemma valid_epdp__fw_req : valid_epdp epdp__fw_req.
proof.
apply epdp_intro.
move => x.
rewrite /epdp__fw_req /= /dec__fw_req /enc__fw_req /=.
by case x.
move => [mod [pt1_1 pt1_2] pt2 tag v] u.
rewrite /epdp__fw_req /dec__fw_req /enc__fw_req /=.
case (mod = Adv \/ pt1_2 <> pi \/ tag <> _tag__fw_req) => //.
rewrite !negb_or /= not_adv.
move => [#] -> -> -> match_eq_some /=.
have val_v :
  (Top.UCUniv.epdp_pair_univ<:port, univ> (epdp_port_univ)
                                                          (Top.UCEncoding.epdp_id)).`dec v =
  Some (u.`fw_req__pt2 ,u.`fw_req__u).
  move : match_eq_some.
  case ((Top.UCUniv.epdp_pair_univ<:port, univ> (epdp_port_univ)
                                                                (Top.UCEncoding.epdp_id)).`dec v) => //.
  by case.
move : match_eq_some.
rewrite val_v /= => <- /=.
apply epdp_dec_enc => //.
qed.

hint simplify [eqtrue] valid_epdp__fw_req.
hint rewrite epdp : valid_epdp__fw_req.

lemma eq_of_valid__fw_req (m : msg) :
  is_valid epdp__fw_req m =>
  m =
  let x = oget (epdp__fw_req.`dec m) in
(Dir, (x.`fw_req___func, pi), x.`fw_req__pt1, _tag__fw_req,
 (Top.UCUniv.epdp_pair_univ<:port, univ> (epdp_port_univ)
                                                         (Top.UCEncoding.epdp_id)).`enc
(x.`fw_req__pt2, x.`fw_req__u)).
proof.
rewrite /is_valid.
move => val_m.
have [] x : exists (x : _fw_req), epdp__fw_req.`dec m = Some x.
  exists (oget (dec__fw_req m)); rewrite -some_oget; smt(); smt().
case x => x1 x2 x3 x4.
move => /(epdp_dec_enc _ _ _ valid_epdp__fw_req) <-.
by rewrite !epdp.
qed.

