clone UC_FwAdv_abs as UC_FwAdv with
  op pi = 1
proof *.

type _state_IF = [ 
  | _State_IF_Final
  | _State_IF_Init
  | _State_IF_Wait of (port) & (port) & (univ)
  
]. 

module UC_Forw : FUNC= {
  var _self : addr
  var _st : _state_IF
  proc init(self_ : addr) : unit = {
    _self <- self_; _st <- _State_IF_Init;
  }
  proc _State_IF_Init__FwDir__D__fw_req (pt1 : port, pt2 : port, u : univ) : msg option = {
    var _r : msg option <- None;
    if (envport _self pt2) {
      _r <- Some
        (UC_FwAdv.epdp__fw_obs.`enc
        {|
          UC_FwAdv.fw_obs___func = _self;
          UC_FwAdv.fw_obs___adv = adv;
          UC_FwAdv.fw_obs__pt1 = pt1;
          UC_FwAdv.fw_obs__pt2 = pt2;
          UC_FwAdv.fw_obs__u = u;
          
        |});
      _st <- _State_IF_Wait (pt1) (pt2) (u);
      
    }
    else {
      _r <- None;
      
    }
    return _r;
  }
  proc _State_IF_Wait__FwAdv__fw_ok (pt1 : port, pt2 : port, u : univ) : msg option = {
    var _r : msg option <- None;
    _r <- Some
      (UC_FwDir.D.epdp__fw_rsp.`enc
      {|
        UC_FwDir.D.fw_rsp___func = _self;
        UC_FwDir.D.fw_rsp__pt2 = pt2;
        UC_FwDir.D.fw_rsp__pt1 = pt1;
        UC_FwDir.D.fw_rsp__u = u;
        
      |});
    _st <- _State_IF_Final;
    return _r;
  }
  proc parties(_m : msg) : msg option = {
    var _r : msg option <- None;
    match _st with
    | _State_IF_Final => {
      
    }
    | _State_IF_Init => {
      match UC_FwDir.D.epdp__fw_req.`dec _m with
      | Some _x => {
        _r <@ _State_IF_Init__FwDir__D__fw_req (_x.`UC_FwDir.D.fw_req__pt1, _x.`UC_FwDir.D.fw_req__pt2, _x.`UC_FwDir.D.fw_req__u);
      }
      | None => {
        
      }
      end;
    }
    | _State_IF_Wait pt1 pt2 u => {
      match UC_FwAdv.epdp__fw_ok.`dec _m with
      | Some _x => {
        _r <@ _State_IF_Wait__FwAdv__fw_ok (pt1, pt2, u);
      }
      | None => {
        
      }
      end;
    }
    end;
    return _r;
  }
  proc invoke(m : msg) : msg option = {
    var r : msg option <- None;
    if ((m.`1 = Dir /\ m.`2.`1 = _self /\ envport _self m.`3)\/ (m.`1 = Adv
                                                               /\
                                                               m.`2.`1 = _self
                                                               /\
                                                               m.`3.`1 = adv)){
      r <@ parties(m);
    }
  return r;
  }
  
}.


(*alias*)
module IF = UC_Forw.
op _invar_IF (g : glob IF) : bool = true.

 

op glob_UC_Forw_to__st (g : glob UC_Forw) / : _state_IF = g.`2.
op [smt_opaque] _metric_IF (g : glob UC_Forw) : int =
  match glob_UC_Forw_to__st g with
  | _State_IF_Final => 0
  | _State_IF_Init => 2
  | _State_IF_Wait _ _ _ => 1
  end.
  


lemma IF_invoke (n : int) : hoare [
  UC_Forw.invoke :
  _invar_IF (glob UC_Forw) /\ _metric_IF (glob UC_Forw) = n
  ==>
  _invar_IF (glob UC_Forw) /\ 
  (res <> None =>
  _metric_IF (glob UC_Forw) < n
  /\ ((oget res).`1 = Adv => (oget res).`2.`2 \in oflist [_adv_if_pi] /\ (oget res).`3.`2 = 1))
   ].
proof. rewrite /_metric_IF /=. proc. sp 1. (*initializing return value*)
if. (*invoke guard*) inline. sp 1. sp 1. (*initializing input, return value*)
match. (*state match*)
(*state branch Final*) sp 1. skip. move => />;smt(). (*empty state match branch code*)
(*state branch Init*) match. (*message match*)
sp 1. skip. move => />;smt(). (*None branch of message match, dec failed*)
sp 1. (*state param assignment, return value initialization*)sp 3. (*pattern bindings*)
if. (*if instruction*)
sp 1. sp 3. skip. move => />;smt(mem_oflist mem_rangeset in_fsetU). (*SendAndTransition instruction*)
 sp 1. sp 2. skip. move => />;smt(). (*Fail instruction*)  
(*state branch Wait*) match. (*message match*)
sp 1. skip. move => />;smt(). (*None branch of message match, dec failed*)
sp 4. (*state param assignment, return value initialization*)sp 1. sp 3. skip. move => />;smt(mem_oflist mem_rangeset in_fsetU). (*SendAndTransition instruction*)
 skip. smt(). (*invoke guard false*) qed. 

lemma IF_metric_good (g : glob IF) :   _invar_IF g => 0 <= _metric_IF g.
  proof. rewrite /_metric_IF /=.   smt(). qed.   lemma IF_init :
  hoare [IF.init : true ==> _invar_IF (glob IF)]. proof. proc. auto. qed. 
 


